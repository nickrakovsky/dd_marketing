---
export interface Props {
  videoId: string;
  title?: string;
}

const { videoId, title = "Related Short" } = Astro.props;
---

<div class="sidebar-card mb-4 !p-0 overflow-hidden border border-[#E5D3B3] dark:border-gray-700">
  <div class="p-3 border-b border-[#E5D3B3] dark:border-gray-700 bg-white dark:bg-gray-800">
    <div class="sidebar-card-title">{title}</div>
  </div>
  
  <div class="w-full bg-black">
    <lite-youtube 
      videoid={videoId} 
      playlabel="Play short" 
      params="rel=0" 
      class="lite-youtube-short w-full"
    ></lite-youtube>
  </div>
</div>

<style>
  /* Override the default 16:9 aspect ratio from global lite-youtube styles for this vertical video */
  .lite-youtube-short::after {
    padding-bottom: calc(100% / (9 / 16)) !important;
  }
</style>
