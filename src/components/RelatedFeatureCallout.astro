---
// src/components/RelatedFeatureCallout.astro
import type { CollectionEntry } from 'astro:content';

interface Props {
  feature: CollectionEntry<'features'>;
  isSidebar?: boolean;
}

const { feature, isSidebar = false } = Astro.props;
const { title, description, icon } = feature.data;

// Clean up the icon path if it contains a Keystatic hash prefix (e.g. /images/features/63d76..._name.svg)
const cleanIcon = icon ? icon.replace(/\/([0-9a-fA-F]{24})_/, '/') : '';
---

{isSidebar ? (
  /* Sidebar Layout (Desktop) */
  <div class="border-2 border-black bg-[#FFF8EE] dark:bg-gray-800 p-5 rounded-none shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] dark:shadow-[4px_4px_0px_0px_rgba(255,255,255,0.15)] transition-all duration-300 not-prose">
    {cleanIcon && (
      <div class="w-12 h-12 mb-4 bg-white dark:bg-gray-900 border-2 border-black flex items-center justify-center p-2 rounded-none">
        <img 
          src={cleanIcon} 
          alt="" 
          class="w-full h-full object-contain" 
          loading="lazy" 
        />
      </div>
    )}
    <h3 class="font-bruta uppercase text-[#fd4f00] dark:text-[#ff7635] text-lg font-bold tracking-wider leading-tight mb-2">
      {title}
    </h3>
    <p class="font-recoleta text-sm text-gray-700 dark:text-gray-300 leading-relaxed mb-4">
      {description}
    </p>
    <a 
      href={`/datadocks-features/${feature.slug}`} 
      class="inline-flex items-center justify-center w-full py-2.5 px-4 bg-[#fd4f00] hover:bg-black text-white text-center rounded-none font-recoleta font-bold text-sm border-b-4 border-transparent hover:border-b-[#fd4f00] transition-all"
    >
      Learn More
    </a>
  </div>
) : (
  /* Inline Layout (Mobile / Tablet) */
  <div class="border-2 border-black bg-[#FFF8EE] dark:bg-gray-800 p-6 rounded-none shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] dark:shadow-[4px_4px_0px_0px_rgba(255,255,255,0.15)] transition-all duration-300 not-prose">
    <div class="flex flex-col sm:flex-row items-start gap-5">
      {cleanIcon && (
        <div class="w-14 h-14 bg-white dark:bg-gray-900 border-2 border-black flex items-center justify-center p-2 rounded-none shrink-0">
          <img 
            src={cleanIcon} 
            alt="" 
            class="w-full h-full object-contain" 
            loading="lazy" 
          />
        </div>
      )}
      <div class="flex-grow">
        <h3 class="font-bruta uppercase text-[#fd4f00] dark:text-[#ff7635] text-xl font-bold tracking-wider leading-tight mb-2">
          {title}
        </h3>
        <p class="font-recoleta text-base text-gray-700 dark:text-gray-300 leading-relaxed mb-4">
          {description}
        </p>
        <a 
          href={`/datadocks-features/${feature.slug}`} 
          class="inline-flex items-center justify-center py-2.5 px-6 bg-[#fd4f00] hover:bg-black text-white text-center rounded-none font-recoleta font-bold text-sm border-b-4 border-transparent hover:border-b-[#fd4f00] transition-all"
        >
          Explore Feature
        </a>
      </div>
    </div>
  </div>
)}
