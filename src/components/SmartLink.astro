---
// src/components/SmartLink.astro
import { getEntry } from 'astro:content';

interface Props {
  href?: string;
  id?: string;
  type?: 'feature' | 'benefit' | 'post' | 'glossary' | 'academic' | 'video' | 'external';
  title?: string;
  snippet?: string;
  bibRef?: string;
  citation?: string;
  class?: string;
  anchorText?: string;
}

const props = Astro.props;
let { href, id, type, title, snippet, bibRef, citation, class: className, anchorText } = props;

// Infer type and id from href if possible
let parsedHref = href || '';
if (parsedHref.startsWith('/') && !parsedHref.startsWith('//')) {
  parsedHref = parsedHref.replace(/\.mdx?(#.*)?$/, '$1');
  if (href) href = parsedHref;
}
if (parsedHref.startsWith('http://datadocks.com') || parsedHref.startsWith('https://datadocks.com') || parsedHref.startsWith('https://www.datadocks.com')) {
  try {
    const url = new URL(parsedHref);
    parsedHref = url.pathname + url.search + url.hash;
  } catch(e) {}
}

if (parsedHref && !type) {
  if (parsedHref.startsWith('/posts/')) {
    type = 'post';
    id = id || parsedHref.replace('/posts/', '').replace(/\/$/, '').split('#')[0];
  } else if (parsedHref.startsWith('/videos/')) {
    type = 'video';
    id = id || parsedHref.replace('/videos/', '').replace(/\/$/, '').split('#')[0];
  } else if (parsedHref.startsWith('/datadocks-features/')) {
    type = 'feature';
    id = id || parsedHref.replace('/datadocks-features/', '').replace(/\/$/, '').split('#')[0];
  } else if (parsedHref.startsWith('/benefits/')) {
    type = 'benefit';
    id = id || parsedHref.replace('/benefits/', '').replace(/\/$/, '').split('#')[0];
  } else if (parsedHref.startsWith('#ref') || parsedHref.startsWith('#cite')) {
    type = 'academic';
    bibRef = bibRef || parsedHref;
  } else if (parsedHref.startsWith('http://') || parsedHref.startsWith('https://')) {
    type = 'external' as any;
    try {
      const extUrl = new URL(parsedHref);
      title = title || extUrl.hostname.replace(/^www\./, '');
      snippet = snippet || '';
    } catch(e) {
      title = title || 'External Link';
    }
  }
}

if (id) {
  id = id.replace(/\.mdx?$/, '');
}

// Fetch data
let youtubeId = '';
let iconStr = '';
if (type === 'glossary' && id) {
  const entry = await getEntry('glossary', id);
  if (entry) {
    title = title || entry.data.termName;
    snippet = snippet || entry.data.contextSnippet;
    href = href || (entry.data.targetPost ? `/posts/${entry.data.targetPost.id}` : '#');
  }
} else if (type === 'post' && id) {
  const entry = await getEntry('posts', id);
  if (entry) {
    title = title || entry.data.title;
    snippet = snippet || entry.data.description;
    href = href || `/posts/${id}`;
  }
} else if (type === 'video' && id) {
  const entry = await getEntry('videos', id);
  if (entry) {
    title = title || entry.data.title;
    snippet = snippet || entry.data.description;
    href = href || `/videos/${id}`;
    youtubeId = entry.data.postType?.value?.youtubeId || '';
    if (entry.data.postType?.discriminant === 'video') {
      type = 'video-widescreen' as any;
    }
  }
} else if (type === 'feature' && id) {
  const entry = await getEntry('features', id);
  if (entry) {
    title = title || entry.data.title;
    snippet = snippet || entry.data.description;
    href = href || `/datadocks-features/${id}`;
    if (entry.data.icon) {
      iconStr = entry.data.icon.replace(/\/([0-9a-fA-F]{24})_/, '/');
    }
  }
} else if (type === 'benefit' && id) {
  href = href || `/benefits/${id}`;
  const benefitsData: Record<string, {title: string, desc: string, icon: string}> = {
    'increase-capacity': { title: 'Increase Capacity', desc: 'Eliminate bottlenecks and slash overtime costs. DataDocks optimizes your appointment slots based on actual load times.', icon: '/images/features/linechart-file.svg' },
    'digitize-operations': { title: 'Digitize Operations', desc: 'Move away from paper and spreadsheets. Get real-time visibility into your yard and docks.', icon: '/images/features/checked-laptop.svg' },
    'delight-carriers': { title: 'Delight Carriers', desc: 'Become a shipper of choice. Give carriers a self-serve portal to book appointments 24/7.', icon: '/images/features/people.svg' },
    'see-everything': { title: 'See Everything', desc: 'A single dashboard for all your operations. Connect your teams with live updates.', icon: '/images/features/vision.svg' }
  };
  if (benefitsData[id]) {
    title = title || `${benefitsData[id].title} with DataDocks`;
    snippet = snippet || benefitsData[id].desc;
    iconStr = benefitsData[id].icon;
  }
} else if (type === 'academic') {
  // Academic links rely on manually passed title/snippet and bibRef or href.
  href = href || '#';
  title = title || "Academic Source";
} else if (type === 'external') {
  // External links — title is the domain, snippet can be overridden
  title = title || 'External Link';
}

const isSmartLink = !!type && (title || snippet);
---

{!isSmartLink ? (
  <a href={href} class={className || "font-medium text-[#fd4f00] hover:underline"}
    {...(href?.startsWith('http') ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
  >
    <slot>{anchorText || href}</slot>
  </a>
) : (
  <a 
    href={href !== '#' ? href : undefined} 
    data-smartlink-trigger="true"
    data-smartlink-type={type}
    data-smartlink-title={title}
    data-smartlink-snippet={snippet}
    data-smartlink-href={href}
    data-smartlink-bibref={bibRef}
    data-smartlink-youtube-id={youtubeId}
    data-smartlink-icon={iconStr}
    class={`inline underline decoration-dotted decoration-[#fd4f00] lg:decoration-gray-400 hover:decoration-[#fd4f00] !text-inherit hover:!text-[#fd4f00] dark:hover:!text-[#ff7635] transition-colors cursor-pointer font-medium data-[highlighted=true]:!text-[#fd4f00] data-[highlighted=true]:decoration-[#fd4f00] ${className || ''}`}
    {...(type === 'external' ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
  ><slot>{anchorText || id}</slot>{citation && <sup class="text-[#fd4f00] dark:text-[#ff7635] ml-0.5 font-bold">{citation}</sup>}{type === 'external' && <svg class="inline w-3 h-3 ml-0.5 -mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>}<span class="inline lg:hidden ml-0.5 text-[#fd4f00] text-xs font-bold align-super" aria-hidden="true">?</span></a>
)}

<script>
  let hoverTimeout: number | undefined;

  function ensureUIElements() {
    if (document.getElementById('smartlink-scrim')) return;

    // Create Scrim
    const scrim = document.createElement('div');
    scrim.id = 'smartlink-scrim';
    scrim.className = 'fixed inset-0 bg-black/40 hidden z-40 transition-opacity duration-300 opacity-0';
    scrim.setAttribute('aria-hidden', 'true');
    document.body.appendChild(scrim);

    // Create Mobile Sheet
    const sheet = document.createElement('div');
    sheet.id = 'smartlink-mobile-sheet';
    sheet.className = 'fixed bottom-0 inset-x-0 z-50 translate-y-full transition-transform duration-300 bg-[#FFF8E9] dark:bg-gray-800 rounded-t-2xl shadow-2xl border-t border-[#E5D3B3] dark:border-gray-700 overflow-hidden not-prose';
    sheet.setAttribute('role', 'dialog');
    sheet.setAttribute('aria-labelledby', 'sl-mobile-title');
    sheet.innerHTML = `
      <div class="w-12 h-1.5 bg-gray-300 dark:bg-gray-600 rounded-full mx-auto mt-3 mb-2"></div>
      <div class="px-6 pb-8 pt-2">
        <h3 id="sl-mobile-title" class="text-2xl font-bruta uppercase text-[#fd4f00] dark:text-[#ff7635] mb-3"></h3>
        <p id="sl-mobile-snippet" class="text-gray-700 dark:text-gray-300 font-recoleta text-lg leading-relaxed mb-6"></p>
        <div id="sl-mobile-actions" class="flex flex-col gap-3"></div>
      </div>
    `;
    document.body.appendChild(sheet);

    // Create Desktop Card
    const card = document.createElement('div');
    card.id = 'smartlink-desktop-card';
    card.className = 'fixed z-50 hidden w-80 bg-white dark:bg-gray-800 shadow-2xl border border-[#E5D3B3] dark:border-gray-700 rounded-xl transition-opacity duration-200 opacity-0 group not-prose';
    card.innerHTML = `
      <div class="absolute -inset-y-6 inset-x-0 pointer-events-auto"></div>
      <div class="relative p-4">
        <h3 id="sl-desktop-title" class="font-sans text-sm font-bold text-gray-900 dark:text-white m-0 leading-tight"></h3>
        <p id="sl-desktop-snippet" class="font-sans text-xs text-gray-600 dark:text-gray-400 mt-1 leading-snug"></p>
        <div id="sl-desktop-actions" class="mt-3 flex items-center gap-3"></div>
      </div>
    `;
    document.body.appendChild(card);
  }

  function getActionLinksHTML(type: string, href: string, bibRef: string, isMobile: boolean): string {
    if (type === 'academic') {
      const btnClass = isMobile 
        ? "inline-flex items-center justify-center w-full py-3 px-4 bg-[#fd4f00] text-white rounded-none font-recoleta font-bold text-lg border-b-4 border-transparent hover:bg-black transition-all"
        : "inline-flex items-center gap-1 font-sans text-xs font-semibold text-gray-500 dark:text-gray-400 hover:text-[#fd4f00] dark:hover:text-[#ff7635] hover:underline w-fit";
      const secClass = isMobile
        ? "inline-flex items-center justify-center w-full py-3 px-4 bg-gray-200 text-gray-800 rounded-none font-recoleta font-bold text-lg border-b-4 border-transparent hover:bg-gray-300 transition-all"
        : "inline-flex items-center gap-1 font-sans text-xs font-semibold text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white hover:underline w-fit";
        
      let html = '';
      if (href && href !== '#') {
        html += `<a href="${href}" target="_blank" rel="noopener noreferrer" class="${btnClass}">View Source</a>`;
      }
      if (bibRef) {
        html += `<a href="${bibRef}" class="${secClass}" onclick="closeSmartLinkUI()">Go to Bibliography</a>`;
      }
      return html;
    } 
    
    if (type === 'glossary' && (!href || href === '#')) {
      return ''; 
    }

    const linkText = type === 'video' ? 'Watch video' : type === 'feature' ? 'Explore feature' : type === 'external' ? 'Visit site' : 'Read more';
    const targetAttrs = type === 'external' ? 'target="_blank" rel="noopener noreferrer"' : '';
    
    if (isMobile) {
      return `<a href="${href}" ${targetAttrs} class="inline-flex items-center justify-center w-full py-3 px-4 bg-[#fd4f00] text-white text-center rounded-none font-recoleta font-bold text-lg border-b-4 border-transparent hover:bg-black transition-all">${linkText}</a>`;
    } else {
      return `<a href="${href}" ${targetAttrs} class="inline-flex items-center gap-1 font-sans text-xs font-semibold text-gray-500 dark:text-gray-400 hover:text-[#fd4f00] dark:hover:text-[#ff7635] hover:underline w-fit">
        ${linkText}
        <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
          ${type === 'external' ? '<path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />' : '<path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />'}
        </svg>
      </a>`;
    }
  }

  function getPremiumCardHTML(dataset: any) {
    const type = dataset.smartlinkType;
    const href = dataset.smartlinkHref || '#';
    const title = (dataset.smartlinkTitle || '').replace(/</g, '&lt;');
    const snippet = (dataset.smartlinkSnippet || '').replace(/</g, '&lt;');
    const icon = dataset.smartlinkIcon || '';
    
    let iconHtml = '';
    if (icon) {
      iconHtml = `
        <div class="w-7 h-7 bg-gray-50 border border-[#E5D3B3] flex items-center justify-center p-1 rounded-lg shrink-0">
          <img src="${icon}" alt="" class="w-full h-full object-contain" loading="lazy" />
        </div>`;
    }
    
    return `
      <div class="relative border border-[#E5D3B3] dark:border-gray-700 border-t-4 border-t-[#fd4f00] bg-white dark:bg-gray-800 p-4 rounded-xl shadow-md hover:shadow-lg transition-all duration-300 not-prose group/feature">
        <div class="flex items-center gap-2.5 mb-2">
          ${iconHtml}
          <h3 class="font-sans text-sm font-bold text-[#fd4f00] dark:text-[#ff7635] leading-tight m-0">
            <a href="${href}" class="before:absolute before:inset-0 outline-none hover:underline">
              ${title}
            </a>
          </h3>
        </div>
        <p class="font-sans text-xs text-gray-600 dark:text-gray-400 mt-2 leading-relaxed pr-6">
          ${snippet}
        </p>
        <div class="absolute bottom-4 right-4 text-[#fd4f00] dark:text-[#ff7635] opacity-60 group-hover/feature:opacity-100 transition-opacity">
          <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </div>
      </div>
    `;
  }

  window.closeSmartLinkUI = function() {
    const sheet = document.getElementById('smartlink-mobile-sheet');
    const scrim = document.getElementById('smartlink-scrim');
    const card  = document.getElementById('smartlink-desktop-card');
    
    if (sheet && scrim) {
      sheet.classList.add('translate-y-full');
      scrim.classList.remove('opacity-100');
      setTimeout(() => scrim.classList.add('hidden'), 300);
    }
    if (card) {
      card.classList.remove('opacity-100');
      setTimeout(() => card.classList.add('hidden'), 200);
    }
  };

  function openMobileSheet(trigger: HTMLElement) {
    ensureUIElements();
    const sheet  = document.getElementById('smartlink-mobile-sheet');
    const scrim  = document.getElementById('smartlink-scrim');
    const title  = document.getElementById('sl-mobile-title');
    const snip   = document.getElementById('sl-mobile-snippet');
    const actions = document.getElementById('sl-mobile-actions');
    if (!sheet || !scrim || !actions) return;

    const type = trigger.dataset.smartlinkType || 'post';
    const href = trigger.dataset.smartlinkHref || '#';
    const bibRef = trigger.dataset.smartlinkBibref || '';

    if (title) title.textContent = trigger.dataset.smartlinkTitle  || 'Reference';
    if (snip)  snip.textContent  = trigger.dataset.smartlinkSnippet || '';
    
    actions.innerHTML = getActionLinksHTML(type, href, bibRef, true);

    scrim.classList.remove('hidden');
    requestAnimationFrame(() => {
      scrim.classList.add('opacity-100');
      sheet.classList.remove('translate-y-full');
    });

    const closeOnScrim = () => {
      window.closeSmartLinkUI();
      scrim.removeEventListener('click', closeOnScrim);
    };
    scrim.addEventListener('click', closeOnScrim);
  }

  function createPersistentCard(trigger: HTMLElement): HTMLElement {
    const type = trigger.dataset.smartlinkType || 'post';
    const href = trigger.dataset.smartlinkHref || '#';
    const bibRef = trigger.dataset.smartlinkBibref || '';
    const youtubeId = trigger.dataset.smartlinkYoutubeId || '';
    const title = (trigger.dataset.smartlinkTitle || 'Reference').replace(/</g, '&lt;');
    const snippet = (trigger.dataset.smartlinkSnippet || '').replace(/</g, '&lt;');

    const card = document.createElement('div');
    card.className = 'absolute left-0 z-30 w-full smartlink-persistent-card group transition-all duration-300 pointer-events-auto transform';

    if (type === 'feature' || type === 'benefit') {
       card.classList.add('opacity-70', 'data-[hovered=true]:opacity-100', 'data-[hovered=true]:z-40');
       card.innerHTML = getPremiumCardHTML(trigger.dataset);
    } else {
       card.classList.add('sidebar-card', 'opacity-40', 'grayscale', 'dark:opacity-50', 'dark:grayscale', 'data-[hovered=true]:opacity-100', 'data-[hovered=true]:grayscale-0', 'data-[hovered=true]:z-40');
       const actionsHtml = getActionLinksHTML(type, href, bibRef, false);

       let mediaHtml = '';
       if (type === 'video' && youtubeId) {
         card.classList.remove('grayscale', 'dark:grayscale', 'opacity-40', 'dark:opacity-50');
         card.classList.add('opacity-100');
         card.dataset.hovered = 'true';
         card.style.padding = '0px';
         mediaHtml = `
           <div class="p-3 border-b border-[#E5D3B3] dark:border-gray-700 bg-white dark:bg-gray-800 rounded-t-xl">
             <div class="sidebar-card-title">${title}</div>
           </div>
           <div class="w-full bg-black relative rounded-b-xl overflow-hidden" style="padding-bottom: calc(100% / (9 / 16));">
             <lite-youtube videoid="${youtubeId}" playlabel="Play short" params="rel=0" class="absolute inset-0 w-full h-full"></lite-youtube>
           </div>
         `;
         card.innerHTML = mediaHtml;
       } else {
         card.innerHTML = `
           <h3 class="sidebar-card-title">${title}</h3>
           <p class="sidebar-card-snippet">${snippet}</p>
           <div class="mt-3 flex items-center gap-3">
             ${actionsHtml}
           </div>`;
       }
    }
    return card;
  }

  function showHoverCard(trigger: HTMLElement, e: MouseEvent) {
    if (window.innerWidth < 768 || window.innerWidth >= 1024) return;
    clearTimeout(hoverTimeout);
    ensureUIElements();
    const card    = document.getElementById('smartlink-desktop-card');
    const dTitle  = document.getElementById('sl-desktop-title');
    const dSnip   = document.getElementById('sl-desktop-snippet');
    const actions = document.getElementById('sl-desktop-actions');
    if (!card || !actions) return;

    const type = trigger.dataset.smartlinkType || 'post';
    const href = trigger.dataset.smartlinkHref || '#';
    const bibRef = trigger.dataset.smartlinkBibref || '';

    if (dTitle) dTitle.textContent = trigger.dataset.smartlinkTitle  || 'Reference';
    if (dSnip)  dSnip.textContent  = trigger.dataset.smartlinkSnippet || '';
    
    actions.innerHTML = getActionLinksHTML(type, href, bibRef, false);

    const cardWidth  = 320; // w-80
    const cardH      = card.offsetHeight || 180;
    const roomAbove  = e.clientY > cardH + 10;
    
    let leftPos = e.clientX - (cardWidth / 2);
    leftPos = Math.max(16, Math.min(leftPos, window.innerWidth - cardWidth - 16));
    
    card.style.left     = `${leftPos}px`;
    card.style.width    = `${cardWidth}px`;
    card.style.top      = roomAbove
      ? `${e.clientY - cardH - 4}px`
      : `${e.clientY + 4}px`;

    card.classList.remove('hidden');
    requestAnimationFrame(() => card.classList.add('opacity-100'));
  }

  function hideHoverCard() {
    hoverTimeout = window.setTimeout(() => {
      const card = document.getElementById('smartlink-desktop-card');
      if (card) {
        card.classList.remove('opacity-100');
        setTimeout(() => {
          if (!card.classList.contains('opacity-100')) {
            card.classList.add('hidden');
          }
        }, 200);
      }
    }, 150);
  }

  function positionPersistentCards() {
    if (window.innerWidth < 1024) return;
    const sidebar = document.getElementById('blog-right-sidebar');
    if (!sidebar) return;

    // Remove existing dynamic cards to recalculate cleanly
    sidebar.querySelectorAll('.smartlink-persistent-card').forEach(c => c.remove());

    const contentArea = document.getElementById('content');
    if (!contentArea) return;
    const contentTop = contentArea.getBoundingClientRect().top + window.scrollY;

    const placedCards: { top: number; bottom: number; el: HTMLElement; isFallback?: boolean }[] = [];
    const minGap = 32;
    const minTopOffset = 400; // Fallback cards must not appear within first 400px of article
    const minFallbackSeparation = 250; // Min vertical distance between fallback cards
    
    // Account for existing static sidebar items (Lead Capture, Video)
    const staticItems = Array.from(sidebar.children).filter(el => !el.classList.contains('smartlink-persistent-card')) as HTMLElement[];
    let staticHeightUsed = 0;
    
    if (staticItems.length > 0) {
        const lastItem = staticItems[staticItems.length - 1];
        staticHeightUsed = lastItem.offsetTop + lastItem.offsetHeight + minGap;
        
        staticItems.forEach(item => {
           placedCards.push({
               top: item.offsetTop,
               bottom: item.offsetTop + item.offsetHeight,
               el: item
           });
        });
    }

    const allTriggers = Array.from(document.querySelectorAll('[data-smartlink-trigger="true"]')) as HTMLElement[];

    // Fallback Logic: Inject at most 1 feature + 1 benefit card
    const fallbackDataEl = document.getElementById('smartlink-fallback-data');
    if (fallbackDataEl) {
        let features: any[] = [];
        let benefits: any[] = [];
        try {
            features = JSON.parse(fallbackDataEl.dataset.features || '[]');
            benefits = JSON.parse(fallbackDataEl.dataset.benefits || '[]');
        } catch(e) {}
        
        // Find first unlinked feature
        let featureFallback: any = null;
        for (const f of features) {
            const isLinked = allTriggers.some(el => {
                return el.dataset.smartlinkType === 'feature' && (el.dataset.smartlinkHref || '').includes(f.id);
            }) || Array.from(document.querySelectorAll('[data-feature-callout-anchor="true"] a')).some(a => {
                return (a.getAttribute('href') || '').includes(f.id);
            });
            if (!isLinked) { featureFallback = { type: 'feature', ...f }; break; }
        }
        
        // Find first unlinked benefit
        let benefitFallback: any = null;
        for (const b of benefits) {
            const isLinked = allTriggers.some(el => {
                return el.dataset.smartlinkType === 'benefit' && (el.dataset.smartlinkHref || '').includes(b.id);
            });
            if (!isLinked) { benefitFallback = { type: 'benefit', ...b }; break; }
        }

        const fallbackItems = [featureFallback, benefitFallback].filter(Boolean);
        const headings = Array.from(document.querySelectorAll('.prose h2')) as HTMLElement[];
        
        // Place feature at H2#1, benefit at H2#3+ (with minimum separation)
        const targetIndices = [1, Math.max(3, Math.min(headings.length - 1, 4))];
        let lastFallbackY = -Infinity;
        
        fallbackItems.forEach((item, index) => {
            const hIdx = Math.min(targetIndices[index] || 1, headings.length - 1);
            const heading = headings[hIdx];
            if (heading) {
                const dummyTrigger = document.createElement('span');
                Object.assign(dummyTrigger.dataset, {
                    smartlinkType: item.type,
                    smartlinkHref: item.url,
                    smartlinkTitle: item.title,
                    smartlinkSnippet: item.description,
                    smartlinkIcon: item.icon
                });
                const pCard = createPersistentCard(dummyTrigger);
                pCard.dataset.hovered = 'true'; 
                pCard.classList.remove('opacity-70'); // fully opaque fallback
                
                sidebar.appendChild(pCard);
                const h = pCard.offsetHeight || 120;
                
                let idealY = (heading.getBoundingClientRect().top + window.scrollY) - contentTop;
                idealY = Math.max(idealY, staticHeightUsed);
                idealY = Math.max(idealY, minTopOffset); // Enforce minimum distance from top
                idealY = Math.max(idealY, lastFallbackY + minFallbackSeparation); // Enforce separation
                lastFallbackY = idealY + h;

                placedCards.push({
                    top: idealY,
                    bottom: idealY + h,
                    el: pCard,
                    isFallback: true
                });
            }
        });
    }

    // Now place natural triggers
    allTriggers.forEach((trigger) => {
      if (trigger.dataset.smartlinkType === 'video-widescreen') return;

      let cardEl = trigger.cardEl;
      if (!cardEl) {
        cardEl = createPersistentCard(trigger);
        trigger.cardEl = cardEl;

        const currentCardEl = cardEl; // Capture in closure
        currentCardEl.addEventListener('mouseenter', () => {
          currentCardEl.dataset.hovered = 'true';
          trigger.dataset.highlighted = 'true';
        });
        currentCardEl.addEventListener('mouseleave', () => {
          currentCardEl.dataset.hovered = 'false';
          trigger.dataset.highlighted = 'false';
        });
      }
      sidebar.appendChild(cardEl);

      const triggerRect = trigger.getBoundingClientRect();
      const triggerY = (triggerRect.top + window.scrollY) - contentTop;

      let idealY = triggerY;
      idealY = Math.max(idealY, staticHeightUsed);

      const h = cardEl.offsetHeight || 120;
      placedCards.push({ top: idealY, bottom: idealY + h, el: cardEl });
    });

    // Identify table blocker regions
    const tables = Array.from(document.querySelectorAll('.prose .table-wrapper')) as HTMLElement[];
    const tableBlockers = tables.map(t => {
      const rect = t.getBoundingClientRect();
      const top = (rect.top + window.scrollY) - contentTop - minGap;
      const bottom = (rect.bottom + window.scrollY) - contentTop + minGap;
      return { top, bottom };
    });

    // Resolve overlaps (Shift DOWN)
    placedCards.sort((a, b) => a.top - b.top);
    for (let i = 0; i < placedCards.length; i++) {
      const curr = placedCards[i];
      const cardH = curr.bottom - curr.top;
      
      // 1. Avoid previous cards
      if (i > 0) {
        const prev = placedCards[i - 1];
        if (curr.top < prev.bottom + minGap) {
          const shift = (prev.bottom + minGap) - curr.top;
          curr.top += shift;
          curr.bottom += shift;
        }
      }

      // 2. Avoid tables — try placing ABOVE the table first, then below
      for (const tb of tableBlockers) {
        if (curr.top < tb.bottom && curr.bottom > tb.top) {
          // Card overlaps this table. Try above first.
          const abovePos = tb.top - cardH - minGap;
          const belowPos = tb.bottom;
          // Only place above if there's room (not overlapping previous card)
          const prevBottom = i > 0 ? placedCards[i - 1].bottom + minGap : staticHeightUsed;
          if (abovePos >= prevBottom && abovePos >= 0) {
            curr.top = abovePos;
            curr.bottom = abovePos + cardH;
          } else {
            // Place below the table
            curr.top = belowPos;
            curr.bottom = belowPos + cardH;
          }
        }
      }
      // Final check: if still overlapping any table after repositioning, push below
      let overlapWithTable = true;
      let safetyCounter = 0;
      while (overlapWithTable && safetyCounter < 10) {
        overlapWithTable = false;
        safetyCounter++;
        for (const tb of tableBlockers) {
          if (curr.top < tb.bottom && curr.bottom > tb.top) {
            curr.top = tb.bottom;
            curr.bottom = tb.bottom + cardH;
            overlapWithTable = true;
          }
        }
      }
    }

    // Resolve bottom collision (Shift UP)
    const prose = document.querySelector('.prose') as HTMLElement;
    if (prose && placedCards.length > 0) {
       const proseBottom = prose.offsetTop + prose.offsetHeight;
       const lastCard = placedCards[placedCards.length - 1];
       if (lastCard.bottom > proseBottom) {
          const shiftUp = lastCard.bottom - proseBottom;
          lastCard.top -= shiftUp;
          lastCard.bottom -= shiftUp;
          
          for (let i = placedCards.length - 2; i >= 0; i--) {
             const curr = placedCards[i];
             const next = placedCards[i + 1];
             if (curr.bottom > next.top - minGap) {
                const overlap = curr.bottom - (next.top - minGap);
                curr.top -= overlap;
                curr.bottom -= overlap;
             }
          }
       }
    }

    // Apply styles
    placedCards.forEach(c => {
       if (c.el.classList.contains('smartlink-persistent-card')) {
           c.el.style.top = `${c.top}px`;
       }
    });

    const lastCardFinal = placedCards[placedCards.length - 1];
    if (lastCardFinal) {
      sidebar.style.minHeight = `${lastCardFinal.bottom + minGap}px`;
    }
  }

  function attachSmartLinkEvents() {
    const triggers = document.querySelectorAll('[data-smartlink-trigger="true"]');
    
    // Inject inline tablet cards
    triggers.forEach(el => {
        const trigger = el as HTMLElement;
        if (trigger.dataset.smartlinkInlineBound) return;
        trigger.dataset.smartlinkInlineBound = 'true';
        
        const type = trigger.dataset.smartlinkType;
        if (type === 'feature' || type === 'benefit' || type === 'video-widescreen') {
            const parentP = trigger.closest('p, li') as HTMLElement;
            if (parentP && parentP.parentNode && !parentP.dataset.hasInlineCard) {
                const inlineCard = document.createElement('div');
                
                if (type === 'video-widescreen') {
                    const youtubeId = trigger.dataset.smartlinkYoutubeId || '';
                    if (youtubeId) {
                        inlineCard.className = 'w-full my-8 not-prose';
                        inlineCard.innerHTML = `
                            <div class="w-full bg-black relative rounded-xl overflow-hidden shadow-lg border border-[#E5D3B3] dark:border-gray-700" style="padding-bottom: calc(100% / (16 / 9));">
                                <lite-youtube videoid="${youtubeId}" params="rel=0" class="absolute inset-0 w-full h-full"></lite-youtube>
                            </div>
                        `;
                        // Keep the original text trigger in place
                    }
                } else {
                    inlineCard.className = 'hidden md:block lg:hidden my-6';
                    inlineCard.innerHTML = getPremiumCardHTML(trigger.dataset);
                }
                
                parentP.after(inlineCard);
                parentP.dataset.hasInlineCard = 'true';
            }
        }
    });
    
    // Tablet Fallback Injection — max 1 feature + 1 benefit
    const fallbackDataEl = document.getElementById('smartlink-fallback-data');
    if (fallbackDataEl) {
        let features: any[] = [];
        let benefits: any[] = [];
        try {
            features = JSON.parse(fallbackDataEl.dataset.features || '[]');
            benefits = JSON.parse(fallbackDataEl.dataset.benefits || '[]');
        } catch(e) {}
        
        let featureFallback: any = null;
        for (const f of features) {
            const isLinked = Array.from(triggers).some((el: any) => el.dataset.smartlinkType === 'feature' && (el.dataset.smartlinkHref || '').includes(f.id));
            if (!isLinked) { featureFallback = { type: 'feature', ...f }; break; }
        }
        let benefitFallback: any = null;
        for (const b of benefits) {
            const isLinked = Array.from(triggers).some((el: any) => el.dataset.smartlinkType === 'benefit' && (el.dataset.smartlinkHref || '').includes(b.id));
            if (!isLinked) { benefitFallback = { type: 'benefit', ...b }; break; }
        }
        
        const fallbackItems = [featureFallback, benefitFallback].filter(Boolean);
        const headings = Array.from(document.querySelectorAll('.prose h2')) as HTMLElement[];
        const targetIndices = [1, Math.max(3, Math.min(headings.length - 1, 4))];
        
        fallbackItems.forEach((item: any, index: number) => {
            const hIdx = Math.min(targetIndices[index] || 1, headings.length - 1);
            const heading = headings[hIdx];
            if (heading && !heading.dataset.hasInlineCard) {
                const dummyData = {
                    smartlinkType: item.type,
                    smartlinkHref: item.url,
                    smartlinkTitle: item.title,
                    smartlinkSnippet: item.description,
                    smartlinkIcon: item.icon
                };
                const inlineCard = document.createElement('div');
                inlineCard.className = 'hidden md:block lg:hidden my-6';
                inlineCard.innerHTML = getPremiumCardHTML(dummyData);
                heading.after(inlineCard);
                heading.dataset.hasInlineCard = 'true';
            }
        });
    }

    const card = document.getElementById('smartlink-desktop-card');
    
    triggers.forEach(el => {
      const trigger = el as HTMLElement;
      if (trigger.dataset.smartlinkEventsBound) return;
      trigger.dataset.smartlinkEventsBound = 'true';
      
      trigger.addEventListener('click', (e) => {
        if (window.innerWidth < 1024) {
          const type = trigger.dataset.smartlinkType;
          if (type === 'feature' || type === 'benefit') {
             // Let mobile inline card or standard tap-through handle it?
             // Actually mobile has inline cards? No, tablet has inline cards (`md:block lg:hidden`). Mobile is `< 768`.
             // So mobile triggers bottom sheet.
             e.preventDefault();
             openMobileSheet(trigger);
          } else {
             e.preventDefault();
             openMobileSheet(trigger);
          }
        }
      });

      trigger.addEventListener('mouseenter', (e) => {
        if (window.innerWidth >= 1024) {
          const pCard = trigger.cardEl;
          if (pCard) pCard.dataset.hovered = 'true';
        } else if (window.innerWidth >= 768) {
          const type = trigger.dataset.smartlinkType;
          if (type !== 'feature' && type !== 'benefit') {
              showHoverCard(trigger, e);
          }
        }
      });

      trigger.addEventListener('mouseleave', () => {
        if (window.innerWidth >= 1024) {
          const pCard = trigger.cardEl;
          if (pCard) pCard.dataset.hovered = 'false';
        } else if (window.innerWidth >= 768) {
          hideHoverCard();
        }
      });
    });

    if (card) {
      card.addEventListener('mouseenter', () => {
        clearTimeout(hoverTimeout);
      });
      card.addEventListener('mouseleave', hideHoverCard);
    }
    
    requestAnimationFrame(positionPersistentCards);
    setTimeout(positionPersistentCards, 500);
  }

  // Custom typings
  declare global {
    interface HTMLElement {
      cardEl?: HTMLElement;
    }
    interface Window {
      closeSmartLinkUI: () => void;
    }
  }

  // Initialize
  if (!document.getElementById('smartlink-scrim')) {
    ensureUIElements();
  }
  attachSmartLinkEvents();
  document.addEventListener('astro:page-load', attachSmartLinkEvents);

  let resizeTimer: number;
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimer);
    resizeTimer = window.setTimeout(positionPersistentCards, 100);
  });
</script>

