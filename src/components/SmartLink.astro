---
// src/components/SmartLink.astro
import { getEntry } from 'astro:content';

interface Props {
  href?: string;
  id?: string;
  type?: 'feature' | 'benefit' | 'post' | 'glossary' | 'academic' | 'video' | 'external';
  title?: string;
  snippet?: string;
  bibRef?: string;
  citation?: string;
  class?: string;
  anchorText?: string;
}

const { class: className, anchorText, id: rawId } = Astro.props;
let { href, type, title: propTitle, snippet: propSnippet, bibRef, citation } = Astro.props;

let id = rawId;
let title = propTitle;
let snippet = propSnippet;
const isManual = !!(propTitle || propSnippet);

console.log('SmartLink Render:', { href, id, text: Astro.slots.has('default') ? 'has_slot' : 'no_slot' });

// Infer type and id from href if possible
let parsedHref = href || '';
if (parsedHref.startsWith('/') && !parsedHref.startsWith('//')) {
  parsedHref = parsedHref.replace(/\.mdx?(#.*)?$/, '$1');
  if (href) href = parsedHref;
}
if (parsedHref.startsWith('http://datadocks.com') || parsedHref.startsWith('https://datadocks.com') || parsedHref.startsWith('https://www.datadocks.com')) {
  try {
    const url = new URL(parsedHref);
    parsedHref = url.pathname + url.search + url.hash;
  } catch(e) {}
}

if (parsedHref && !type) {
  if (parsedHref.startsWith('/posts/')) {
    type = 'post';
    id = id || parsedHref.replace('/posts/', '').replace(/\/$/, '').split('#')[0];
  } else if (parsedHref.startsWith('/videos/')) {
    type = 'video';
    id = id || parsedHref.replace('/videos/', '').replace(/\/$/, '').split('#')[0];
  } else if (parsedHref.startsWith('/datadocks-features/')) {
    type = 'feature';
    id = id || parsedHref.replace('/datadocks-features/', '').replace(/\/$/, '').split('#')[0];
  } else if (parsedHref.startsWith('/benefits/')) {
    type = 'benefit';
    id = id || parsedHref.replace('/benefits/', '').replace(/\/$/, '').split('#')[0];
  } else if (parsedHref.startsWith('#ref') || parsedHref.startsWith('#cite')) {
    type = 'academic';
    bibRef = bibRef || parsedHref;
    citation = citation || bibRef.replace('#ref-', '').replace('#cite-', '');
  } else if (parsedHref.includes('play.google.com/store/apps') || parsedHref.includes('apps.apple.com')) {
    type = 'app-store' as any;
    try {
      const url = new URL(parsedHref);
      title = title || (parsedHref.includes('apple') ? 'App Store' : 'Google Play');
      snippet = snippet || 'Get the DataDocks app for your device.';
    } catch(e) {
      title = title || 'App Store';
    }
  } else if (parsedHref.startsWith('http://') || parsedHref.startsWith('https://')) {
    if (!parsedHref.includes('calendly.com')) {
      type = 'external' as any;
      try {
        const extUrl = new URL(parsedHref);
        title = title || extUrl.hostname.replace(/^www\./, '');
        snippet = snippet || '';
      } catch(e) {
        title = title || 'External Link';
      }
    }
  }
}

if (id) {
  id = id.replace(/\.mdx?$/, '');
}

// Fetch data
let youtubeId = '';
let iconStr = '';

async function getEntryCaseInsensitive(collection: any, idToFind: string): Promise<any> {
  if (!idToFind) return null;
  const { getCollection } = await import('astro:content');
  const allEntries = await getCollection(collection);
  return allEntries.find((e: any) => e.slug.toLowerCase() === idToFind.toLowerCase());
}
if (type === 'glossary' && id) {
  const entry = await getEntryCaseInsensitive('glossary', id);
  if (entry) {
    title = title || entry.data.termName;
    snippet = snippet || entry.data.contextSnippet;
    href = href || (entry.data.targetPost ? `/posts/${entry.data.targetPost.id}` : '#');
  }
} else if (type === 'post' && id) {
  const entry = await getEntryCaseInsensitive('posts', id);
  if (entry) {
    title = title || entry.data.title;
    snippet = snippet || entry.data.description;
    href = href || `/posts/${id}`;
  }
} else if (type === 'video' && id) {
  const entry = await getEntryCaseInsensitive('videos', id);
  if (entry) {
    title = title || entry.data.title;
    snippet = snippet || entry.data.description;
    href = href || `/videos/${id}`;
    youtubeId = entry.data.postType?.value?.youtubeId || '';
    if (entry.data.postType?.discriminant === 'video') {
      type = 'video-widescreen' as any;
    }
  }
} else if (type === 'feature' && id) {
  const entry = await getEntryCaseInsensitive('features', id);
  if (entry) {
    title = title || entry.data.title;
    snippet = snippet || entry.data.description;
    href = href || `/datadocks-features/${id}`;
    if (entry.data.icon) {
      iconStr = entry.data.icon.replace(/\/([0-9a-fA-F]{24})_/, '/');
    }
  }
} else if (type === 'benefit' && id) {
  href = href || `/benefits/${id}`;
  const benefitsData: Record<string, {title: string, desc: string, icon: string}> = {
    'increase-capacity': { title: 'Increase Capacity', desc: 'Eliminate bottlenecks and slash overtime costs. DataDocks optimizes your appointment slots based on actual load times.', icon: '/images/features/linechart-file.svg' },
    'digitize-operations': { title: 'Digitize Operations', desc: 'Move away from paper and spreadsheets. Get real-time visibility into your yard and docks.', icon: '/images/features/checked-laptop.svg' },
    'delight-carriers': { title: 'Delight Carriers', desc: 'Become a shipper of choice. Give carriers a self-serve portal to book appointments 24/7.', icon: '/images/features/people.svg' },
    'see-everything': { title: 'See Everything', desc: 'A single dashboard for all your operations. Connect your teams with live updates.', icon: '/images/features/vision.svg' }
  };
  if (benefitsData[id]) {
    title = title || `${benefitsData[id].title} with DataDocks`;
    snippet = snippet || benefitsData[id].desc;
    iconStr = benefitsData[id].icon;
  }
} else if (type === 'academic') {
  // Academic links rely on manually passed title/snippet and bibRef or href.
  href = href || '#';
  title = title || "Academic Source";
} else if (type === 'external') {
  // External links — title is the domain, snippet can be overridden
  title = title || 'External Link';
}

const isSmartLink = !!type && (title || snippet);
---

{!isSmartLink ? (
  <a href={href} class={className || "font-medium text-[#fd4f00] hover:underline"}
    {...(href?.startsWith('http') ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
  >
    <slot>{anchorText || href}</slot>
  </a>
) : (
  <a 
    id={bibRef && bibRef.startsWith('#ref-') ? bibRef.replace('#ref-', 'cite-') : undefined}
    href={type === 'video' ? undefined : (href !== '#' ? href : undefined)} 
    data-smartlink-trigger="true"
    data-smartlink-type={type}
    data-smartlink-title={title}
    data-smartlink-snippet={snippet}
    data-smartlink-href={href}
    data-smartlink-bibref={bibRef}
    data-smartlink-manual={isManual ? "true" : undefined}
    data-smartlink-youtube-id={youtubeId}
    data-smartlink-icon={iconStr}
    class={`inline underline decoration-dotted decoration-[#fd4f00] lg:decoration-gray-400 hover:decoration-[#fd4f00] !text-inherit hover:!text-[#fd4f00] dark:hover:!text-[#ff7635] transition-colors cursor-pointer font-medium data-[highlighted=true]:!text-[#fd4f00] data-[highlighted=true]:decoration-[#fd4f00] [&_strong]:!text-inherit [&_em]:!text-inherit ${className || ''}`}
    {...((type === 'external' && href) ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
  ><slot>{anchorText || id}</slot>{citation && <sup class="text-[#fd4f00] dark:text-[#ff7635] ml-0.5 font-bold">{citation}</sup>}{type === 'external' && <svg class="inline w-3 h-3 ml-0.5 -mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>}{(type && type !== 'external' && type !== 'academic' && !citation) && <span class="inline lg:hidden ml-0.5 text-[#fd4f00] text-xs font-bold align-super" aria-hidden="true">?</span>}</a>
)}



