---
// src/components/SmartLinkController.astro
---

{/* Mobile Scrim */}
<div 
  id="smartlink-scrim" 
  class="fixed inset-0 bg-black/40 hidden z-40 transition-opacity duration-300 opacity-0"
  aria-hidden="true"
></div>

{/* Mobile Bottom Sheet */}
<div 
  id="smartlink-mobile-sheet" 
  class="fixed bottom-0 inset-x-0 z-50 translate-y-full transition-transform duration-300 bg-[#FFF8E9] rounded-t-2xl shadow-2xl border-t border-[#E5D3B3] overflow-hidden not-prose"
  role="dialog"
  aria-labelledby="sl-mobile-title"
>
  <div class="w-12 h-1.5 bg-gray-300 rounded-full mx-auto mt-3 mb-2"></div>
  <div class="px-6 pb-8 pt-2">
    <h3 id="sl-mobile-title" class="text-2xl font-bruta uppercase text-[#fd4f00] mb-3">Related Guide</h3>
    <p id="sl-mobile-snippet" class="text-gray-700 font-recoleta text-lg leading-relaxed mb-6"></p>
    <a 
      id="sl-mobile-link" 
      href="/posts" 
      class="inline-flex items-center justify-center w-full py-3 px-4 bg-[#fd4f00] text-white text-center rounded-none font-recoleta font-bold text-lg border-b-4 border-transparent hover:bg-black transition-all"
    >Explore the full guide</a>
  </div>
</div>

{/* Desktop hover-card (tooltip fallback when margin space is insufficient) */}
<div 
  id="smartlink-desktop-card" 
  class="fixed z-50 hidden w-80 bg-white dark:bg-gray-800 shadow-2xl border border-[#E5D3B3] dark:border-gray-700 rounded-xl transition-opacity duration-200 opacity-0 group not-prose"
>
  {/* Hover Bridge - an invisible area that connects the card to the cursor */}
  <div class="absolute -inset-y-6 inset-x-0 pointer-events-auto"></div>
  
  <div class="relative p-4">
    <h3 id="sl-desktop-title" class="font-sans text-sm font-bold text-gray-900 dark:text-white m-0 leading-tight">Related Guide</h3>
    <p id="sl-desktop-snippet" class="font-sans text-xs text-gray-600 dark:text-gray-400 mt-1 leading-snug"></p>
    <a 
      id="sl-desktop-link" 
      href="/posts" 
      class="inline-flex items-center gap-1 font-sans text-xs font-semibold text-gray-500 dark:text-gray-400 group-hover:text-[#fd4f00] dark:group-hover:text-[#ff7635] hover:underline mt-3 w-fit"
    >
      Explore the full guide
      <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
      </svg>
    </a>
  </div>
</div>

<script>
  let hoverTimeout: number | undefined;

  function openMobileSheet(trigger: HTMLElement) {
    const sheet  = document.getElementById('smartlink-mobile-sheet');
    const scrim  = document.getElementById('smartlink-scrim');
    const title  = document.getElementById('sl-mobile-title');
    const snip   = document.getElementById('sl-mobile-snippet');
    const link   = document.getElementById('sl-mobile-link') as HTMLAnchorElement | null;
    if (!sheet || !scrim) return;

    if (title) title.textContent = trigger.dataset.smartlinkTitle  || '';
    if (snip)  snip.textContent  = trigger.dataset.smartlinkSnippet || '';
    if (link)  link.href          = trigger.dataset.smartlinkHref   || '#';

    scrim.classList.remove('hidden');
    requestAnimationFrame(() => {
      scrim.classList.add('opacity-100');
      sheet.classList.remove('translate-y-full');
    });

    const closeOnScrim = () => {
      sheet.classList.add('translate-y-full');
      scrim.classList.remove('opacity-100');
      setTimeout(() => scrim.classList.add('hidden'), 300);
      scrim.removeEventListener('click', closeOnScrim);
    };
    scrim.addEventListener('click', closeOnScrim);
  }

  function createPersistentCard(trigger: HTMLElement): HTMLElement {
    const card = document.createElement('div');
    card.className = [
      'absolute left-0 z-30 w-full bg-white dark:bg-gray-800 border border-[#E5D3B3] dark:border-gray-700 rounded-xl shadow-md p-4 not-prose smartlink-persistent-card group',
      'opacity-40 grayscale dark:opacity-50 dark:grayscale transition-all duration-300 pointer-events-auto transform',
      'data-[hovered=true]:opacity-100 data-[hovered=true]:grayscale-0 data-[hovered=true]:z-40'
    ].join(' ');

    const title   = (trigger.dataset.smartlinkTitle   || '').replace(/</g, '&lt;');
    const snippet = (trigger.dataset.smartlinkSnippet || '').replace(/</g, '&lt;');
    const href    = trigger.dataset.smartlinkHref || '#';

    card.innerHTML = `
      <h3 class="font-sans text-sm font-bold text-gray-900 dark:text-white m-0 leading-tight">${title}</h3>
      <p class="font-sans text-xs text-gray-600 dark:text-gray-400 mt-1 leading-snug">${snippet}</p>
      <a href="${href}" class="inline-flex items-center gap-1 font-sans text-xs font-semibold text-gray-500 dark:text-gray-400 group-hover:text-[#fd4f00] group-data-[hovered=true]:text-[#fd4f00] dark:group-hover:text-[#ff7635] dark:group-data-[hovered=true]:text-[#ff7635] hover:underline mt-3 w-fit">
        Explore guide
        <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </a>`;
    return card;
  }

  function showHoverCard(trigger: HTMLElement, e: MouseEvent) {
    if (window.innerWidth < 1024) return;
    clearTimeout(hoverTimeout);
    const card    = document.getElementById('smartlink-desktop-card');
    const dTitle  = document.getElementById('sl-desktop-title');
    const dSnip   = document.getElementById('sl-desktop-snippet');
    const dLink   = document.getElementById('sl-desktop-link') as HTMLAnchorElement | null;
    if (!card) return;

    if (dTitle) dTitle.textContent = trigger.dataset.smartlinkTitle  || '';
    if (dSnip)  dSnip.textContent  = trigger.dataset.smartlinkSnippet || '';
    if (dLink)  dLink.href          = trigger.dataset.smartlinkHref   || '#';

    const cardWidth  = 320; // w-80
    
    // Position tooltip very close to cursor with a tiny offset to avoid recursive flickering
    const cardH      = card.offsetHeight || 180;
    const roomAbove  = e.clientY > cardH + 10;
    
    // Center the card horizontally on the cursor, but keep it within the screen bounds
    let leftPos = e.clientX - (cardWidth / 2);
    leftPos = Math.max(16, Math.min(leftPos, window.innerWidth - cardWidth - 16));
    
    card.style.left     = `${leftPos}px`;
    card.style.width    = `${cardWidth}px`;
    card.style.top      = roomAbove
      ? `${e.clientY - cardH - 4}px`
      : `${e.clientY + 4}px`;

    card.classList.remove('hidden');
    requestAnimationFrame(() => card.classList.add('opacity-100'));
  }

  function hideHoverCard() {
    hoverTimeout = window.setTimeout(() => {
      const card = document.getElementById('smartlink-desktop-card');
      if (!card) return;
      card.classList.remove('opacity-100');
      setTimeout(() => {
        if (!card.classList.contains('opacity-100')) card.classList.add('hidden');
      }, 200);
    }, 150);
  }

  function initSmartLinks() {
    // Cleanup old persistent cards from sidebar if present
    const sidebar = document.getElementById('blog-right-sidebar');
    if (sidebar) {
      sidebar.querySelectorAll('.smartlink-persistent-card').forEach(c => c.remove());
    }
    clearTimeout(hoverTimeout);

    const triggers = Array.from(document.querySelectorAll<HTMLElement>('[data-smartlink-trigger="true"]'));
    const featureCallout = document.getElementById('sidebar-feature-callout');
    if (triggers.length === 0 && !featureCallout) return;

    const isDesktop = window.innerWidth >= 1024;
    const article = document.getElementById('content') || document.querySelector('article');
    if (!article) return;

    if (isDesktop) article.style.position = 'relative';

    const hasSpace = isDesktop && sidebar && window.getComputedStyle(sidebar).display !== 'none';

    if (hasSpace && sidebar) {
      const calloutAnchor = document.querySelector('[data-feature-callout-anchor="true"]') as HTMLElement | null;

      if (featureCallout) {
        if (calloutAnchor) {
          featureCallout.style.position = 'absolute';
          featureCallout.style.left = '0';
          featureCallout.style.width = '100%';
        } else {
          // Reset styling for backward compatibility
          featureCallout.style.position = '';
          featureCallout.style.left = '';
          featureCallout.style.width = '';
          featureCallout.style.top = '';
        }
      }

      const glossaryCards: { card: HTMLElement; trigger: HTMLElement }[] = [];

      triggers.forEach(trigger => {
        trigger.onclick = (e) => {
          if (window.innerWidth < 1024) {
            e.preventDefault();
            openMobileSheet(trigger);
          }
        };

        const card = createPersistentCard(trigger);
        card.classList.add('smartlink-persistent-card');
        card.style.top = `${trigger.offsetTop}px`;
        sidebar.appendChild(card);
        glossaryCards.push({ card, trigger });

        const activate = () => {
          if (window.innerWidth >= 1024) {
            card.setAttribute('data-hovered', 'true');
            trigger.setAttribute('data-highlighted', 'true');
          }
        };
        const deactivate = () => {
          card.removeAttribute('data-hovered');
          trigger.removeAttribute('data-highlighted');
        };
        trigger.onmouseenter = activate;
        trigger.onmouseleave = deactivate;
        card.onmouseenter = activate;
        card.onmouseleave = deactivate;
      });

      // Wait for next frame to ensure offsetHeight is accurate
      requestAnimationFrame(() => {
        const verticalGap = 24;

        if (featureCallout) {
          const sidebarRect = sidebar.getBoundingClientRect();
          const F_top = calloutAnchor 
            ? (calloutAnchor.getBoundingClientRect().top - sidebarRect.top) 
            : featureCallout.offsetTop;
          
          if (calloutAnchor) {
            featureCallout.style.top = `${F_top}px`;
          }

          const F_height = featureCallout.offsetHeight;

          // Separate glossary cards into above and below the feature callout
          const aboveCards: { card: HTMLElement; top: number }[] = [];
          const belowCards: { card: HTMLElement; top: number }[] = [];

          glossaryCards.forEach(item => {
            const preferredTop = item.trigger.getBoundingClientRect().top - sidebarRect.top;
            const cardData = { card: item.card, top: preferredTop };
            if (preferredTop < F_top) {
              aboveCards.push(cardData);
            } else {
              belowCards.push(cardData);
            }
          });

          // Resolve aboveCards (stack upwards from F_top)
          aboveCards.sort((a, b) => b.top - a.top); // sort descending (closest to F_top first)
          let upperLimit = F_top;
          aboveCards.forEach(item => {
            const h = item.card.offsetHeight;
            let targetTop = item.top;
            if (targetTop + h + verticalGap > upperLimit) {
              targetTop = upperLimit - h - verticalGap;
            }
            if (targetTop < 0) targetTop = 0;
            item.top = targetTop;
            item.card.style.top = `${targetTop}px`;
            upperLimit = targetTop;
          });

          // Resolve belowCards (stack downwards from F_top + F_height)
          belowCards.sort((a, b) => a.top - b.top); // sort ascending (closest to F_top first)
          let lowerLimit = F_top + F_height;
          belowCards.forEach(item => {
            let targetTop = item.top;
            if (targetTop < lowerLimit + verticalGap) {
              targetTop = lowerLimit + verticalGap;
            }
            item.top = targetTop;
            item.card.style.top = `${targetTop}px`;
            lowerLimit = targetTop + item.card.offsetHeight;
          });

        } else {
          // Fallback: no feature callout, just stack downwards
          const sidebarRect = sidebar.getBoundingClientRect();
          const mappedCards = glossaryCards.map(item => ({
            card: item.card,
            top: item.trigger.getBoundingClientRect().top - sidebarRect.top
          }));

          mappedCards.sort((a, b) => a.top - b.top);
          mappedCards.forEach((item, idx) => {
            let targetTop = item.top;
            if (idx > 0) {
              const prev = mappedCards[idx - 1];
              const prevBottom = prev.top + prev.card.offsetHeight;
              if (targetTop < prevBottom + verticalGap) {
                targetTop = prevBottom + verticalGap;
              }
            }
            item.top = targetTop;
            item.card.style.top = `${targetTop}px`;
          });
        }
      });
    } else {
      const card = document.getElementById('smartlink-desktop-card');
      if (card) {
        card.onmouseenter = () => {
          if (window.innerWidth >= 1024) clearTimeout(hoverTimeout);
        };
        card.onmouseleave = hideHoverCard;
      }

      triggers.forEach(trigger => {
        trigger.onclick = (e) => {
          if (window.innerWidth < 1024) {
            e.preventDefault();
            openMobileSheet(trigger);
          }
        };

        if (isDesktop) {
          trigger.onmouseenter = (e) => {
            showHoverCard(trigger, e);
            trigger.setAttribute('data-highlighted', 'true');
          };
          trigger.onmouseleave = () => {
            hideHoverCard();
            trigger.removeAttribute('data-highlighted');
          };
          // For the tooltip fallback, we also want the card hover to highlight the trigger
          if (card) {
            card.addEventListener('mouseenter', () => trigger.setAttribute('data-highlighted', 'true'));
            card.addEventListener('mouseleave', () => trigger.removeAttribute('data-highlighted'));
          }
        }
      });
    }
  }

  document.addEventListener('astro:page-load', initSmartLinks);
  initSmartLinks();
</script>
