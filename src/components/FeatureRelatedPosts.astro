---
// src/components/FeatureRelatedPosts.astro
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import { ytThumb } from '../lib/yt-thumb';

interface Props {
  featureSlug: string;
}

const { featureSlug } = Astro.props;

// 1. Fetch all blog posts
const allPosts = await getCollection('posts');

// 2. Filter posts related to this feature
const relatedPosts = allPosts
  .filter((post: CollectionEntry<'posts'>) => {
    const rf = post.data.relatedFeature;
    if (!rf) return false;
    return rf.id === featureSlug;
  })
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

// 3. If there are no related posts, don't render anything
if (relatedPosts.length === 0) {
  return null;
}
---

<section class="w-full max-w-7xl mx-auto px-6 lg:px-8 pb-24 border-t border-[#E5D3B3] dark:border-gray-800 pt-16 mt-8">
  <div class="flex flex-col md:flex-row md:items-end md:justify-between mb-10 gap-4">
    <div>
      <h2 class="font-bruta uppercase text-black dark:text-white text-3xl md:text-4xl font-bold tracking-tight mb-4">Related Guides & Articles</h2>
      <div class="w-16 h-1 bg-[#fd4f00]"></div>
    </div>
    <a href="/posts" class="text-[#fd4f00] font-recoleta font-bold flex items-center gap-2 hover:underline">
      View all resources
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
    </a>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
    {relatedPosts.map((post: any) => {
      const href = `/posts/${post.slug}`;
      const isVideo = post.data.postType?.discriminant === 'video' || post.data.postType?.discriminant === 'short';
      const youtubeId = post.data.postType.discriminant !== 'article' ? post.data.postType.value?.youtubeId : undefined;
      
      return (
        <a 
          href={href} 
          class="group flex flex-col bg-white dark:bg-gray-800 rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-500 border border-[#E5D3B3] dark:border-gray-700 hover:-translate-y-1"
        >
          {/* Cover image / Thumbnail */}
          <div class="relative aspect-[16/10] overflow-hidden bg-gray-100 dark:bg-gray-900">
            {post.data.cardImage ? (
              <Image 
                src={post.data.cardImage} 
                alt={post.data.cardAlt || post.data.title}
                width={600}
                height={375}
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
              />
            ) : isVideo && youtubeId ? (
              <img
                src={ytThumb(youtubeId)}
                alt={post.data.title}
                loading="lazy"
                decoding="async"
                class="w-full h-full object-cover opacity-80 group-hover:opacity-100 transition-opacity"
              />
            ) : (
              <div class="w-full h-full flex items-center justify-center bg-[#FBC3AD]/30">
                <svg class="w-12 h-12 text-[#fd4f00] opacity-20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                </svg>
              </div>
            )}
            {isVideo && (
              <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity bg-black/20">
                <div class="w-12 h-12 bg-[#fd4f00] rounded-full flex items-center justify-center text-white">
                  <svg class="w-6 h-6 ml-1" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M8 5v14l11-7z"/>
                  </svg>
                </div>
              </div>
            )}
          </div>

          {/* Card Body */}
          <div class="p-6 flex flex-col flex-grow">
            <div class="flex items-center justify-between mb-3">
              <span class="text-[10px] font-bold uppercase tracking-widest text-[#fd4f00] bg-[#fd4f00]/5 px-2 py-1 rounded">
                {post.data.category || 'Logistics'}
              </span>
              <span class="text-[10px] font-bold uppercase tracking-widest text-gray-400">
                {isVideo ? 'Video' : 'Article'}
              </span>
            </div>
            <h3 class="font-recoleta text-lg md:text-xl font-bold text-gray-900 dark:text-white group-hover:text-[#fd4f00] transition-colors leading-tight mb-3 line-clamp-2">
              {post.data.title}
            </h3>
            {post.data.description && (
              <p class="font-recoleta text-sm text-gray-500 dark:text-gray-400 line-clamp-3 mb-4 leading-relaxed">
                {post.data.description}
              </p>
            )}
            <div class="mt-auto flex items-center justify-between pt-4 border-t border-gray-100 dark:border-gray-700">
              <span class="text-xs text-gray-500 dark:text-gray-400 font-recoleta">
                By {post.data.author}
              </span>
              <span class="text-xs text-gray-400 font-mono">
                {post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
              </span>
            </div>
          </div>
        </a>
      );
    })}
  </div>
</section>
