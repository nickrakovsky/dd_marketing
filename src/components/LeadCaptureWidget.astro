---
export interface Props {
  headline: string;
  buttonText?: string;
  eventName: string;
  redirectUrl: string;
}

const {
  headline,
  buttonText = "Download",
  eventName,
  redirectUrl,
} = Astro.props;

const BENTO_UUID = "b4cb9a34a989bcc643714151df7b7154";
const uid = Math.random().toString(36).slice(2, 9);
---

<div class="sidebar-card mb-4 group/lmf lead-magnet-container !p-5" id={`lmf-${uid}`}>
  <div class="success-message hidden w-full text-center py-2">
    <div class="flex items-center justify-center gap-1 text-green-700 font-bold font-recoleta text-sm">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
      </svg>
      Check your email!
    </div>
    <p class="sidebar-card-snippet mt-2">
      Didn't get it?{" "}
      <a href={redirectUrl} target="_blank" rel="noreferrer" class="sidebar-card-link !mt-0 !inline">
        Download directly
      </a>.
    </p>
  </div>

  <form
    class="lead-magnet-form block w-full"
    data-event={eventName}
    data-redirect={redirectUrl}
    data-uuid={BENTO_UUID}
  >
    <div class="sidebar-card-title font-bold text-gray-900 dark:text-white leading-snug mb-3">
      {headline}
    </div>

    <div class="flex flex-col gap-0 mt-3">
      <input
        type="email"
        name="email"
        placeholder="Enter your email"
        required
        class="w-full h-10 px-3 bg-[#FFF8EE] dark:bg-gray-900 border border-[#E5D3B3] dark:border-gray-600 border-b-0 rounded-none text-sm font-sans placeholder:text-gray-400 focus:border-[#fd4f00] focus:outline-none transition-colors relative z-10 focus:border-b"
      />
      <button
        type="submit"
        class="w-full h-10 bg-[#fd4f00] hover:bg-[#e54700] text-white font-sans font-bold text-sm rounded-none shadow-sm transition-colors cursor-pointer"
      >
        {buttonText}
      </button>
    </div>
  </form>

  <p class="disclaimer-message block text-center text-[10px] text-gray-400 mt-2 font-sans leading-tight">
    You'll also receive occasional updates. Unsubscribe anytime.
  </p>
</div>

{/* 
  We don't need to duplicate the Bento tracking script here because 
  LeadMagnetForm.astro already attaches a global script that binds 
  to any form with the .lead-magnet-form class. However, if this page 
  doesn't have an inline LeadMagnetForm, the script won't exist. 
  Let's add a scoped script just for this widget's logic, using a 
  data-bound check to prevent double-binding.
*/}
<script is:inline>
  (function() {
    function attachSidebarLeadMagnetForms() {
      document.querySelectorAll('.lead-magnet-form:not([data-sidebar-bound])').forEach(function(form) {
        // If it was already bound by the global script, don't bind again
        if (form.getAttribute('data-bound') === 'true') return;
        
        form.setAttribute('data-sidebar-bound', 'true');
        form.addEventListener('submit', function(e) {
          e.preventDefault();

          var emailInput = form.querySelector('input[name="email"]');
          var email = emailInput ? emailInput.value : '';
          var eventName = form.getAttribute('data-event');
          var redirectUrl = form.getAttribute('data-redirect');

          if (email) {
            if (typeof window.bento !== 'undefined' && typeof window.bento.identify === 'function') {
              window.bento.identify(email);
              window.bento.track(eventName, { source: window.location.pathname });
            }

            fetch('/api/bento-track', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                email: email,
                event: eventName,
                source: window.location.pathname,
                landingPage: sessionStorage.getItem('dd_landing_page') || window.location.href,
                visitorUuid: (typeof window.getBentoVisitorUuid === 'function') ? window.getBentoVisitorUuid() : null
              }),
              keepalive: true
            }).catch(function() {});
          }

          form.reset();

          var container = form.closest('.lead-magnet-container');
          if (container) {
            form.classList.remove('block');
            form.classList.add('hidden');

            var disclaimer = container.querySelector('.disclaimer-message');
            if (disclaimer) {
              disclaimer.classList.remove('block');
              disclaimer.classList.add('hidden');
            }

            var success = container.querySelector('.success-message');
            if (success) {
              success.classList.remove('hidden');
              success.classList.add('block');
            }
          }

          if (redirectUrl) {
            window.open(redirectUrl, '_blank', 'noopener');
          }
        });
      });
    }

    attachSidebarLeadMagnetForms();
    document.addEventListener('astro:page-load', attachSidebarLeadMagnetForms);
  })();
</script>
