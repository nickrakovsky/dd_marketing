---
import { Mail, Phone, Linkedin, Youtube, X } from "lucide-react";
import { Image } from "astro:assets";
import capterraBadge from "@/assets/capterra-logo.png";
import soc2Badge from "@/assets/soc2-badge.png";
import canadaBadge from "@/assets/canada-badge.png";

const MAIN_SITE = "";

const hoverLinkClass = `
  relative inline-block text-base text-[#FFF8E9] transition-colors duration-300
  hover:text-[#FF5722]
  after:content-[''] 
  after:absolute 
  after:w-full 
  after:scale-x-0 
  after:h-[1px] 
  after:bottom-0 
  after:left-0 
  after:bg-[#FF5722] 
  after:origin-bottom-right 
  after:transition-transform 
  after:duration-300 
  hover:after:scale-x-100 
  hover:after:origin-bottom-left
`;

const columns = {
  contact: {
    title: "Contact Us",
    address: [
      "405 Queen Street S",
      "#75078",
      "Bolton, ON",
      "L7E 1H6"
    ],
    email: "info@datadocks.com",
    phone: "(647) 848-8250"
  },
  howItHelps: {
    title: "How DataDocks Helps",
    links: [
      { label: "Increase Capacity", href: `${MAIN_SITE}/benefits/increase-capacity` },
      { label: "See Everything", href: `${MAIN_SITE}/benefits/see-everything` },
      { label: "Delight Carriers", href: `${MAIN_SITE}/benefits/delight-carriers` },
      { label: "Digitize Operations", href: `${MAIN_SITE}/benefits/digitize-operations` },
    ]
  },
  features1: {
    title: "Features",
    links: [
      { label: "Documentation", href: `${MAIN_SITE}/datadocks-features/documentation` },
      { label: "Capacity Limits", href: `${MAIN_SITE}/datadocks-features/capacity-limits` },
      { label: "Custom Rules", href: `${MAIN_SITE}/datadocks-features/custom-rules` },
      { label: "Data Validation", href: `${MAIN_SITE}/datadocks-features/data-validation` },
      { label: "Carrier Portal", href: `${MAIN_SITE}/datadocks-features/carrier-portal` },
      { label: "Yard Management", href: `${MAIN_SITE}/datadocks-features/yard-management` },
    ]
  },
  features2: {
    title: "",
    links: [
      { label: "Dock Dashboard", href: `${MAIN_SITE}/datadocks-features/dock-dashboard` },
      { label: "Efficiency Reports", href: `${MAIN_SITE}/datadocks-features/efficiency-reports` },
      { label: "Notifications", href: `${MAIN_SITE}/datadocks-features/notifications` },
      { label: "Access Anywhere", href: `${MAIN_SITE}/datadocks-features/access-anywhere` },
      { label: "Live Editing", href: `${MAIN_SITE}/datadocks-features/live-editing` },
      { label: "Integration", href: `${MAIN_SITE}/datadocks-features/integration` },
    ]
  },
  quickLinks: {
    title: "Quick Links",
    links: [
      { label: "Login", href: "https://app.datadocks.com" },
      { label: "About", href: `${MAIN_SITE}/about` },
      { label: "Support", href: "https://datadocks.com/support" },
      { label: "DataDocks Vs. OpenDock", href: `${MAIN_SITE}/datadocks-vs-opendock` },
      { label: "Privacy Policy", href: "/privacy-policy" },
    ]
  }
};
---

<footer class="bg-black text-[#FFF8E9] py-12 border-t border-white/10 font-sans">
  <div class="container mx-auto px-6 max-w-7xl">
    
    {/* TOP SECTION: LINKS */}
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-[1.2fr_1fr_2.2fr_1fr] gap-y-12 gap-x-12 lg:gap-20 mb-12">
      
      {/* 1. CONTACT */}
      <div class="col-span-1">
        <h3 class="font-recoleta font-bold text-lg mb-4 text-[#FFF8E9]">Contact Us</h3>
        <div class="text-base text-[#FFF8E9]/90 space-y-0 leading-snug mb-4">
          {columns.contact.address.map(line => <p>{line}</p>)}
        </div>
        <div class="space-y-1">
          <a href={`mailto:${columns.contact.email}`} class={hoverLinkClass}>
            {columns.contact.email}
          </a>
          <br/>
          <a href={`tel:${columns.contact.phone.replace(/\D/g,'')}`} class={hoverLinkClass}>
            {columns.contact.phone}
          </a>
        </div>
      </div>

      {/* 2. HOW IT HELPS */}
      <div class="col-span-1">
        <h3 class="font-recoleta font-bold text-lg mb-4 text-[#FFF8E9]">{columns.howItHelps.title}</h3>
        <ul class="space-y-1.5">
          {columns.howItHelps.links.map(link => (
            <li>
              <a href={link.href} class={hoverLinkClass}>
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      {/* 3 & 4. FEATURES (Grouped) */}
      <div class="col-span-1 lg:col-span-1 grid grid-cols-1 sm:grid-cols-2 gap-4 lg:gap-8">
        <div>
          <h3 class="font-recoleta font-bold text-lg mb-4 text-[#FFF8E9]">{columns.features1.title}</h3>
          <ul class="space-y-1.5">
            {columns.features1.links.map(link => (
              <li>
                <a href={link.href} class={hoverLinkClass}>
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
        <div class="pt-0 lg:pt-[2.75rem]">
          <ul class="space-y-1.5">
            {columns.features2.links.map(link => (
              <li>
                <a href={link.href} class={hoverLinkClass}>
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>

      {/* 5. QUICK LINKS */}
      <div class="col-span-1">
        <h3 class="font-recoleta font-bold text-lg mb-4 text-[#FFF8E9]">{columns.quickLinks.title}</h3>
        <ul class="space-y-1.5">
          {columns.quickLinks.links.map(link => (
            <li>
              <a href={link.href} class={hoverLinkClass}>
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

    </div>

    {/* BOTTOM SECTION: LOGOS & COPYRIGHT */}
    <div class="flex flex-col lg:flex-row justify-between items-center gap-12 pt-4">
      
      {/* Group the 3 primary logos for even spacing */}
      <div class="flex flex-col md:flex-row items-center justify-between w-full lg:w-3/4 gap-12 lg:gap-8">
        {/* 1. Datadocks Logo Icon */}
        <a href="/" class="hover:scale-105 transition-transform duration-300">
          <img
            src="/images/Orange-Logo.svg"
            alt="DataDocks Logo"
            width="56"
            height="56"
            loading="lazy"
            class="w-14 h-14"
          />
        </a>

        {/* 2. AICPA/SOC2 Badge */}
        <a 
          href="https://www.aicpa.org/soc4so" 
          target="_blank" 
          rel="noopener noreferrer"
          class="hover:scale-105 transition-transform duration-300"
        >
          <Image
            src={soc2Badge}
            alt="AICPA SOC2 Certified"
            width={120}
            loading="lazy"
            class="h-24 w-auto object-contain"
          />
        </a>

        {/* 3. Canada Badge */}
        <a 
          href="https://feddev-ontario.canada.ca/" 
          target="_blank" 
          rel="noopener noreferrer"
          class="hover:scale-105 transition-transform duration-300"
        >
          <div class="sr-only">
            Funded by the Federal Economic Development Agency for Southern Ontario
          </div>
          <Image
            src={canadaBadge}
            alt="Government of Canada"
            width={600}
            loading="lazy"
            class="h-10 w-auto object-contain"
          />
        </a>
      </div>

      {/* Right: Socials & Copyright */}
      <div class="flex flex-col items-center lg:items-end gap-3 shrink-0">
        <div class="flex items-center gap-5">
          <a href="https://linkedin.com/company/datadocks" target="_blank" rel="noopener noreferrer" class="text-[#FFF8E9]/60 hover:text-[#0077b5] transition-colors">
             <Linkedin className="w-5 h-5" />
            <span class="sr-only">LinkedIn</span>
          </a>
          <a href="https://x.com/datadocks" target="_blank" rel="noopener noreferrer" class="text-[#FFF8E9]/60 hover:text-[#FFF8E9] transition-colors">
            <svg viewBox="0 0 24 24" aria-hidden="true" class="w-5 h-5 fill-current">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"></path>
            </svg>
            <span class="sr-only">X (formerly Twitter)</span>
          </a>
          <a href="https://www.youtube.com/@datadocks" target="_blank" rel="noopener noreferrer" class="text-[#FFF8E9]/60 hover:text-[#FF0000] transition-colors">
            <Youtube className="w-5 h-5" />
            <span class="sr-only">YouTube</span>
          </a>
        </div>
        <p class="text-sm text-[#FFF8E9]/80">
          © Northfire {new Date().getFullYear()}
        </p>
      </div>

    </div>

  </div>
</footer>