---
import { Linkedin, Youtube } from "lucide-react";

const MAIN_SITE = "";

const hoverLinkClass = `
  relative inline-block text-[#FFF8E9] transition-colors duration-300
  hover:text-[#FF5722]
  after:content-[''] 
  after:absolute 
  after:w-full 
  after:scale-x-0 
  after:h-[1px] 
  after:bottom-0 
  after:left-0 
  after:bg-[#FF5722] 
  after:origin-bottom-right 
  after:transition-transform 
  after:duration-300 
  hover:after:scale-x-100 
  hover:after:origin-bottom-left
`;

const columns = {
  contact: {
    title: "Contact Us",
    address: [
      "405 Queen Street S",
      "#75078",
      "Bolton, ON",
      "L7E 1H6"
    ],
    email: "info@datadocks.com",
    phone: "(647) 848-8250"
  },
  howItHelps: {
    title: "How DataDocks Helps",
    links: [
      { label: "Increase Capacity", href: `${MAIN_SITE}/benefits/increase-capacity` },
      { label: "See Everything", href: `${MAIN_SITE}/benefits/see-everything` },
      { label: "Delight Carriers", href: `${MAIN_SITE}/benefits/delight-carriers` },
      { label: "Digitize Operations", href: `${MAIN_SITE}/benefits/digitize-operations` },
    ]
  },
  features1: {
    title: "Features",
    links: [
      { label: "Documentation", href: `${MAIN_SITE}/datadocks-features/documentation` },
      { label: "Capacity Limits", href: `${MAIN_SITE}/datadocks-features/capacity-limits` },
      { label: "Custom Rules", href: `${MAIN_SITE}/datadocks-features/custom-rules` },
      { label: "Data Validation", href: `${MAIN_SITE}/datadocks-features/data-validation` },
      { label: "Carrier Portal", href: `${MAIN_SITE}/datadocks-features/carrier-portal` },
      { label: "Yard Management", href: `${MAIN_SITE}/datadocks-features/yard-management` },
    ]
  },
  features2: {
    title: "",
    links: [
      { label: "Dock Dashboard", href: `${MAIN_SITE}/datadocks-features/dock-dashboard` },
      { label: "Efficiency Reports", href: `${MAIN_SITE}/datadocks-features/efficiency-reports` },
      { label: "Notifications", href: `${MAIN_SITE}/datadocks-features/notifications` },
      { label: "Access Anywhere", href: `${MAIN_SITE}/datadocks-features/access-anywhere` },
      { label: "Live Editing", href: `${MAIN_SITE}/datadocks-features/live-editing` },
      { label: "Integration", href: `${MAIN_SITE}/datadocks-features/integration` },
    ]
  },
  quickLinks: {
    title: "Quick Links",
    links: [
      { label: "Login", href: "https://app.datadocks.com" },
      { label: "About", href: `${MAIN_SITE}/about` },
      { label: "Support", href: `${MAIN_SITE}/support` },
      { label: "Mobile App", href: "/mobile-app" },
      { label: "DataDocks v.s. Opendock", href: `${MAIN_SITE}/datadocks-vs-opendock` },
      { label: "Privacy Policy", href: "/privacy-policy" },
    ]
  }
};
---

<footer class="bg-black text-[#FFF8E9] py-12 border-t border-white/10 font-sans text-[1rem] min-[330px]:text-[1.1rem] min-[480px]:text-base transition-[font-size] duration-300" style="content-visibility: auto; contain-intrinsic-size: auto 500px;">
  <div class="container mx-auto px-6 max-w-7xl">

    {/* ── LINK COLUMNS ─────────────────────────────────────────────────────────────
        Single responsive markup tree (previously five duplicate breakpoint blocks).
        Each link/image/heading now appears exactly ONCE in the DOM and reflows via
        CSS grid: 2 cols on small phones → 3 at 480px → 4 at desktop. Features holds
        all 12 links and flows into 2 sub-columns on desktop via CSS columns.
    ─────────────────────────────────────────────────────────────────────────────── */}
    <div class="grid grid-cols-2 min-[480px]:grid-cols-3 md:grid-cols-[1.2fr_1fr_2.2fr_1fr] gap-x-8 gap-y-10 mb-10">
      {/* Contact — semantic <address> for NAP consistency (local SEO) */}
      <div>
        <h3 class="font-recoleta font-bold text-lg mb-4 text-[#FFF8E9]">{columns.contact.title}</h3>
        <address class="not-italic text-[#FFF8E9]/90 leading-snug space-y-0 mb-4">
          {columns.contact.address.map(line => <p>{line}</p>)}
        </address>
        <div class="flex flex-col gap-1">
          <a href={`mailto:${columns.contact.email}`} class={hoverLinkClass}>{columns.contact.email}</a>
          <a href={`tel:${columns.contact.phone.replace(/\D/g,'')}`} class={hoverLinkClass}>{columns.contact.phone}</a>
        </div>
      </div>

      {/* How DataDocks Helps */}
      <div>
        <h3 class="font-recoleta font-bold text-lg mb-4 text-[#FFF8E9]">{columns.howItHelps.title}</h3>
        <ul class="space-y-1.5">
          {columns.howItHelps.links.map(link => (<li><a href={link.href} class={hoverLinkClass}>{link.label}</a></li>))}
        </ul>
      </div>

      {/* Features — all 12 links; 2-up on desktop via CSS multi-column */}
      <div>
        <h3 class="font-recoleta font-bold text-lg mb-4 text-[#FFF8E9]">{columns.features1.title}</h3>
        <ul class="space-y-1.5 md:columns-2 md:gap-8 [&>li]:break-inside-avoid">
          {[...columns.features1.links, ...columns.features2.links].map(link => (<li><a href={link.href} class={hoverLinkClass}>{link.label}</a></li>))}
        </ul>
      </div>

      {/* Quick Links */}
      <div>
        <h3 class="font-recoleta font-bold text-lg mb-4 text-[#FFF8E9]">{columns.quickLinks.title}</h3>
        <ul class="space-y-1.5">
          {columns.quickLinks.links.map(link => (<li><a href={link.href} class={hoverLinkClass}>{link.label}</a></li>))}
        </ul>
      </div>
    </div>

    {/* ── BRAND + LEGAL BAR ────────────────────────────────────────────────────────
        Logo, badges, social links and copyright each appear ONCE. Stacks and centers
        on mobile; spreads into a row on desktop. Social icons are real links at every
        size (previously the small-screen variants were non-clickable icons).
    ─────────────────────────────────────────────────────────────────────────────── */}
    <div class="flex flex-col items-center gap-8 pt-8 border-t border-white/10 md:flex-row md:justify-between md:items-center">
      {/* Logo + trust badges */}
      <div class="flex flex-nowrap items-center justify-center gap-6 min-[480px]:gap-10 md:justify-start">
        <a href="/" class="hover:scale-105 transition-transform duration-300">
          <img src="/images/Orange-Logo.svg" alt="DataDocks Logo" width="56" height="56" class="w-14 h-14" loading="lazy" decoding="async" />
        </a>
        <img src="/images/soc2-badge.png" alt="AICPA SOC2 Certified" width="120" height="119" class="h-16 min-[480px]:h-20 w-auto object-contain" loading="lazy" decoding="async" />
        <a href="https://feddev-ontario.canada.ca/" target="_blank" rel="noopener noreferrer" class="hover:scale-105 transition-transform duration-300">
          <img src="/images/canada-badge.png" alt="Government of Canada" width="600" height="43" class="h-10 w-auto max-w-full object-contain" loading="lazy" decoding="async" />
        </a>
      </div>

      {/* Social links + copyright */}
      <div class="flex flex-col items-center gap-3 md:items-end">
        <div class="flex items-center gap-5">
          <a href="https://www.linkedin.com/company/datadocks" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="text-[#FFF8E9]/60 hover:text-[#0077b5] transition-colors"><Linkedin aria-hidden="true" className="w-5 h-5" /></a>
          <a href="https://x.com/datadocks" target="_blank" rel="noopener noreferrer" aria-label="X (Twitter)" class="text-[#FFF8E9]/60 hover:text-[#FFF8E9] transition-colors">
            <svg viewBox="0 0 24 24" aria-hidden="true" class="w-5 h-5 fill-current"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"></path></svg>
          </a>
          <a href="https://www.youtube.com/@datadocks" target="_blank" rel="noopener noreferrer" aria-label="YouTube" class="text-[#FFF8E9]/60 hover:text-[#FF0000] transition-colors"><Youtube aria-hidden="true" className="w-5 h-5" /></a>
        </div>
        <p class="text-sm text-[#FFF8E9]/80">©{new Date().getFullYear()} Northfire Inc.</p>
      </div>
    </div>

  </div>
</footer>