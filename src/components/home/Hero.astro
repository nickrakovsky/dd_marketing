---
const basePath = import.meta.env.BASE_URL.replace(/\/$/, "");
const bentoAction = "https://track.bentonow.com/forms/b4cb9a34a989bcc643714151df7b7154/Demo%20Subscriber?hardened=true";
const calendlyUrl = "https://calendly.com/nick-rakovsky/datadocks-demo?primary_color=FF5722";
---

<section class="relative pt-16 md:pt-24 pb-12 overflow-hidden bg-[#FFF8E9] text-black">
  <div class="container mx-auto px-4">
    <div class="flex flex-col items-center max-w-5xl mx-auto text-center">
      
      {/* 1. Main Heading */}
      <div class="relative mb-10 w-full max-w-4xl mx-auto">
         <h1 class="font-bruta uppercase relative z-0 text-black">
            
            {/* MOBILE / TABLET STACKED VIEW (below 860px) */}
            <span class="block hero-desktop:hidden text-[clamp(3rem,11vw,7rem)] leading-[0.85] text-black w-full">
              <span class="block relative inline-block">YOUR
                <div class="absolute top-0 right-0 -translate-y-1/2 translate-x-1/2 z-10 w-[clamp(40px,10vw,80px)] h-[clamp(40px,10vw,80px)]">
                  <img 
                    src={`${basePath}/images/hero-badge.webp`}
                    alt="Save Time Make It Visible"
                    class="w-full h-full animate-[spin_12s_linear_infinite]"
                  />
                </div>
              </span>
              <span class="block">LOADING</span>
              <span class="block">DOCK,</span>
              <span class="block">YOUR</span>
              <span class="block">RULES</span>
            </span>

            {/* DESKTOP VIEW (860px+) — restored to original text-8xl that fits on 2 lines */}
            <span class="hidden hero-desktop:block text-8xl leading-[0.85] text-black">
              <span class="relative inline-block">
                YOUR LOADING DOCK,
                <div class="absolute top-[2%] right-[calc(0.5ch)] -translate-y-1/2 translate-x-1/2 z-10 w-24 h-24">
                  <img 
                    src={`${basePath}/images/hero-badge.webp`}
                    alt="Save Time Make It Visible"
                    class="w-full h-full animate-[spin_12s_linear_infinite]"
                  />
                </div>
              </span>
              <span class="block">YOUR RULES</span>
            </span>

         </h1>
      </div>

      {/* 2. Subheading — responsive: ~4 lines narrow / ~3 lines mid / 2 lines desktop */}
      <p class="font-recoleta text-[clamp(1.1rem,3.2vw,1.5rem)] text-black mb-12 max-w-[85vw] sm:max-w-[340px] md:max-w-[400px] lg:max-w-[640px] mx-auto leading-relaxed px-2">
        Our dock scheduling software is known for having the easiest interface and the most helpful team in the industry.
        <br class="hidden lg:block" />
        <strong class="text-black block mt-3 md:mt-4">Start turning trucks around faster today.</strong>
      </p>

      {/* 3. Form Area */}
      <div class="w-full max-w-[95%] md:max-w-2xl mx-auto mb-12 px-0">
        <form 
          id="hero-bento-form"
          class="flex flex-col sm:flex-row items-stretch justify-center gap-0 bg-[#EFE2D2] sm:bg-transparent"
        >
          <input 
            type="email" 
            name="email"
            placeholder="Enter your email" 
            style="outline: none !important; box-shadow: none !important; -webkit-appearance: none;"
            class="!h-12 sm:!h-14 w-full sm:w-[22rem] px-4 text-center sm:text-left sm:hover:pl-5 sm:focus:pl-5 transition-all duration-300 bg-[#EFE2D2] text-black placeholder:text-[#8D785C] text-lg border-none font-recoleta focus:ring-0 focus:outline-none"
            required
          />
          <button 
            type="submit"
            class="!h-12 sm:!h-14 w-full sm:w-auto px-8 bg-[#FF5507] hover:bg-black text-white font-medium transition-colors duration-500 whitespace-nowrap tracking-wide text-lg flex items-center justify-center font-recoleta"
          >
            Get Free Demo
          </button>
        </form>
      </div>

    </div>

    {/* 4. Desktop Hero Image */}
    <div class="hidden hero-desktop:block relative w-screen ml-[calc(50%-50vw)] mt-16 shadow-[0_12px_15px_-10px_rgba(0,0,0,0.1)] overflow-hidden">
      <img
        src={`${basePath}/images/DataDocks-Calendar-Screenshot.webp`}
        alt="DataDocks Calendar Interface"
        fetchpriority="high"
        loading="eager"
        class="w-full h-auto object-cover"
      />
    </div>

    {/* 5. Mobile/Tablet Hero Image — tappable/draggable pan */}
    <div class="block hero-desktop:hidden mt-8 w-full px-0 mb-4">
      <div id="hero-mobile-frame" class="relative w-full h-[55vh] min-h-[350px] rounded-xl shadow-[0_10px_12px_-8px_rgba(0,0,0,0.1)] overflow-hidden touch-none">
        <img 
          id="hero-mobile-img"
          src={`${basePath}/images/homepage-screenshot-mobile.webp`}
          alt="DataDocks Calendar Interface Mobile"
          fetchpriority="high"
          loading="eager"
          class="w-full h-full object-cover hero-pan-active"
          style="object-position: 0% 50%;"
        />
      </div>
    </div>

  </div>
</section>

<style>
  /* Custom breakpoint: 860px for the hero desktop/mobile switch */
  @media (min-width: 860px) {
    .hero-desktop\:block { display: block !important; }
    .hero-desktop\:hidden { display: none !important; }
  }
  @media (max-width: 859px) {
    .hero-desktop\:block { display: none !important; }
  }

  @keyframes pan-x {
    0%, 10% { object-position: 0% 50%; }
    45%, 55% { object-position: 100% 50%; }
    90%, 100% { object-position: 0% 50%; }
  }
  .hero-pan-active {
    animation: pan-x 24s ease-in-out infinite;
    will-change: object-position;
  }
</style>

<script is:inline>
  (function() {
    var calendlyUrl = "https://calendly.com/nick-rakovsky/datadocks-demo?primary_color=FF5722";
    var form = document.getElementById('hero-bento-form');
    if (form) {
      form.addEventListener('submit', function(e) {
        e.preventDefault();
        var email = (form.querySelector('input[name="email"]') || {}).value;
        if (email && window.bento) {
          window.bento.identify(email);
          window.bento.track('Demo Subscriber', { source: window.location.pathname });
        }
        window.open(calendlyUrl, '_blank', 'noopener');
        form.reset();
      });
    }
  })();
</script>
<script>
  const frame = document.getElementById('hero-mobile-frame');
  const img = document.getElementById('hero-mobile-img');

  if (frame && img) {
    let animationStopped = false;
    let isDragging = false;
    let startX = 0;
    let currentPct = 0;

    function stopAnimation() {
      if (animationStopped) return;
      const computed = getComputedStyle(img).objectPosition;
      const match = computed.match(/([\d.]+)%/);
      currentPct = match ? parseFloat(match[1]) : 0;
      img.classList.remove('hero-pan-active');
      img.style.objectPosition = `${currentPct}% 50%`;
      animationStopped = true;
    }

    frame.addEventListener('pointerdown', (e) => {
      stopAnimation();
      isDragging = true;
      startX = e.clientX;
      frame.setPointerCapture(e.pointerId);
    });

    frame.addEventListener('pointermove', (e) => {
      if (!isDragging) return;
      const dx = e.clientX - startX;
      const frameWidth = frame.offsetWidth;
      const deltaPct = -(dx / frameWidth) * 100;
      let newPct = currentPct + deltaPct;
      newPct = Math.max(0, Math.min(100, newPct));
      img.style.objectPosition = `${newPct}% 50%`;
    });

    frame.addEventListener('pointerup', (e) => {
      if (!isDragging) return;
      isDragging = false;
      const computed = getComputedStyle(img).objectPosition;
      const match = computed.match(/([\d.]+)%/);
      currentPct = match ? parseFloat(match[1]) : currentPct;
    });

    frame.addEventListener('pointercancel', () => {
      isDragging = false;
    });
  }
</script>