---
// Final Hero Component (v5)
// - No Badge
// - Uppercase Bruta Headers
// - Centered Layout
---

<section class="relative pt-16 md:pt-24 pb-12 overflow-hidden bg-[#FFF8E9] text-black">
  <div class="container mx-auto px-2">
    <div class="flex flex-col items-center max-w-5xl mx-auto text-center">
      
      {/* 1. Main Heading */}
      <div class="relative mb-6 w-full max-w-4xl mx-auto">
         <h1 class="font-bruta text-[10vw] sm:text-7xl md:text-8xl leading-[0.85] uppercase relative z-0 text-[#FF5507]">
            {/* Note: I added text-[#FF5507] (Orange) just in case, but usually it's black in your design? 
                index.html shows standard text color. If it should be black, remove text-[#FF5507] */}
            <span class="block text-black">
              <span class="relative inline-block">
                YOUR LOADING DOCK,
                {/* Badge anchored to line 1 */}
                <div class="absolute top-[2%] right-[calc(0.5ch)] -translate-y-1/2 translate-x-1/2 z-10 w-11 h-11 md:w-24 md:h-24">
                  <img 
                    src="/images/hero-badge.png" 
                    alt="Save Time Make It Visible"
                    class="w-full h-full animate-[spin_12s_linear_infinite]"
                  />
                </div>
              </span>
            </span>
            <span class="block text-black">YOUR RULES</span>
         </h1>
      </div>

      {/* 2. Subheading */}
      <p class="font-recoleta text-lg md:text-2xl text-gray-700 mb-8 max-w-xl mx-auto leading-relaxed px-1">
        Our dock scheduling software is known for having the easiest interface and the most helpful team in the industry.
        <br class="hidden md:block" />
        <strong class="text-black block mt-3 md:mt-4">Start turning trucks around faster today.</strong>
      </p>

      {/* 3. Form Area */}
      <div class="w-full max-w-[95%] md:max-w-md mx-auto mb-12 px-0">
        <form 
          action="https://calendly.com/nick-rakovsky/datadocks-demo" 
          target="_blank"
          class="flex flex-col md:flex-row items-stretch gap-0 bg-[#EFE2D2] md:bg-transparent"
        >
          <input 
            type="email" 
            placeholder="Enter your email" 
            style="outline: none !important; box-shadow: none !important; -webkit-appearance: none;"
            class="!h-12 md:!h-14 w-full md:w-auto md:flex-1 px-4 text-center md:text-left md:hover:pl-6 md:focus:pl-6 transition-all duration-300 bg-[#EFE2D2] text-black placeholder:text-[#8D785C] text-lg border-none font-recoleta focus:ring-0 focus:outline-none"
            required
          />
          <button 
            type="submit"
            class="!h-12 md:!h-14 w-full md:w-auto px-8 bg-[#FF5507] hover:bg-[#ff6a2b] text-white font-medium transition-all duration-300 whitespace-nowrap tracking-wide text-lg flex items-center justify-center font-recoleta"
          >
            Schedule a Demo
          </button>
        </form>
      </div>

    </div>

    {/* 4. Hero Image - CSS Breakout Full Width */}
    <div class="relative w-screen ml-[calc(50%-50vw)] mt-16 shadow-2xl overflow-hidden border-y border-[#EFE2D2] bg-white">
      <img 
        src="/images/DataDocks-Calendar-Screenshot.webp" 
        alt="DataDocks Calendar Interface" 
        class="w-full h-auto object-cover"
      />
    </div>

  </div>
  </div>
</section>