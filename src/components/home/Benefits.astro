---
// src/components/home/Benefits.astro
// NOTE: We intentionally use plain <img> tags here (not Astro's <Image> component).
// The site uses output: 'server' + imageService: 'compile', which generates hashed
// /_astro/*.webp URLs that only exist in the static build tree. On the live SSR site,
// those URLs hit the catch-all server route and return the homepage HTML instead of
// the actual image — causing the "benefits images don't load" bug. Static files in
// /public/images/ are served directly by Cloudflare Pages with stable, predictable URLs.

const features = [
  {
    title: "Real-Time Dock and Yard Visibility",
    srTitle: "real-time dock and yard visibility",
    description:
      "See exactly what's in your loading dock and yard at a glance, and estimate the loading time for each truck. Spot bottlenecks before they cascade into missed appointments.",
    link: "/benefits/see-everything",
    src: "/images/Managers-Office.webp",
    srcset: "/images/de6c1a54b92ec0cc6a5fe48c9ab2a390_Managers-Office-p-500.webp 500w, /images/Managers-Office.webp 800w",
    alt: "Manager overlooking loading dock operations",
  },
  {
    title: "Reduce Detention Fees and Driver Wait Times",
    srTitle: "reducing detention fees and driver wait times",
    description:
      "Show carriers, with data, how sticking to your schedule gets their trucks in and out of your facility faster. Timestamped arrival and departure records make detention disputes easy to resolve.",
    link: "/benefits/delight-carriers",
    src: "/images/Dock-Interior.webp",
    srcset: "/images/7b6dcc2c228a4f21953e11ac0efd4c2d_Dock-Interior-p-500.webp 500w, /images/Dock-Interior.webp 800w",
    alt: "Inside view of a busy loading dock",
  },
  {
    title: "Increase Warehouse Throughput Without Adding Doors",
    srTitle: "increasing warehouse throughput without adding doors",
    description:
      "Spread truck arrivals evenly across the day instead of bunching at 8 AM. Predict how much manpower you'll need and optimize your operations over time.",
    link: "/benefits/increase-capacity",
    src: "/images/ed60b008d9aeacd6d851628506ef7e44_Warehouse-Interior-p-2000.webp",
    srcset: "/images/ed60b008d9aeacd6d851628506ef7e44_Warehouse-Interior-p-500.webp 500w, /images/ed60b008d9aeacd6d851628506ef7e44_Warehouse-Interior-p-800.webp 800w, /images/ed60b008d9aeacd6d851628506ef7e44_Warehouse-Interior-p-1080.webp 1080w, /images/ed60b008d9aeacd6d851628506ef7e44_Warehouse-Interior-p-1600.webp 1600w, /images/ed60b008d9aeacd6d851628506ef7e44_Warehouse-Interior-p-2000.webp 2000w",
    alt: "Warehouse interior with organized cargo",
  },
  {
    title: "Replace Spreadsheets With a Self-Service Carrier Portal",
    srTitle: "replacing spreadsheets with a self-service carrier portal",
    description:
      "Carriers book and you stay in control. Replace calls and emails with an easy interface that sends automatic notifications to drivers, dispatchers, and your warehouse team.",
    link: "/benefits/digitize-operations",
    src: "/images/Dock-Exterior.webp",
    srcset: "/images/77558bf99568593951c2f7f59bda11ae_Dock-Exterior-p-500.webp 500w, /images/Dock-Exterior.webp 800w",
    alt: "Exterior view of loading docks",
  },
];
---

<section class="py-20 bg-[#FFF8E9]">
  <div class="container mx-auto px-4">
    <div class="flex flex-col gap-16 max-w-7xl mx-auto">
      {
        features.map((feature, index) => (
          <div
            class={`flex flex-col lg:flex-row items-center gap-10 lg:gap-16 ${index % 2 === 1 ? "lg:flex-row-reverse" : ""}`}
          >
            {/* Text Side */}
            <div class="w-full lg:w-5/12 flex-shrink-0 space-y-6">
              <h2 class="font-bruta text-3xl sm:text-4xl lg:text-5xl text-black uppercase leading-tight">
                {feature.title}
              </h2>
              <div class="w-16 h-1 bg-[#FF5507]" />
              <p class="font-recoleta text-lg md:text-xl text-gray-700 leading-relaxed">
                {feature.description}
              </p>
              <a
                href={feature.link}
                class="inline-block w-full lg:w-auto text-center px-8 py-3 bg-[#FE5000] text-white font-recoleta font-medium rounded-none hover:bg-black hover:text-white transition-colors duration-300 tracking-wide text-lg [text-shadow:0px_1px_2px_rgba(0,0,0,0.4)] hover:[text-shadow:none]"
              >
                Learn More<span class="sr-only"> about {feature.srTitle}</span>
              </a>
            </div>

            {/* Image Side */}
            <div class="w-full lg:w-7/12 flex-shrink-0">
              <div class="relative rounded-2xl overflow-hidden shadow-xl border border-gray-100 aspect-[4/3]">
                <img
                  src={feature.src}
                  srcset={feature.srcset}
                  sizes="(max-width: 1024px) 100vw, 58vw"
                  alt={feature.alt}
                  loading="lazy"
                  decoding="async"
                  class="w-full h-full object-cover"
                />
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
