---
// src/components/home/Resources.astro
// Homepage internal link section. The Webflow → Astro migration removed
// homepage links to blog posts, costing internal link juice. This section
// restores it with curated, high-value articles matched to commercial intent.

import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';

// Curated featured posts — chosen because they match our highest-value
// commercial keywords, support topical authority, AND have cover images.
const featuredSlugs = [
  'what-is-dock-scheduling',
  'best-yard-management-options',
  'what-is-a-yard-management-system-yms',
  'warehouse-receiving-process',
  'dwell-time-in-trucking',
  'carrier-scorecards',
];

const allPosts = await getCollection('posts');
const featured = featuredSlugs
  .map((slug) => allPosts.find((p: CollectionEntry<'posts'>) => p.slug === slug))
  .filter((p): p is CollectionEntry<'posts'> => p !== undefined);
---

<section class="relative py-20 md:py-28 overflow-hidden">

  {/* Layered background: deep cream base with a diagonal orange accent band */}
  <div class="absolute inset-0 bg-[#EFE2D2]" aria-hidden="true"></div>
  <div
    class="absolute inset-0 opacity-[0.04] pointer-events-none"
    style="background-image: radial-gradient(#FE5000 1px, transparent 1px); background-size: 24px 24px;"
    aria-hidden="true"
  ></div>
  <div
    class="absolute -top-20 -right-20 w-80 h-80 rounded-full bg-[#FE5000] opacity-[0.08] blur-3xl pointer-events-none"
    aria-hidden="true"
  ></div>
  <div
    class="absolute -bottom-32 -left-20 w-96 h-96 rounded-full bg-[#FE5000] opacity-[0.05] blur-3xl pointer-events-none"
    aria-hidden="true"
  ></div>

  <div class="relative container mx-auto px-4 max-w-7xl">

    {/* Section header */}
    <div class="flex flex-col md:flex-row md:items-end md:justify-between mb-14 gap-6">
      <div>
        <div class="font-recoleta text-sm uppercase tracking-[0.2em] text-[#FE5000] font-bold mb-4">
          Resources
        </div>
        <h2 class="font-bruta text-3xl sm:text-4xl lg:text-5xl uppercase leading-tight text-black mb-5">
          Learn More About<br class="hidden md:block" />
          <span class="text-[#FE5000]">Dock and Yard Operations</span>
        </h2>
        <div class="w-16 h-1 bg-[#FF5507]"></div>
      </div>
      <a
        href="/posts"
        class="group inline-flex items-center gap-2 font-recoleta text-sm uppercase tracking-[0.15em] font-bold text-black hover:text-[#FE5000] transition-colors self-start md:self-end"
      >
        See all articles
        <span class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-[#FE5000] text-white transition-transform group-hover:translate-x-1">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
            <path d="m9 18 6-6-6-6"/>
          </svg>
        </span>
      </a>
    </div>

    {/* Post grid */}
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
      {featured.map((post: CollectionEntry<'posts'>) => (
        <a
          href={`/posts/${post.slug}`}
          class="resource-card group flex flex-col bg-[#FFF8E9] rounded-2xl overflow-hidden shadow-[0_4px_20px_rgba(0,0,0,0.05)] hover:shadow-[0_12px_40px_rgba(254,80,0,0.18)] transition-all duration-300 hover:-translate-y-1"
        >
          {/* Cover image */}
          {post.data.cardImage && (
            <div class="relative aspect-[16/10] overflow-hidden bg-[#EFE2D2]">
              <Image
                src={post.data.cardImage}
                alt={post.data.cardAlt || post.data.title}
                width={640}
                height={400}
                loading="lazy"
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
              />
              {/* Gradient overlay */}
              <div class="absolute inset-0 bg-gradient-to-t from-black/30 via-transparent to-transparent opacity-60 group-hover:opacity-40 transition-opacity"></div>
              {/* Category badge */}
              {post.data.category && (
                <div class="absolute top-4 left-4">
                  <span class="inline-block font-recoleta text-[10px] uppercase tracking-[0.15em] font-bold text-white bg-black/70 backdrop-blur-sm px-3 py-1.5 rounded-full">
                    {post.data.category}
                  </span>
                </div>
              )}
            </div>
          )}

          {/* Body */}
          <div class="p-6 md:p-7 flex flex-col flex-grow">
            <h3 class="font-bruta text-xl md:text-[1.4rem] uppercase text-black leading-[1.15] mb-3 group-hover:text-[#FE5000] transition-colors">
              {post.data.title}
            </h3>
            <p class="font-recoleta text-[15px] text-gray-600 leading-relaxed flex-grow mb-5 line-clamp-3">
              {post.data.description}
            </p>
            <div class="flex items-center justify-between pt-4 border-t border-[#EFE2D2] mt-auto">
              <span class="font-recoleta text-xs uppercase tracking-wider text-gray-500">
                {post.data.author}
              </span>
              <div class="inline-flex items-center gap-1.5 font-recoleta text-sm font-bold text-[#FE5000]">
                Read
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-1">
                  <path d="m9 18 6-6-6-6"/>
                </svg>
              </div>
            </div>
          </div>
        </a>
      ))}
    </div>

  </div>
</section>

<style>
  /* line-clamp-3 fallback for older browsers (most modern ones already support it via Tailwind) */
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
