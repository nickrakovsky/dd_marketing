---
const features = [
  { title: "Carrier Self-Scheduling", slug: "carrier-portal", srTitle: "how DataDocks' carrier scheduling portal works", text: "Let carriers self-manage and book their own dock appointments through a branded, secure portal, cutting scheduling labor by 80%.", icon: "/images/features/checked-laptop.svg" },
  { title: "Yard Visibility & Jockey Orders", slug: "yard-management", srTitle: "managing real-time yard visibility and sending jockey orders", text: "Track trailer locations on a digital yard map and send electronic jockey orders to keep yard and dock flow in sync.", icon: "/images/features/vision.svg" },
  { title: "In-app QC & Compliance Checks", slug: "documentation", srTitle: "running digital quality control and compliance check-lists", text: "Upload BOLs, capture damage photos, complete compliance checklists, and collect digital signatures directly at the dock door.", icon: "/images/features/submit-document.svg" },
  { title: "Dock Capacity Management", slug: "capacity-limits", srTitle: "setting hourly dock capacity and booking limits", text: "Set hourly booking limits and load-type constraints across specific docks or zones to prevent facility bottlenecks.", icon: "/images/features/partially-shipped.svg" },
  { title: "Automated Scheduling Rules", slug: "custom-rules", srTitle: "enforcing automated custom scheduling and routing rules", text: "Define custom rules for auto-approvals, required lead times, and carrier booking privileges to automate your scheduling workflow.", icon: "/images/features/delivery.svg" },
  { title: "PO Validation & Data Integrity", slug: "data-validation", srTitle: "enforcing required fields and validating load-to-PO quantities", text: "Enforce required booking fields and validate load quantities against PO limits to prevent over-allocation and data entry errors.", icon: "/images/features/data-quality.svg" },
  { title: "Detention Analytics & Executive Reporting", slug: "efficiency-reports", srTitle: "analyzing carrier detention costs and dock utilization reports", text: "Track gate-to-gate dwell times, calculate detention exposure, and export carrier performance reports to eliminate wait-time fees.", icon: "/images/features/linechart-file.svg" },
  { title: "Automated Alerts & Notifications", slug: "notifications", srTitle: "sending automated jockey, carrier, and driver alerts", text: "Trigger instant email or SMS alerts to carriers, drivers, and yard jockeys when appointment times change or delays occur.", icon: "/images/features/push-notifications.svg" },
  { title: "Mobile Companion App", slug: "access-anywhere", srTitle: "using mobile companion app on the dock floor and yard", text: "Access a mobile-optimized interface on tablets or smartphones for gate check-ins, dock inspections, and real-time status updates.", icon: "/images/features/multiple-devices.svg" },
  { title: "AI Logistics Assistant", slug: "ai-assistant", srTitle: "using conversational AI logistics assistant for schedule queries", text: "Ask the AI assistant natural language questions about your dock schedule, carrier history, and potential bottlenecks to get instant answers.", icon: "/images/features/people.svg" },
  { title: "WMS & TMS Integrations", slug: "integration", srTitle: "integrating dock schedule with WMS and TMS systems", text: "Connect seamlessly with your WMS and TMS to sync purchase orders, automate status updates, and eliminate manual double-entry.", icon: "/images/features/automation.svg" },
  { title: "Live Dock Dashboard", slug: "dock-dashboard", srTitle: "managing scheduling flow with the live dock dashboard", text: "Monitor gate check-ins, loading progress, and dock status in real-time from an interactive, drag-and-drop board.", icon: "/images/features/dashboard-layout.svg" }
];

const slugify = (text: string) => text.toLowerCase().replace(/\s+/g, '-');
---

<section id="features" class="py-24 bg-[#FFF8E9]">
  <div class="container mx-auto px-2 md:px-4 max-w-7xl">
    
    <div class="text-center mb-16 max-w-4xl mx-auto">
      <h2 class="font-bruta text-4xl md:text-5xl uppercase leading-none mb-4 text-black">
        Everything You Need to <span class="text-[#FE5000]">Master Your Docks and Yard</span>
      </h2>
    </div>

    {/* 2 cols on small screens, 3 cols on md+ (768px) */}
    <div class="grid grid-cols-2 md:grid-cols-3 gap-x-2 md:gap-x-4 gap-y-4 md:gap-y-5">
      {features.map((feature) => {
        const featureUrl = `/datadocks-features/${feature.slug || slugify(feature.title)}`;
        return (
        <>
          {/* DESKTOP (md+): Whole card is a link */}
          <a 
            href={featureUrl}
            class="feature-card hidden md:block p-8 rounded-2xl border border-transparent bg-[#FFF8E9] transition-all duration-300"
          >
            <div class="flex flex-row items-center gap-3 mb-4">
              <div class="w-10 h-10 flex-shrink-0">
                <img
                  src={feature.icon}
                  alt={feature.title}
                  width="40"
                  height="40"
                  loading="lazy"
                  class="w-full h-full object-contain"
                />
              </div>
              <h3 class="feature-title font-bruta text-2xl uppercase text-black transition-colors leading-tight">
                {feature.title}
              </h3>
            </div>
            <p class="font-recoleta text-[15px] text-gray-700 leading-relaxed">
              {feature.text}
            </p>
          </a>

          {/* MOBILE (<md): Card is static, only "Learn More" is a link */}
          <div 
            class="feature-card md:hidden p-3 rounded-2xl border border-transparent bg-[#FFF8E9] transition-all duration-300 flex flex-col focus:outline-none"
            tabindex="0"
            role="button"
          >
            <h3 class="feature-title font-bruta text-base sm:text-lg uppercase text-black transition-colors leading-tight mb-2">
              {feature.title}
            </h3>
            <div class="clearfix flex-grow">
              <div class="float-left mr-2 mb-1 w-7 h-7 sm:w-8 sm:h-8 flex-shrink-0">
                <img
                  src={feature.icon}
                  alt={feature.title}
                  width="32"
                  height="32"
                  loading="lazy"
                  class="w-full h-full object-contain"
                />
              </div>
              <p class="font-recoleta text-[clamp(0.78rem,2.2vw,0.9rem)] text-gray-700 leading-relaxed">
                {feature.text}
              </p>
            </div>
            
            {/* Mobile Affordance: Only this part is a link */}
            <a href={featureUrl} class="mobile-link flex items-center gap-1 mt-3 self-start outline-none">
              <span class="link-text font-recoleta text-[10px] sm:text-xs text-[#FE5000] font-bold transition-colors [text-shadow:0px_1px_2px_rgba(0,0,0,0.15)]">Learn More</span>
              <span class="sr-only"> about {feature.srTitle}</span>
              <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#FE5000" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" class="sm:w-3 sm:h-3 drop-shadow-sm">
                <path d="m9 18 6-6-6-6"/>
              </svg>
            </a>
          </div>
        </>
      )})}
    </div>

  </div>
</section>

<style>
  /* Common highlight styles for desktop hover and mobile focus/active */
  .feature-card:hover,
  .feature-card:focus {
    border-color: #EFE2D2;
    box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1);
  }

  /* Desktop-only hover effects */
  @media (hover: hover) and (pointer: fine) {
    .feature-card:hover .feature-title {
      color: #FE5000;
    }
  }

  /* Mobile active/tactile feedback and persistence */
  @media (hover: none), (pointer: coarse) {
    /* Title remains orange when focused or hovered (which sticks on mobile) */
    .feature-card:focus .feature-title,
    .feature-card:hover .feature-title,
    .feature-card:active .feature-title {
      color: #FE5000;
    }

    /* "Learn More" text flashes black when selected */
    .mobile-link:active .link-text {
      color: #000000 !important;
    }
    
    .mobile-link:active svg {
      stroke: #000000 !important;
    }
  }

  /* Clearfix for the floated icon on mobile */
  .clearfix::after {
    content: "";
    clear: both;
    display: table;
  }
</style>