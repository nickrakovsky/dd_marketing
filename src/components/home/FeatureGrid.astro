---
const features = [
  { title: "Carrier Portal", srTitle: "how DataDocks' carrier portal works", text: "Let carriers self-manage dock appointments and check-ins with a branded, easy-to-use portal that streamlines scheduling.", icon: "/images/features/checked-laptop.svg" },
  { title: "Yard Management", srTitle: "how to get real-time yard visibility", text: "Get real-time yard visibility. Track trailers, reduce congestion, and streamline dock operations for peak efficiency.", icon: "/images/features/vision.svg" },
  { title: "Documentation", srTitle: "accessing our product documentation", text: "Access comprehensive product documentation and developer guides to help you integrate and configure DataDocks.", icon: "/images/features/submit-document.svg" },
  { title: "Capacity Limits", srTitle: "setting constraints on docks and yard areas", text: "Set maximum limits for docks and yard areas to prevent overbooking, reduce bottlenecks, and maintain safety.", icon: "/images/features/partially-shipped.svg" },
  { title: "Custom Rules", srTitle: "creating flexible business rules", text: "Create flexible business rules for scheduling, approvals, and compliance to match your site's unique workflow.", icon: "/images/features/delivery.svg" },
  { title: "Data Validation", srTitle: "how built-in data validation works", text: "Ensure cleaner data with built-in validation for appointments and inputs - reducing errors and rework.", icon: "/images/features/data-quality.svg" },
  { title: "Efficiency Reports", srTitle: "tracking operational performance metrics", text: "Track performance metrics like dwell time and appointment adherence to identify bottlenecks.", icon: "/images/features/linechart-file.svg" },
  { title: "Notifications", srTitle: "staying ahead with automatic alerts", text: "Stay ahead of delays and changes with automatic alerts and real-time notifications for teams and drivers.", icon: "/images/features/push-notifications.svg" },
  { title: "Access Anywhere", srTitle: "using DataDocks across any device", text: "Use DataDocks from any device, anywhere. No downloads required - just simple, secure, browser-based access.", icon: "/images/features/multiple-devices.svg" },
  { title: "Live Editing", srTitle: "making real-time collaborative edits", text: "Make real-time edits to schedules, trailers, and contact info with collaborative tools that keep everyone updated.", icon: "/images/features/people.svg" },
  { title: "Integration", srTitle: "integrating seamlessly with your WMS or TMS", text: "Integrate seamlessly with your WMS/TMS to eliminate double entry and streamline operations.", icon: "/images/features/automation.svg" },
  { title: "Dock Dashboard", srTitle: "managing appointments with the intuitive dashboard", text: "Manage appointments in real-time with an intuitive dashboard designed to reduce congestion and delays.", icon: "/images/features/dashboard-layout.svg" }
];

const slugify = (text: string) => text.toLowerCase().replace(/\s+/g, '-');
---

<section id="features" class="py-24 bg-[#FFF8E9]">
  <div class="container mx-auto px-2 md:px-4 max-w-7xl">
    
    <div class="text-center mb-16 max-w-4xl mx-auto">
      <h2 class="font-bruta text-4xl md:text-5xl uppercase leading-none mb-4 text-black">
        Everything You Need to <span class="text-[#FE5000]">Master Your Docks and Yard</span>
      </h2>
    </div>

    {/* 2 cols on small screens, 3 cols on md+ (768px) */}
    <div class="grid grid-cols-2 md:grid-cols-3 gap-x-2 md:gap-x-4 gap-y-4 md:gap-y-5">
      {features.map((feature) => (
        <>
          {/* DESKTOP (md+): Whole card is a link */}
          <a 
            href={`/datadocks-features/${slugify(feature.title)}`}
            class="feature-card hidden md:block p-8 rounded-2xl border border-transparent bg-[#FFF8E9] transition-all duration-300"
          >
            <div class="flex flex-row items-center gap-3 mb-4">
              <div class="w-10 h-10 flex-shrink-0">
                <img
                  src={feature.icon}
                  alt={feature.title}
                  width="40"
                  height="40"
                  loading="lazy"
                  class="w-full h-full object-contain"
                />
              </div>
              <h3 class="feature-title font-bruta text-2xl uppercase text-black transition-colors leading-tight">
                {feature.title}
              </h3>
            </div>
            <p class="font-recoleta text-[15px] text-gray-700 leading-relaxed">
              {feature.text}
            </p>
          </a>

          {/* MOBILE (<md): Card is static, only "Learn More" is a link */}
          <div 
            class="feature-card md:hidden p-3 rounded-2xl border border-transparent bg-[#FFF8E9] transition-all duration-300 flex flex-col focus:outline-none"
            tabindex="0"
          >
            <h3 class="feature-title font-bruta text-base sm:text-lg uppercase text-black transition-colors leading-tight mb-2">
              {feature.title}
            </h3>
            <div class="clearfix flex-grow">
              <div class="float-left mr-2 mb-1 w-7 h-7 sm:w-8 sm:h-8 flex-shrink-0">
                <img
                  src={feature.icon}
                  alt={feature.title}
                  width="32"
                  height="32"
                  loading="lazy"
                  class="w-full h-full object-contain"
                />
              </div>
              <p class="font-recoleta text-[clamp(0.78rem,2.2vw,0.9rem)] text-gray-700 leading-relaxed">
                {feature.text}
              </p>
            </div>
            
            {/* Mobile Affordance: Only this part is a link */}
            <a href={`/datadocks-features/${slugify(feature.title)}`} class="mobile-link flex items-center gap-1 mt-3 self-start outline-none">
              <span class="link-text font-recoleta text-[10px] sm:text-xs text-[#FE5000] font-bold transition-colors [text-shadow:0px_1px_2px_rgba(0,0,0,0.15)]">Learn More</span>
              <span class="sr-only"> about {feature.srTitle}</span>
              <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#FE5000" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" class="sm:w-3 sm:h-3 drop-shadow-sm">
                <path d="m9 18 6-6-6-6"/>
              </svg>
            </a>
          </div>
        </>
      ))}
    </div>

  </div>
</section>

<style>
  /* Common highlight styles for desktop hover and mobile focus/active */
  .feature-card:hover,
  .feature-card:focus {
    border-color: #EFE2D2;
    box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1);
  }

  /* Desktop-only hover effects */
  @media (hover: hover) and (pointer: fine) {
    .feature-card:hover .feature-title {
      color: #FE5000;
    }
  }

  /* Mobile active/tactile feedback and persistence */
  @media (hover: none), (pointer: coarse) {
    /* Title remains orange when focused or hovered (which sticks on mobile) */
    .feature-card:focus .feature-title,
    .feature-card:hover .feature-title,
    .feature-card:active .feature-title {
      color: #FE5000;
    }

    /* "Learn More" text flashes black when selected */
    .mobile-link:active .link-text {
      color: #000000 !important;
    }
    
    .mobile-link:active svg {
      stroke: #000000 !important;
    }
  }

  /* Clearfix for the floated icon on mobile */
  .clearfix::after {
    content: "";
    clear: both;
    display: table;
  }
</style>