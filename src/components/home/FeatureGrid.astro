---
const features = [
  { title: "Carrier Portal", text: "Let carriers self-manage dock appointments and check-ins with a branded, easy-to-use portal that streamlines scheduling.", icon: "/images/features/checked-laptop.svg" },
  { title: "Yard Management", text: "Get real-time yard visibility. Track trailers, reduce congestion, and streamline dock operations for peak efficiency.", icon: "/images/features/vision.svg" },
  { title: "Documentation", text: "Access comprehensive product documentation and developer guides to help you integrate and configure DataDocks.", icon: "/images/features/submit-document.svg" },
  { title: "Capacity Limits", text: "Set maximum limits for docks and yard areas to prevent overbooking, reduce bottlenecks, and maintain safety.", icon: "/images/features/partially-shipped.svg" },
  { title: "Custom Rules", text: "Create flexible business rules for scheduling, approvals, and compliance to match your site's unique workflow.", icon: "/images/features/delivery.svg" },
  { title: "Data Validation", text: "Ensure cleaner data with built-in validation for appointments and inputs - reducing errors and rework.", icon: "/images/features/data-quality.svg" },
  { title: "Efficiency Reports", text: "Track performance metrics like dwell time and appointment adherence to identify bottlenecks.", icon: "/images/features/linechart-file.svg" },
  { title: "Notifications", text: "Stay ahead of delays and changes with automatic alerts and real-time notifications for teams and drivers.", icon: "/images/features/push-notifications.svg" },
  { title: "Access Anywhere", text: "Use DataDocks from any device, anywhere. No downloads required - just simple, secure, browser-based access.", icon: "/images/features/multiple-devices.svg" },
  { title: "Live Editing", text: "Make real-time edits to schedules, trailers, and contact info with collaborative tools that keep everyone updated.", icon: "/images/features/people.svg" },
  { title: "Integration", text: "Integrate seamlessly with your WMS/TMS to eliminate double entry and streamline operations.", icon: "/images/features/automation.svg" },
  { title: "Dock Dashboard", text: "Manage appointments in real-time with an intuitive dashboard designed to reduce congestion and delays.", icon: "/images/features/dashboard-layout.svg" }
];

const slugify = (text: string) => text.toLowerCase().replace(/\s+/g, '-');
---

<section id="features" class="py-24 bg-[#FFF8E9]">
  <div class="container mx-auto px-2 md:px-4 max-w-7xl">
    
    <div class="text-center mb-16 max-w-4xl mx-auto">
      <h2 class="font-bruta text-4xl md:text-5xl uppercase leading-none mb-4 text-black">
        Everything You Need to <span class="text-[#FF5507]">Master Your Docks and Yard</span>
      </h2>
    </div>

    {/* 2 cols on small screens, 3 cols on md+ (768px) */}
    <div class="grid grid-cols-2 md:grid-cols-3 gap-x-2 md:gap-x-4 gap-y-4 md:gap-y-5">
      {features.map((feature) => (
        <a 
          href={`/datadocks-features/${slugify(feature.title)}/`}
          class="group block p-3 md:p-8 rounded-2xl border border-transparent hover:border-[#EFE2D2] hover:shadow-lg transition-all duration-300 bg-[#FFF8E9]"
        >
          {/* DESKTOP (md+): icon beside title, then body text below — ORIGINAL LAYOUT */}
          <div class="hidden md:block">
            <div class="flex flex-row items-center gap-3 mb-4">
              <div class="w-10 h-10 flex-shrink-0">
                <img
                  src={feature.icon}
                  alt={feature.title}
                  width="40"
                  height="40"
                  loading="lazy"
                  class="w-full h-full object-contain"
                />
              </div>
              <h3 class="font-bruta text-2xl uppercase text-black group-hover:text-[#FF5507] transition-colors leading-tight">
                {feature.title}
              </h3>
            </div>
            <p class="font-recoleta text-[15px] text-gray-700 leading-relaxed">
              {feature.text}
            </p>
          </div>

          {/* MOBILE (<md): title on top, icon floats left of body text */}
          <div class="md:hidden">
            <h3 class="font-bruta text-base sm:text-lg uppercase text-black group-hover:text-[#FF5507] transition-colors leading-tight mb-2">
              {feature.title}
            </h3>
            <div>
              <div class="float-left mr-2 mb-1 w-7 h-7 sm:w-8 sm:h-8 flex-shrink-0">
                <img
                  src={feature.icon}
                  alt={feature.title}
                  width="32"
                  height="32"
                  loading="lazy"
                  class="w-full h-full object-contain"
                />
              </div>
              <p class="font-recoleta text-[clamp(0.78rem,2.2vw,0.9rem)] text-gray-700 leading-relaxed">
                {feature.text}
              </p>
            </div>
          </div>
        </a>
      ))}
    </div>

  </div>
</section>