---
// src/components/home/CTA.astro
---

<section class="py-10 md:py-12 bg-[#FF5507]">
  <div class="container mx-auto px-6 md:px-8">
    
    {/* Center aligned heading + inline form that flows naturally with text. */}
    <div class="text-left md:text-center w-full max-w-[1200px] mx-auto">
      
      <h2 class="inline font-bruta text-[clamp(1.6rem,5vw,3rem)] uppercase leading-tight md:leading-[1.1] text-[#FFF8E9] align-middle">
        Find out for yourself what DataDocks can do<br class="hidden md:inline" /> for your operations
      </h2>

      <form
        action="https://calendly.com/nick-rakovsky/datadocks-demo"
        target="_blank"
        class="flex flex-col md:flex-row md:inline-flex items-stretch w-full md:w-auto align-middle mt-5 md:mt-0 md:ml-3 gap-2 md:gap-0"
      >
        <input
          type="email"
          placeholder="Enter your email"
          style="outline: none !important; box-shadow: none !important; -webkit-appearance: none;"
          class="h-12 w-full md:w-64 lg:w-[20rem] px-4 bg-[#EFE2D2] text-black placeholder:text-[#8D785C] text-lg border-none font-recoleta focus:ring-0 focus:outline-none rounded-none"
          required
        />
        <button
          type="submit"
          class="h-12 px-8 bg-black hover:bg-[#EFE2D2] hover:text-black md:hover:bg-[#FF5507] md:hover:text-white text-white font-bold transition-all duration-300 uppercase tracking-wide text-sm font-recoleta whitespace-nowrap rounded-none"
        >
          Get Free Demo
        </button>
      </form>
    </div>

  </div>
</section>