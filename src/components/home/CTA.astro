---
// src/components/home/CTA.astro
---

<section class="py-10 md:py-[3.25rem] bg-[#FF5507]">
  <div class="container mx-auto px-6 md:px-8">
    <div class="w-full text-center h-full flex flex-col justify-center items-center">
      
      <div class="inline-block text-center min-[1020px]:text-left max-w-full w-full min-[1020px]:w-auto">
        <h2 class="font-bruta text-[clamp(1.6rem,4vw,3.1rem)] uppercase leading-tight text-[#FFF8E9]">
          <span class="inline min-[1020px]:block">Find out for yourself what DataDocks can do</span>
          <span class="inline min-[1020px]:hidden"> </span>
          <span class="inline min-[1020px]:inline-flex min-[1020px]:items-center">
            <span>for your operations</span>
            <form
              id="cta-bento-form"
              class="inline-flex flex-col sm:flex-row items-stretch sm:items-center justify-center w-full min-[1020px]:w-auto min-[1020px]:ml-5 mt-6 min-[1020px]:mt-0 gap-0"
              novalidate
            >
          <div class="relative flex flex-col w-full sm:w-[18rem] lg:w-[22rem]">
            <input
              type="email"
              name="email"
              placeholder="Enter your work email"
              style="outline: none !important; box-shadow: none !important; -webkit-appearance: none;"
              class="h-12 lg:h-[3.35rem] w-full px-5 bg-[#EFE2D2] text-black placeholder:text-[#8D785C] text-base lg:text-[17px] border-none font-recoleta focus:ring-0 focus:outline-none rounded-none transition-all duration-300 sm:hover:pl-6 sm:focus:pl-6"
              required
            />
            <p
              id="cta-email-error"
              class="absolute -bottom-6 left-0 text-[#FFF8E9] text-xs font-recoleta opacity-0 transition-opacity duration-200 whitespace-nowrap"
            >
              Please use a business email address.
            </p>
          </div>
          <button
            type="submit"
            class="h-12 lg:h-[3.35rem] px-6 lg:px-8 bg-black hover:bg-[#EFE2D2] hover:text-black md:hover:bg-[#FF5507] md:hover:text-white text-white font-bold transition-all duration-300 uppercase tracking-wide text-[14px] lg:text-[15px] font-recoleta whitespace-nowrap rounded-none flex-shrink-0"
          >
            Get Free Demo
          </button>
        </form>
          </span>
        </h2>
      </div>

    </div>
  </div>
</section>

<script is:inline>
  (function() {
    var calendlyUrl = "https://calendly.com/nick-rakovsky/datadocks-demo?primary_color=FF5722";

    var BLOCKED_DOMAINS = new Set([
      "gmail.com",
      "yahoo.com",
      "outlook.com",
      "hotmail.com",
      "live.com",
      "msn.com",
      "icloud.com",
      "me.com",
      "aol.com",
      "protonmail.com",
      "proton.me",
      "gmx.com",
      "mail.com",
      "yandex.com"
    ]);

    function isBusinessEmail(email) {
      var parts = email.toLowerCase().trim().split('@');
      if (parts.length !== 2) return false;
      return !BLOCKED_DOMAINS.has(parts[1]);
    }

    function showError(form, show) {
      var err = document.getElementById('cta-email-error');
      var input = form.querySelector('input[name="email"]');
      if (!err) return;
      err.style.opacity = show ? '1' : '0';
      if (input) {
        if (show) input.classList.add('ring-1', 'ring-[#FFF8E9]');
        else input.classList.remove('ring-1', 'ring-[#FFF8E9]');
      }
    }

    function attachCtaForm() {
      var form = document.getElementById('cta-bento-form');
      if (!form || form.dataset.bound) return;
      form.dataset.bound = 'true';

      var emailInput = form.querySelector('input[name="email"]');
      if (emailInput) {
        emailInput.addEventListener('input', function() {
          showError(form, false);
        });
      }

      form.addEventListener('submit', function(e) {
        e.preventDefault();
        var email = emailInput ? emailInput.value.trim() : '';

        if (!email || !isBusinessEmail(email)) {
          showError(form, true);
          if (emailInput) emailInput.focus();
          return;
        }

        showError(form, false);

        // 1. Client-side identify (Primary stitching)
        // If the SDK is loaded and not blocked, this handles the identity link officially.
        if (typeof window.bento !== 'undefined' && typeof window.bento.identify === 'function') {
          window.bento.identify(email);
        }

        // 2. Server-side proxy (Backup/Ad-block resistant)
        fetch('/api/bento-track', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            email: email,
            event: 'Demo Subscriber',
            source: window.location.pathname,
            landingPage: sessionStorage.getItem('dd_landing_page') || window.location.href,
            visitorUuid: (typeof window.getBentoVisitorUuid === 'function') ? window.getBentoVisitorUuid() : null
          }),
          keepalive: true
        }).catch(function() {});

        window.open(calendlyUrl + '&email=' + encodeURIComponent(email), '_blank', 'noopener');
        form.reset();
      });
    }

    attachCtaForm();
    document.addEventListener('astro:page-load', attachCtaForm);
  })();
</script>