---
// src/components/home/WhatIsDockScheduling.astro
// Operational comparison and impact metrics for DataDocks.
// Voice and tone aligned with GEMINI.md: practical, direct, and operator-led.

const comparisonRows = [
  {
    dimension: "How carriers book",
    manual: "Email or call your coordinator, then wait for confirmation",
    datadocks: "Self-service portal with instant confirmation",
  },
  {
    dimension: "Arrival and departure data",
    manual: "Manual note on a clipboard or spreadsheet",
    datadocks: "Automatic timestamps, exportable for disputes",
  },
  {
    dimension: "Detention disputes",
    manual: "He-said-she-said, often conceded",
    datadocks: "Data-backed, resolved in minutes",
  },
  {
    dimension: "Schedule changes",
    manual: "Chain of emails and missed notifications",
    datadocks: "One click, driver and team auto-notified",
  },
  {
    dimension: "Visibility across the team",
    manual: "One person knows the schedule",
    datadocks: "Shared dashboard for the whole floor",
  },
  {
    dimension: "Preventing double-bookings",
    manual: "Human error, no safety net",
    datadocks: "Rules engine blocks conflicts before they happen",
  },
];

const stats = [
  { value: "40–60%", label: "Reduction in detention fees within the first quarter" },
  { value: "10–15%", label: "Throughput increase without adding doors or staff" },
  { value: "10–15", label: "Hours recovered per coordinator per week" },
];
---

<section class="py-20 md:py-28 bg-[#FFF8E9]">
  <div class="container mx-auto px-4 max-w-6xl">

    {/* Header Section */}
    <div class="mb-12">
      <h2 class="font-bruta text-3xl sm:text-4xl lg:text-5xl uppercase leading-[0.95] text-black mb-10">
        Stop Managing Your Dock<br />
        <span class="text-[#FE5000]">With Spreadsheets</span>
      </h2>
      <div class="w-16 h-1 bg-[#FF5507] mb-12"></div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-16 items-start">
        <div class="font-recoleta text-lg text-gray-800 leading-relaxed">
          <p>
            Manually managing dock appointments is a recipe for congestion. When carriers have to call or email for every slot, your team spends half their shift on the phone instead of on the floor. DataDocks replaces that chaos with a self-service carrier portal that respects your facility's capacity and business rules.
          </p>
        </div>
        <div class="font-recoleta text-lg text-gray-800 leading-relaxed">
          <p>
            This eliminates the back-and-forth, cuts detention fees, and ensures your team always knows exactly what’s hitting the dock next. By automating the schedule, you move from reactive firefighting to a controlled, predictable flow of freight from gate to door.
          </p>
        </div>
      </div>
    </div>

    {/* Comparison Table */}
    <div class="mb-20">
      {/* Mobile: stacked cards */}
      <div class="block md:hidden space-y-4">
        {comparisonRows.map((row) => (
          <div class="bg-[#EFE2D2] rounded-2xl p-5 shadow-sm">
            <div class="font-sans text-xs uppercase tracking-wider text-gray-500 mb-4 font-bold">
              {row.dimension}
            </div>
            <div class="space-y-3">
              <div class="flex gap-3 items-start">
                <span class="flex-shrink-0 inline-flex items-center justify-center w-6 h-6 rounded-full bg-white/60 text-gray-600">
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M6 18L18 6M6 6l12 12"></path>
                  </svg>
                </span>
                <div>
                  <div class="font-recoleta text-xs uppercase tracking-wide text-gray-500 mb-1 text-[10px]">Spreadsheets + Phone</div>
                  <p class="font-recoleta text-sm text-gray-700">{row.manual}</p>
                </div>
              </div>
              <div class="flex gap-3 items-start">
                <span class="flex-shrink-0 inline-flex items-center justify-center w-6 h-6 rounded-full bg-[#FE5000] text-white">
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path>
                  </svg>
                </span>
                <div>
                  <div class="font-recoleta text-xs uppercase tracking-wide text-[#FE5000] font-semibold mb-1 text-[10px]">DataDocks</div>
                  <p class="font-recoleta text-sm text-gray-900 leading-tight">{row.datadocks}</p>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>

      {/* Desktop: Tightened table */}
      <div class="hidden md:block rounded-xl overflow-hidden border border-[#EFE2D2] shadow-[0_2px_15px_rgba(0,0,0,0.03)] bg-[#EFE2D2]">
        <table class="w-full border-collapse">
          <thead>
            <tr>
              <th class="text-left py-4 px-6 font-sans text-[10px] uppercase tracking-[0.15em] text-gray-500 w-1/4 bg-[#EFE2D2]">
                &nbsp;
              </th>
              <th class="text-left py-4 px-6 font-sans text-xs uppercase tracking-wider text-gray-600 border-l border-[#FFF8E9] bg-[#EFE2D2]">
                Spreadsheets + Phone
              </th>
              <th class="text-left py-4 px-6 font-sans text-xs uppercase tracking-wider text-[#FE5000] border-l border-[#FFF8E9] bg-[#FFF0E0] relative">
                <span class="absolute top-0 left-0 w-full h-1 bg-[#FE5000]"></span>
                DataDocks
              </th>
            </tr>
          </thead>
          <tbody>
            {comparisonRows.map((row) => (
              <tr>
                <td class="py-4 px-6 font-sans text-sm uppercase tracking-wide text-black align-top leading-tight border-t border-[#FFF8E9] bg-[#EFE2D2] font-bold">
                  {row.dimension}
                </td>
                <td class="py-4 px-6 font-recoleta text-[15px] text-gray-700 leading-relaxed align-top border-t border-l border-[#FFF8E9] bg-[#EFE2D2]">
                  <span class="flex gap-3 items-start">
                    <span class="flex-shrink-0 inline-flex items-center justify-center w-5 h-5 rounded-full bg-white/60 text-gray-600 mt-1">
                      <svg class="w-2.5 h-2.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M6 18L18 6M6 6l12 12"></path>
                      </svg>
                    </span>
                    <span>{row.manual}</span>
                  </span>
                </td>
                <td class="py-4 px-6 font-recoleta text-[15px] text-gray-900 leading-relaxed align-top border-t border-l border-[#FFF8E9] bg-[#FFF0E0]">
                  <span class="flex gap-3 items-start">
                    <span class="flex-shrink-0 inline-flex items-center justify-center w-5 h-5 rounded-full bg-[#FE5000] text-white mt-1">
                      <svg class="w-2.5 h-2.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path>
                      </svg>
                    </span>
                    <span class="font-medium">{row.datadocks}</span>
                  </span>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    {/* Impact Statistics Section */}
    <div class="border-t border-[#EFE2D2] pt-16">
      <div class="mb-10 text-center md:text-left">
        <h3 class="font-recoleta text-2xl md:text-3xl font-bold text-black mb-2">
          Facilities using DataDocks typically see:
        </h3>
        <div class="w-16 h-1 bg-[#FF5507] mx-auto md:mx-0"></div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
        {stats.map((stat) => (
          <div class="group bg-[#EFE2D2] rounded-2xl p-7 shadow-sm border border-[#E4D4C0]/50 transition-all duration-300 hover:shadow-md hover:-translate-y-1 hover:border-[#FE5000]/20">
            <div class="font-bruta text-4xl lg:text-5xl text-[#5f483a] group-hover:text-[#FE5000] mb-3 font-extrabold transition-colors duration-300">{stat.value}</div>
            <p class="font-recoleta text-[1.1rem] text-black leading-snug">{stat.label}</p>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>
