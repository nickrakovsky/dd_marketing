---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.jsx';
import Hero from '../components/home/Hero.astro'; 
import Clients from '../components/home/Clients.astro';
import Benefits from '../components/home/Benefits.astro';
import FeatureGrid from '../components/home/FeatureGrid.astro';
import Testimonials from '../components/home/Testimonials.tsx';
import CTA from '../components/home/CTA.astro';
import Footer from '../components/Footer.astro';

// We are keeping this commented out to prevent the "CSS Civil War."
// If the page looks totally broken later, we can try uncommenting it.
// import '../styles/webflow-legacy.css';
---

<Layout title="Dock Scheduling Software for Warehouses | DataDocks">
  
  {/* client:idle tells Astro to "turn on" the React code 
      once the initial page load finishes so the dropdown menus work without blocking rendering.
  */}
  <Navigation client:idle />

  <main class="bg-[#FFF8E9] min-h-screen">
    
    <Hero />

    <Clients />

    <Benefits />

    <FeatureGrid />

    <Testimonials client:visible />

    <CTA />
    
  </main>

  <Footer />
  
</Layout>