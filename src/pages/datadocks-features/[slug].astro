---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.jsx';
import Footer from '../../components/Footer.astro';
import CTA from '../../components/home/CTA.astro';

export async function getStaticPaths() {
  const features = await getCollection('features');
  return features.map(feature => ({
    params: { slug: feature.slug },
    props: { feature },
  }));
}

const { feature: propFeature } = Astro.props;
const { slug } = Astro.params;

let feature = propFeature;
if (!feature) {
  const features = await getCollection('features');
  feature = (features as any[]).find(f => f.slug === slug);
}

if (!feature) {
  return Astro.redirect('/404');
}

const { Content } = await (feature as any).render();
---

<Layout title={`${feature.data.title} | DataDocks - Dock Scheduling Features`} description={feature.data.description}>
  <Navigation client:idle />
  
  <main class="bg-[#FFF8E9] min-h-screen pt-32 pb-24">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      
      {/* Header section */}
      <div class="max-w-3xl mx-auto text-center mb-16">
        <h3 class="text-brand-orange text-lg font-bold tracking-tight uppercase mb-4">DataDocks' Features</h3>
        <h1 class="text-4xl sm:text-5xl font-extrabold text-gray-900 tracking-tight font-recoleta mb-6">
          {feature.data.title}
        </h1>
        <p class="text-xl text-gray-600">
          {feature.data.description}
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
        {/* Content Section */}
        <div class="prose prose-lg prose-orange max-w-none">
          <Content />
        </div>

        {/* Video / Visual Section */}
        <div class="w-full flex justify-center sticky top-32">
          {feature.data.videoUrl ? (
            <div class="w-full aspect-video rounded-2xl overflow-hidden shadow-xl">
               <!-- Basic video embed; could be enhanced with lite-youtube-embed if the URL is extracted to ID -->
               <iframe 
                 src={feature.data.videoUrl.replace('youtu.be/', 'www.youtube.com/embed/')} 
                 class="w-full h-full border-0" 
                 allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
                 allowfullscreen
               ></iframe>
            </div>
          ) : feature.data.icon ? (
            <div class="w-64 h-64 p-12 bg-white rounded-full shadow-[0_0_50px_rgba(0,0,0,0.05)] flex items-center justify-center">
               <img src={feature.data.icon} alt={feature.data.title} class="w-full h-full object-contain" />
            </div>
          ) : null}
        </div>
      </div>

    </div>
  </main>

  <CTA />
  <Footer />
</Layout>
