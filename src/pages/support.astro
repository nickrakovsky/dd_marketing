---
export const prerender = true;

import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import CTA from '../components/home/CTA.astro';
import FAQ from '../components/FAQ.tsx';

const supportFaqs = {
  frequentlyAskedQuestionsText: "Frequently Asked Questions",
  faqs: [
    {
      question: "Do customers/carrier accounts count towards User Accounts?",
      answer: "No. You get unlimited customer/carrier/vendor accounts. Only internal team members who manage schedules and settings count as user accounts."
    },
    {
      question: "Can my customers/carriers see all my appointments?",
      answer: "No. Each carrier or customer can only see appointments tied to their own account. Your internal schedule, other carriers' bookings, and facility-wide data remain private."
    },
    {
      question: "I have many different locations. Can DataDocks handle that?",
      answer: "Yes. DataDocks was designed to scale horizontally across multiple locations. Each facility gets its own dashboard, capacity rules, and reporting while you maintain a unified view across all sites."
    },
    {
      question: "Can I run DataDocks as a standalone product?",
      answer: "Absolutely. DataDocks works great as a standalone product with no other systems required. Many facilities start with DataDocks on its own and add integrations later as their needs grow."
    },
    {
      question: "Can I integrate DataDocks with our current systems?",
      answer: "Yes. DataDocks integrates with many systems and provides a robust REST API. Contact us to seamlessly integrate your flow."
    },
    {
      question: "Can we cancel at any time?",
      answer: "Yes. There's no minimum contract for DataDocks. You can cancel at any time without penalties or long-term commitments."
    }
  ]
};
---

<Layout title="Frequently Asked Questions & Support | DataDocks" description="Get answers to common questions about DataDocks dock scheduling software — pricing, integrations, multi-location support, carrier accounts, and cancellation policy." schemaData={{ faq: supportFaqs.faqs }}>
  <Navigation />

  <main class="bg-[#FFF8E9] min-h-screen pt-32 font-sans text-black">
    
    <!-- Hero & FAQ Section -->
    <section class="max-w-7xl mx-auto px-6 lg:px-8 pb-16 md:pb-24">
      <div class="mb-12 md:mb-16">
        <h1 class="font-bruta text-[2.5rem] md:text-[3rem] leading-[0.9] uppercase flex flex-col items-start tracking-tight font-extrabold">
          <span class="text-[#FF5507]">FAQ</span>
          <span>& Support</span>
        </h1>
        <p class="mt-6 md:mt-8 font-recoleta text-base md:text-lg italic text-black/60 max-w-2xl">
          Got a question you need answered?<br />Check below for the answers to our most common questions.
        </p>
      </div>

      <div class="space-y-12">
        {/* Reuse React FAQ Component */}
        <FAQ content={supportFaqs} noHeader={true} noBackground={true} client:visible />
      </div>
    </section>

    <!-- Contact Form Section (Horizontal & Compact) -->
    <section class="bg-[#EFE2D2] py-12 md:py-24 px-6 lg:px-8">
      <div class="max-w-7xl mx-auto flex flex-col md:flex-row gap-12 md:gap-24 items-center">
        
        <div class="md:w-[40%] space-y-6">
          <h2 class="font-recoleta text-3xl md:text-5xl font-semibold leading-[1.1]">
            Don't see your question here? We'd be happy to answer it.
          </h2>
          <div class="flex flex-col gap-1 md:gap-2">
            <a href="mailto:info@datadocks.com" class="text-xl md:text-2xl text-[#FF5507] font-medium hover:opacity-80 transition-all">info@datadocks.com</a>
            <div class="text-xl md:text-2xl font-medium">(647) 848-8250</div>
          </div>
        </div>

        <form id="wf-form-Support-Form" name="wf-form-Support-Form" class="md:w-[60%] space-y-4 w-full">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 md:gap-4">
            <input 
              class="w-full px-5 py-3 md:py-4 bg-[#FFF8E9] rounded-sm border-none focus:ring-1 focus:ring-[#FF5507] outline-none transition-all font-sans text-black/70 placeholder:text-black/40 text-base md:text-lg" 
              name="name" 
              placeholder="Name" 
              type="text" 
              id="name"
              required
            >
            <input 
              class="w-full px-5 py-3 md:py-4 bg-[#FFF8E9] rounded-sm border-none focus:ring-1 focus:ring-[#FF5507] outline-none transition-all font-sans text-black/70 placeholder:text-black/40 text-base md:text-lg" 
              name="Email" 
              placeholder="Enter Your Email" 
              type="email" 
              id="email"
              required
            >
          </div>
          <div class="relative">
            <textarea 
              placeholder="Message" 
              id="Support-Message" 
              name="Support-Message" 
              required
              class="w-full h-32 md:h-40 px-5 py-3 md:py-4 bg-[#FFF8E9] rounded-sm border-none focus:ring-1 focus:ring-[#FF5507] outline-none transition-all resize-none font-sans text-black/70 placeholder:text-black/40 text-base md:text-lg"
            ></textarea>
            <button 
              type="submit" 
              class="absolute bottom-3 right-3 bg-[#FF5507] text-white font-recoleta text-base md:text-lg px-6 md:px-8 py-2 md:py-2.5 hover:bg-black transition-all"
            >
              Send
            </button>
          </div>
        </form>
      </div>
    </section>

    <!-- Sitewide CTA -->
    <CTA />
  </main>
  
  <Footer />
</Layout>

