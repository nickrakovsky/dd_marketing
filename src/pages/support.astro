---
export const prerender = true;

import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import CTA from '../components/home/CTA.astro';
import FAQ from '../components/FAQ.tsx';

const supportFaqs = {
  frequentlyAskedQuestionsText: "Frequently Asked Questions",
  faqs: [
    {
      question: "Do customers/carrier accounts count towards User Accounts?",
      answer: "No. You get unlimited customer/carrier/vendor accounts."
    },
    {
      question: "Can my customers/carriers see all my appointments?",
      answer: "No. The only appointments they can see are the appointments tied to their account."
    },
    {
      question: "I have many different locations. Can DataDocks handle that?",
      answer: "Yes. DataDocks was designed to scale horizontally across multiple locations."
    },
    {
      question: "Can I run DataDocks as a standalone product?",
      answer: "Perfect! DataDocks works great this way."
    },
    {
      question: "Can I integrate DataDocks with our current systems?",
      answer: "Yes. DataDocks integrates with many systems and provides a robust REST API. Contact us to seamlessly integrate your flow."
    },
    {
      question: "Can we cancel at any time?",
      answer: "Yes. There's no minimum contract for DataDocks."
    }
  ]
};
---

<Layout title="Frequently Asked Questions & Support | DataDocks" description="Find quick answers and get expert help tailored to help you get the most out of DataDocks." schemaData={{ faq: supportFaqs.faqs }}>
  <Navigation />

  <main class="bg-[#FFF8E9] min-h-screen pt-32 pb-24">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 mb-16">
      <div class="text-center">
        <h1 class="text-5xl font-black text-gray-900 tracking-tight font-recoleta mb-6">
          <span class="text-[#FF6A13]">Got a question you need answered?</span>
          <br />
          Check below for the answers to our most common questions.
        </h1>
      </div>
    </div>

    {/* Reuse React FAQ Component */}
    <FAQ content={supportFaqs} client:visible />

    <div class="max-w-4xl mx-auto px-6 lg:px-8 mt-20 bg-white rounded-3xl p-12 shadow-sm text-center">
      <h2 class="text-2xl font-bold font-recoleta text-gray-900 mb-8">
        Don't see your question here? We'd be happy to answer them.
      </h2>
      <div class="flex flex-col sm:flex-row justify-center gap-6 sm:gap-12 items-center">
        <a href="mailto:info@datadocks.com" class="text-lg font-semibold text-[#FF6A13] hover:underline">
          info@datadocks.com
        </a>
        <a href="tel:6478488250" class="text-lg font-semibold text-[#FF6A13] hover:underline">
          (647) 848-8250
        </a>
      </div>
    </div>
  </main>
  
  <CTA />
  <Footer />
</Layout>
