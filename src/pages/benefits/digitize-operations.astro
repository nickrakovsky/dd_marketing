---
export const prerender = true;

import Layout from '../../layouts/Layout.astro';
import PageLayout from '../../components/benefits/PageLayout.astro'; 
import { defaultContent } from '../../data/pagesData';

// FIXED: Define the schemaData variable
const schemaData = {
  faq: defaultContent.faq?.faqs,
  reviews: defaultContent.testimonial ? [{
    author: defaultContent.testimonial.name,
    quote: defaultContent.testimonial.quote,
    role: defaultContent.testimonial.role,
    source: defaultContent.testimonial.source,
    url: defaultContent.testimonial.sourceUrl
  }] : []
};
---

<Layout 
  title="Digitize Dock Operations for Better Supply Chain Flow"
  description="Replace spreadsheets with a digital audit trail for every dock appointment. Sync scheduling data to your WMS and TMS automatically for full visibility."
  schemaData={schemaData} 
>
  <PageLayout content={defaultContent} isOrangeNav={true} />
</Layout>