---
export const prerender = true;

import Layout from '../../layouts/Layout.astro';
import PageLayout from '../../components/benefits/PageLayout.astro'; 
import { carriersContent } from '../../data/pagesData';

// FIXED: Define the schemaData variable
const schemaData = {
  faq: carriersContent.faq?.faqs,
  reviews: carriersContent.testimonial ? [{
    author: carriersContent.testimonial.name,
    quote: carriersContent.testimonial.quote,
    role: carriersContent.testimonial.role,
    source: carriersContent.testimonial.source,
    url: carriersContent.testimonial.sourceUrl
  }] : []
};
---

<Layout 
  title="Carrier Scheduling Portal for Self-Service Booking"
  description="Stop the endless emails and phone calls. Give your carriers a self-service scheduling portal to book their own dock appointments 24/7."
  schemaData={schemaData} 
>
  <PageLayout content={carriersContent} isOrangeNav={true} />
</Layout>