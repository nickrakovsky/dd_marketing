    <script is:inline>
      (() => {
        const initLeadForm = () => {
          const leadForm = document.getElementById('lead-form');
          if (!leadForm) return;

          leadForm.addEventListener('submit', async function (e) {
            e.preventDefault();

            const data = Object.fromEntries(new FormData(this));
            const payload = new FormData();

            payload.append('email', data.email);
            payload.append('fields_first_name', data.first_name);
            payload.append('fields_last_name', data.last_name);
            payload.append('fields_company', data.company);

            if (data.phone) payload.append('fields_phone', data.phone);
            if (data.locations) payload.append('fields_numberOfLocations', data.locations);
            if (data.appointments) payload.append('fields_monthlyAppointments', data.appointments);

            payload.append('tags', 'FreeTrial');

            try {
              await fetch(
                'https://track.bentonow.com/forms/b4cb9a34a989bcc643714151df7b7154/%24subscribe?hardened=true',
                {
                  method: 'POST',
                  body: payload,
                }
              );
            } catch (err) {
              console.log('Bento submission error:', err);
            }

            this.style.display = 'none';
            const success = document.getElementById('success');
            if (success) success.style.display = 'flex';
          });
        };

        const initAnalyticsGallery = () => {
          const chartGrid = document.getElementById('chartGrid');
          const chartExpanded = document.getElementById('chartExpanded');
          const chartExpandedImg = document.getElementById('chartExpandedImg');
          const chartExpandedLabel = document.getElementById('chartExpandedLabel');
          const chartClose = document.getElementById('chartClose');

          if (!chartGrid || !chartExpanded || !chartExpandedImg || !chartExpandedLabel || !chartClose) {
            return;
          }

          chartGrid.addEventListener('click', (event) => {
            const target = event.target;
            if (!(target instanceof Element)) return;

            const tile = target.closest('.chart-tile');
            if (!(tile instanceof HTMLElement)) return;

            const img = tile.dataset.img || '';
            const label = tile.dataset.label || '';

            chartExpandedImg.setAttribute('src', img);
            chartExpandedImg.setAttribute('alt', label);
            chartExpandedLabel.textContent = label;

            chartGrid.style.display = 'none';
            chartExpanded.classList.add('visible');
          });

          chartClose.addEventListener('click', () => {
            chartExpanded.classList.remove('visible');
            chartGrid.style.display = 'grid';
          });
        };

        const initMarquee = ({ trackId, sets, duration, cssVar, animName }) => {
          const track = document.getElementById(trackId);
          if (!track) return;

          const items = track.children;
          const perSet = Math.round(items.length / sets);
          let w = 0;

          for (let i = 0; i < perSet; i++) {
            w += items[i].getBoundingClientRect().width;
            const gap = parseFloat(getComputedStyle(track).gap) || 0;
            if (i < perSet - 1) w += gap;
          }

          track.style.setProperty(cssVar, `-${w}px`);
          track.style.animation = `${animName} ${duration}s linear infinite`;
        };

        const init = () => {
          initLeadForm();
          initAnalyticsGallery();
          initMarquee({
            trackId: 'ratingsTrack',
            sets: 3,
            duration: 32,
            cssVar: '--ratings-shift',
            animName: 'ratings-scroll',
          });
          initMarquee({
            trackId: 'integTrack',
            sets: 2,
            duration: 20,
            cssVar: '--integ-shift',
            animName: 'integ-scroll',
          });
        };

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', init, { once: true });
        } else {
          init();
        }
      })();
    </script>
  </body>
