---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

// Fetch and sort posts chronologically
const allPosts = await getCollection('posts');
const sortedPosts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Split posts: The newest post is the Hero, the rest go into the Bento Grid
const highlightedPost = sortedPosts[0];
const restPosts = sortedPosts.slice(1);

// Group the rest of the posts by category
const postsByCategory = restPosts.reduce((acc, post) => {
  const category = post.data.category || 'Logistics';
  if (!acc[category]) {
    acc[category] = [];
  }
  acc[category].push(post);
  return acc;
}, {} as Record<string, typeof restPosts>);

// Fallback background styles
const fallbackGradients = [
  "bg-gradient-to-br from-[#fd4f00] to-[#E5D3B3]",
  "bg-gradient-to-tl from-black via-[#fd4f00] to-black",
  "bg-gradient-to-tr from-[#E5D3B3] to-[#F8EDD9]",
  "bg-gradient-to-bl from-[#fd4f00] to-black",
  "bg-gradient-to-br from-gray-900 to-[#fd4f00]"
];

// Image Globbing for fallback Extraction
const allBlogImages = import.meta.glob<{ default: ImageMetadata }>('/src/assets/blog-images/*.{jpeg,jpg,png,gif,webp}', { eager: true });

const getFirstImage = (body: string) => {
  if (!body) return null;
  const match = body.match(/!\[.*?\]\((.*?)\)/);
  if (match) {
    const filename = match[1].split('/').pop();
    if (filename && allBlogImages[`/src/assets/blog-images/${filename}`]) {
      return allBlogImages[`/src/assets/blog-images/${filename}`].default;
    }
  }
  return null;
};

// Math-based Reading Time Map
const getReadTime = (body: string) => {
  if (!body) return '1 min read';
  const plainText = body.replace(/[^\w\s]/g, '').trim();
  const wordCount = plainText ? plainText.split(/\s+/).length : 0;
  const minReadingTime = Math.max(1, Math.floor(wordCount / 250));
  const maxReadingTime = Math.max(1, Math.ceil(wordCount / 180));
  return minReadingTime === maxReadingTime 
    ? `${minReadingTime} min read` 
    : `${minReadingTime}-${maxReadingTime} min read`;
};

// Category Object Themes
const categoryThemes: Record<string, { bg: string, accent: string, neutral: string, border: string, hoverBorder: string }> = {
  "Facility Operations": { bg: "bg-[#F8EDD9]", accent: "bg-[#fd4f00] text-white", neutral: "text-black", border: "border-black/10", hoverBorder: "hover:border-[#fd4f00]" },
  "Carrier Management": { bg: "bg-[#FFF8E9]", accent: "bg-[#E5D3B3] text-black", neutral: "text-black", border: "border-black/10", hoverBorder: "hover:border-[#E5D3B3]" },
  "Supply Chain Strategy": { bg: "bg-[#fd4f00]", accent: "bg-[#FFF8E9] text-black", neutral: "text-white", border: "border-white/20", hoverBorder: "hover:border-white" },
  "Systems Integration": { bg: "bg-black", accent: "bg-[#F8EDD9] text-black", neutral: "text-white", border: "border-white/20", hoverBorder: "hover:border-white" },
};
const getCategoryTheme = (cat: string) => categoryThemes[cat] || { bg: "bg-gray-100", accent: "bg-[#fd4f00] text-white", neutral: "text-black", border: "border-black/20", hoverBorder: "hover:border-black/50" };

// Category Order
const categoryOrder = ["Facility Operations", "Carrier Management", "Supply Chain Strategy", "Systems Integration"];

// Page metadata
const title = "Shipping & Receiving Best Practice Research | DataDocks";
const description = "DataDocks is a dock appointment scheduling software, that helps increase your facility's performance.";
---

<Layout title={title} description={description}>
  {/* Lite YouTube Embed */}
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/lite-youtube-embed/0.3.3/lite-yt-embed.css" />
  <script src="https://cdnjs.cloudflare.com/ajax/libs/lite-youtube-embed/0.3.3/lite-yt-embed.js" defer></script>

  <div class="min-h-screen flex flex-col">
    
    <Navigation client:idle />

    <main class="flex-grow w-full bg-[#FFF8E9] font-recoleta text-gray-800 pt-24">
      <div class="max-w-7xl mx-auto px-4 md:px-12">
        
        <div class="text-center mb-16 md:mb-24">
          <h1 class="text-4xl md:text-6xl lg:text-[76px] font-bruta uppercase leading-[0.85] tracking-tight w-full">
            <span class="text-[#fd4f00]">RESOURCE HUB:</span><br/>
            <span class="text-black">Guides, Checklists & Insights<br class="hidden sm:block" /> for Operations Teams</span>
          </h1>
        </div>

        {/* Category Icon Hotlinks */}
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-8 mb-20 max-w-4xl mx-auto px-4">
          {categoryOrder.map((category, idx) => (
            <a href={`#category-${idx}`} class="flex flex-col items-center group">
              <div class="w-16 h-16 md:w-24 md:h-24 bg-white rounded-2xl shadow-md border-2 border-[#E5D3B3] flex items-center justify-center mb-4 group-hover:-translate-y-2 group-hover:border-[#fd4f00] group-hover:shadow-lg transition-all duration-300">
                <svg class="w-8 h-8 md:w-10 md:h-10 text-black group-hover:text-[#fd4f00] transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 002-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
                </svg>
              </div>
              <span class="font-bruta uppercase text-sm md:text-base text-center text-gray-800 group-hover:text-[#fd4f00] transition-colors leading-tight">{category}</span>
            </a>
          ))}
        </div>
      </div>

      {/* Category Sections (Scrollable Carousels) */}

      {categoryOrder.map((category, idx) => {
        const posts = postsByCategory[category] || [];
        if (posts.length === 0) return null;
        const theme = getCategoryTheme(category);
        return (
          <section id={`category-${idx}`} class={`w-full ${theme.bg} py-16 md:py-24 border-t-2 border-black/5`}>
            <div class="max-w-7xl mx-auto px-4 md:px-12">
              <div class="flex items-center justify-between mb-12">
                <h3 class={`font-bruta text-3xl md:text-5xl uppercase tracking-tiight ${theme.neutral}`}>{category}</h3>
              </div>
              
              {/* Scrollable Carousel Grid */}
              <div class="grid grid-flow-col grid-rows-2 auto-cols-[85vw] sm:auto-cols-[300px] lg:auto-cols-[calc((100%-4.5rem)/4)] gap-6 overflow-x-auto pb-8 snap-x snap-mandatory scrollbar-hide" style="-ms-overflow-style: none; scrollbar-width: none;">
                
                {posts.map((post, postIdx) => {
                  const type = post.data.contentType || 'article';
                  const isFeatured = postIdx === 0;
                  
                  // Aspect Ratios & Grid Spans
                  let spanClass = "row-span-1 col-span-1 aspect-[4/5]";
                  if (isFeatured) {
                    spanClass = "row-span-2 col-span-2 aspect-[4/5] hidden sm:flex"; 
                  } else if (type === 'video') {
                    spanClass = "row-span-1 col-span-2 h-full";
                  } else if (type === 'short') {
                    spanClass = "row-span-2 col-span-1 aspect-[9/16] my-auto";
                  }

                  const fallbackImg = getFirstImage(post.body || '');
                  const finalReadTime = post.data.readTime || getReadTime(post.body || '');

                  // Pure Video Card Rendering
                  if (!isFeatured && (type === 'video' || type === 'short') && post.data.youtubeId) {
                    return (
                      <a 
                        href={`${import.meta.env.BASE_URL}/posts/${post.slug}?autoplay=1`.replace('//posts', '/posts')} 
                        class={`group snap-start relative flex flex-col justify-center ${type === 'short' ? '' : 'p-3 md:p-4'} rounded-2xl overflow-hidden shadow-sm transition-all duration-300 hover:shadow-xl border-2 ${theme.border} ${theme.hoverBorder} ${spanClass}`}
                        data-priority={post.data.priority}
                      >
                        <lite-youtube 
                           videoid={post.data.youtubeId} 
                           playlabel={post.data.title} 
                           style={`background-image: url('https://i.ytimg.com/vi/${post.data.youtubeId}/hqdefault.jpg'); background-size: cover; background-position: center;`}
                           class={`w-full rounded-lg shadow-md pointer-events-none ${type === 'short' ? 'h-full w-full !rounded-none !shadow-none' : 'aspect-video'}`} 
                        />
                        
                        {/* Title Overlay Visible by Default - Hides on Hover */}
                        <div class="absolute inset-3 md:inset-4 bg-black/85 flex flex-col items-center justify-center opacity-100 group-hover:opacity-0 transition-opacity z-10 rounded-lg p-4">
                           <span class="bg-[#fd4f00] text-white text-[10px] font-bold px-2 py-0.5 rounded-full uppercase tracking-wider mb-3">Watch {type}</span>
                           <h4 class="text-white text-center text-sm md:text-base font-bruta uppercase leading-[1.15] line-clamp-4">{post.data.title}</h4>
                        </div>
                      </a>
                    );
                  }

                  // Non-Video and Featured Card Rendering
                  return (
                    <a 
                      href={`${import.meta.env.BASE_URL}/posts/${post.slug}`.replace('//posts', '/posts')} 
                      class={`group snap-start relative flex flex-col rounded-2xl overflow-hidden shadow-sm transition-all duration-300 hover:shadow-xl ${spanClass} ${isFeatured ? 'bg-white border-0' : `bg-transparent border-2 ${theme.border} ${theme.hoverBorder}`}`}
                      data-priority={post.data.priority}
                    >
                      {isFeatured ? (
                        <>
                          <div class="w-full aspect-video bg-[#F8EDD9] relative overflow-hidden shrink-0">
                            {post.data.youtubeId ? (
                              <img src={`https://img.youtube.com/vi/${post.data.youtubeId}/maxresdefault.jpg`} alt={post.data.title} class="w-full h-full object-cover" />
                            ) : post.data.cardImage ? (
                              <Image src={post.data.cardImage} alt={post.data.title} class="w-full h-full object-cover" />
                            ) : fallbackImg ? (
                              <Image src={fallbackImg} alt={post.data.title} class="w-full h-full object-cover" />
                            ) : (
                              <div class={`w-full h-full opacity-80 ${fallbackGradients[post.slug.length % fallbackGradients.length]}`}></div>
                            )}
                            {/* Badges */}
                            {type === 'video' && <span class="absolute top-4 left-4 bg-[#fd4f00] text-white text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wider flex items-center gap-1 shadow-md z-10"><svg class="w-3 h-3 fill-current" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg> Video</span>}
                            {type === 'short' && <span class="absolute top-4 left-4 bg-black text-white text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wider flex items-center gap-1 shadow-md z-10"><svg class="w-3 h-3 fill-current" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg> Short</span>}
                          </div>
                          <div class={`w-full flex-grow p-6 md:p-8 flex flex-col justify-between min-h-[33.33%] ${theme.accent}`}>
                            <div>
                               <h4 class={`text-2xl md:text-4xl font-bold font-bruta uppercase mb-4 leading-[1.1] opacity-90 transition-opacity group-hover:opacity-100 line-clamp-3`}>{post.data.title}</h4>
                               <div class="w-12 h-[3px] bg-current opacity-30 mb-4"></div>
                               <p class="text-base md:text-lg opacity-80 line-clamp-2 md:line-clamp-3 mb-4">{post.data.description || 'Click here to read the full article.'}</p>
                            </div>
                            <div class="flex flex-col gap-3 md:gap-4 mt-auto">
                               <span class={`font-bold flex items-center gap-2 opacity-90 text-lg md:text-xl`}>Read More <span class="text-2xl leading-none transition-transform group-hover:translate-x-1">&#8594;</span></span>
                               <div class="w-full h-px bg-current opacity-20"></div>
                               <div class="flex items-center justify-between">
                                 <span class="text-[10px] md:text-xs opacity-70 font-bold uppercase tracking-wider">{finalReadTime}</span>
                                 <span class="text-[10px] md:text-xs opacity-70 font-bold uppercase tracking-wider">{post.data.updatedDate ? new Date(post.data.updatedDate).toLocaleDateString() : (post.data.pubDate ? new Date(post.data.pubDate).toLocaleDateString() : '')}</span>
                               </div>
                            </div>
                          </div>
                        </>
                      ) : (
                        <div class={`w-full h-full p-4 md:p-5 flex flex-col justify-between transition-colors ${theme.neutral}`}>
                           <div class="mb-3">
                             <h4 class={`text-lg md:text-xl font-bold font-bruta uppercase leading-[1.15] mb-3 line-clamp-3 ${theme.neutral}`}>{post.data.title}</h4>
                           </div>
                           <div class="mb-3 flex-grow flex flex-col justify-center">
                             <p class={`text-xs md:text-sm opacity-80 line-clamp-3 mb-3 ${theme.neutral}`}>{post.data.description || 'Click here to read the full article.'}</p>
                             <span class={`font-bold flex items-center gap-1 opacity-90 group-hover:opacity-100 mt-auto text-sm ${theme.neutral}`}>Read <span class="text-base leading-none transition-transform group-hover:translate-x-1">&#8594;</span></span>
                           </div>
                           <div class={`pt-3 border-t flex items-center justify-between text-[10px] font-bold uppercase tracking-wider ${theme.border.replace('border-', 'border-')} border-opacity-30 ${theme.neutral}`}>
                              <span class="opacity-70">{finalReadTime.replace(/ read$/i, '')}</span>
                              <span class="opacity-70">{post.data.updatedDate ? new Date(post.data.updatedDate).toLocaleDateString() : (post.data.pubDate ? new Date(post.data.pubDate).toLocaleDateString() : '')}</span>
                           </div>
                        </div>
                      )}
                    </a>
                  );
                })}
              </div>
            </div>
          </section>
        );
      })}

    </main>

    <Footer />
    
  </div>
</Layout>