---
import { getCollection } from 'astro:content';
import BlogPostLayout from '../../layouts/BlogPostLayout.astro';
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation';
import Footer from '../../components/Footer.astro';
import { getFriendlyDate } from '../../utils/dateFormatter';

export async function getStaticPaths() {
  const postEntries = await getCollection('posts');
  return postEntries.map(entry => ({
    params: { slug: entry.slug }, 
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const type = entry.data.contentType || 'article';
const isVideo = type === 'video' || type === 'short';

const formattedDate = new Date(entry.data.pubDate).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});

const allPosts = await getCollection('posts');
const categoryPosts = allPosts
  .filter(p => p.slug !== entry.slug && p.data.category === entry.data.category)
  .sort((a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf());

let relatedPosts = categoryPosts.slice(0, 3);
if (relatedPosts.length < 3) {
  const otherPosts = allPosts
    .filter(p => p.slug !== entry.slug && !relatedPosts.some(rp => rp.slug === p.slug))
    .sort((a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf())
    .slice(0, 3 - relatedPosts.length);
  relatedPosts = [...relatedPosts, ...otherPosts];
}

const getReadTime = (body: string) => {
  if (!body) return '1 min read';
  const plainText = body.replace(/[^\w\s]/g, '').trim();
  const wordCount = plainText ? plainText.split(/\s+/).length : 0;
  const minReadingTime = Math.max(1, Math.floor(wordCount / 250));
  const maxReadingTime = Math.max(1, Math.ceil(wordCount / 180));
  return minReadingTime === maxReadingTime 
    ? `${minReadingTime} min read` 
    : `${minReadingTime}-${maxReadingTime} min read`;
};
---

{isVideo ? (
  <Layout title={entry.data.title} description={entry.data.description}>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/lite-youtube-embed/0.3.3/lite-yt-embed.css" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/lite-youtube-embed/0.3.3/lite-yt-embed.js" defer></script>
    <Navigation client:idle />
    
    <main class="bg-[#0f0f0f] min-h-screen text-white pt-28 pb-20 font-recoleta">
      <div class="max-w-7xl mx-auto px-4 md:px-8 flex flex-col lg:flex-row gap-8">
        
        <div class="flex-grow w-full max-w-4xl">
          
          <div class={`w-full rounded-2xl overflow-hidden shadow-2xl bg-black border border-gray-800 ${type === 'short' ? 'max-w-sm mx-auto aspect-[9/16]' : 'aspect-video'}`}>
            <iframe
              src={`https://www.youtube.com/embed/${entry.data.youtubeId}?autoplay=0&rel=0`}
              title={entry.data.title}
              class="w-full h-full border-0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
            ></iframe>
          </div>

          <div class="mt-6">
            <h1 class="text-2xl md:text-3xl lg:text-4xl font-bruta uppercase leading-tight mb-4 text-white">
              {entry.data.title}
            </h1>
            
            <div class="flex flex-wrap items-center gap-4 text-gray-400 text-sm mb-6 pb-6 border-b border-gray-800">
              <span class="font-bold text-white bg-gray-800 px-4 py-1.5 rounded-full flex items-center gap-2">
                <svg class="w-4 h-4 text-[#fd4f00]" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 14.5v-9l6 4.5-6 4.5z"/></svg>
                {entry.data.author || 'DataDocks'}
              </span>
              <span>Published on {formattedDate}</span>
            </div>

            <div class="bg-gray-900 rounded-xl p-6 text-gray-300 leading-relaxed">
              <Content />
            </div>
          </div>
        </div>

        <div class="w-full lg:w-96 flex-shrink-0 flex flex-col gap-6" style="margin-top: 0;">
          <h3 class="text-xl font-bruta uppercase mb-2 text-white">More Resources</h3>
          
          {relatedPosts.map(post => {
            const postType = post.data.contentType || 'article';
            const finalReadTime = post.data.readTime || getReadTime(post.body || '');
            
            if ((postType === 'video' || postType === 'short') && post.data.youtubeId) {
              const isShort = postType === 'short';
              return (
                <a 
                  href={`${import.meta.env.BASE_URL}/posts/${post.slug}?autoplay=1`.replace('//posts', '/posts')} 
                  class="group relative flex flex-col rounded-2xl overflow-hidden shadow-sm transition-all duration-300 hover:shadow-xl border-2 border-white/20 hover:border-white w-full"
                >
                  {isShort ? (
                    <>
                      <div class="relative w-full aspect-[9/16] overflow-hidden shrink-0">
                        <lite-youtube 
                          videoid={post.data.youtubeId} 
                          playlabel={post.data.title} 
                          style={`background-image: url('https://i.ytimg.com/vi/${post.data.youtubeId}/hqdefault.jpg'); background-size: cover; background-position: center;`}
                          class="w-full h-full pointer-events-none" 
                        ></lite-youtube>
                        <div class="absolute inset-0 bg-black/80 flex flex-col items-center justify-center opacity-100 group-hover:opacity-0 transition-opacity z-10 p-4">
                          <span class="bg-[#fd4f00] text-white text-[10px] font-bold px-2 py-0.5 rounded-full uppercase tracking-wider mb-3">Watch Short</span>
                        </div>
                      </div>
                      <div class="flex-grow flex flex-col justify-center px-4 py-3 text-white border-t border-white/20 bg-black/5">
                        <h4 class="text-sm md:text-base font-bold font-bruta uppercase leading-tight line-clamp-3 text-white">{post.data.title}</h4>
                      </div>
                    </>
                  ) : (
                    <>
                      <lite-youtube 
                        videoid={post.data.youtubeId} 
                        playlabel={post.data.title} 
                        style={`background-image: url('https://i.ytimg.com/vi/${post.data.youtubeId}/hqdefault.jpg'); background-size: cover; background-position: center;`}
                        class="w-full aspect-video pointer-events-none" 
                      ></lite-youtube>
                      <div class="absolute inset-0 bg-black/85 flex flex-col items-center justify-center opacity-100 group-hover:opacity-0 transition-opacity z-10 p-4">
                        <span class="bg-[#fd4f00] text-white text-[10px] font-bold px-2 py-0.5 rounded-full uppercase tracking-wider mb-3">Watch Video</span>
                        <h4 class="text-white text-center text-sm md:text-base font-bruta uppercase leading-[1.15] line-clamp-4">{post.data.title}</h4>
                      </div>
                    </>
                  )}
                </a>
              );
            }

            return (
              <a 
                href={`${import.meta.env.BASE_URL}/posts/${post.slug}`.replace('//posts', '/posts')} 
                class="group relative flex flex-col rounded-2xl overflow-hidden shadow-sm transition-all duration-300 hover:shadow-xl bg-transparent border-2 border-white/20 hover:border-white w-full aspect-[4/5]"
              >
                <div class="w-full h-full p-4 md:p-5 flex flex-col justify-between transition-colors text-white">
                   <div class="mb-3">
                     <h4 class="text-lg md:text-xl font-bold font-bruta uppercase leading-[1.15] mb-3 line-clamp-3 text-white">{post.data.title}</h4>
                   </div>
                   <div class="mb-3 flex-grow flex flex-col justify-center">
                     <p class="text-xs md:text-sm opacity-80 line-clamp-4 mb-3 text-white">{post.data.description || 'Click here to read the full article.'}</p>
                     <span class="font-bold flex items-center gap-1 opacity-90 group-hover:opacity-100 mt-auto text-sm text-white">Read <span class="text-base leading-none transition-transform group-hover:translate-x-1">&#8594;</span></span>
                   </div>
                   <div class="pt-3 border-t flex items-center justify-between text-[10px] font-bold uppercase tracking-wider border-white/20 border-opacity-30 text-white">
                      <span class="opacity-70">{finalReadTime.replace(/ read$/i, '')}</span>
                      <span class="opacity-70">{getFriendlyDate(post.data.updatedDate || post.data.pubDate)}</span>
                   </div>
                </div>
              </a>
            );
          })}
        </div>
        
      </div>
    </main>

    <Footer />
  </Layout>
) : (
  <BlogPostLayout frontmatter={entry.data}>
    <Content />
  </BlogPostLayout>
)}