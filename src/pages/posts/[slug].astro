---
import { getCollection, getEntry } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BlogPostLayout from '../../layouts/BlogPostLayout.astro';
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';
// getFriendlyDate is unused
// import { getFriendlyDate } from '../../utils/dateFormatter';

export const prerender = true;

export async function getStaticPaths() {
  const postEntries = await getCollection('posts');
  return postEntries.map((entry: CollectionEntry<'posts'>) => ({
    params: { slug: entry.slug }, 
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<'posts'>;
}

const { slug } = Astro.params;
const entry: CollectionEntry<'posts'> = (Astro.props as Props).entry || await getEntry('posts', slug as string);

if (!entry) {
  // Fallback for types or edge cases
  return Astro.redirect('/404');
}
const { Content, headings } = await entry.render();

const postType = entry.data.postType?.discriminant || 'article';
const isVideo = postType === 'video' || postType === 'short';

const formattedDate = new Date(entry.data.pubDate).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});

const posts = await getCollection('posts');
const videos = await getCollection('videos');
const allPosts = [...posts, ...videos];

const categoryPosts = allPosts
  .filter((p: any) => p.slug !== entry.slug && p.data.category === entry.data.category)
  .sort((a: any, b: any) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf());

let relatedPosts = categoryPosts.slice(0, 3);
if (relatedPosts.length < 3) {
  const otherPosts = allPosts
    .filter((p: any) => p.slug !== entry.slug && !relatedPosts.some((rp: any) => rp.slug === p.slug))
    .sort((a: any, b: any) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf())
    .slice(0, 3 - relatedPosts.length);
  relatedPosts = [...relatedPosts, ...otherPosts];
}

const getReadTime = (body: string) => {
  if (!body) return '1 min read';
  const plainText = body.replace(/[^\w\s]/g, '').trim();
  const wordCount = plainText ? plainText.split(/\s+/).length : 0;
  const minReadingTime = Math.max(1, Math.floor(wordCount / 250));
  const maxReadingTime = Math.max(1, Math.ceil(wordCount / 180));
  return minReadingTime === maxReadingTime 
    ? `${minReadingTime} min read` 
    : `${minReadingTime}-${maxReadingTime} min read`;
};
---

{isVideo ? (
  <Layout
    title={entry.data.title}
    description={entry.data.description}
    image={(entry.data.postType?.value && 'youtubeId' in entry.data.postType.value && entry.data.postType.value.youtubeId) ? `https://img.youtube.com/vi/${entry.data.postType.value.youtubeId}/maxresdefault.jpg` : undefined}
    type="video"
    videoData={(entry.data.postType?.value && 'youtubeId' in entry.data.postType.value && entry.data.postType.value.youtubeId) ? {
      youtubeId: entry.data.postType.value.youtubeId,
      uploadDate: entry.data.pubDate,
      duration: 'duration' in entry.data.postType.value ? entry.data.postType.value.duration : undefined
    } : undefined}
  >
    <link rel="stylesheet" href="/css/lite-yt-embed.css" media="print" onload="this.media='all'" />
    <script is:inline src="/css/lite-yt-embed.js" defer></script>
    <a href="#video-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 bg-[#fd4f00] text-white px-4 py-2 rounded-lg z-[100] font-bold">Skip to content</a>
    <Navigation />
    
    <main class="bg-[#0f0f0f] min-h-screen text-white pt-28 pb-20 font-recoleta">
      <div class="max-w-7xl mx-auto px-4 md:px-8 flex flex-col lg:flex-row gap-8">
        
        <div id="video-content" class="flex-grow w-full max-w-4xl">
          
          <div class={`w-full rounded-2xl overflow-hidden shadow-2xl bg-black border border-gray-800 ${postType === 'short' ? 'max-w-sm mx-auto aspect-[9/16]' : 'aspect-video'}`}>
            {entry.data.postType?.value && 'youtubeId' in entry.data.postType.value && entry.data.postType.value.youtubeId && (
              <iframe
                src={`https://www.youtube.com/embed/${entry.data.postType.value.youtubeId}?autoplay=1&rel=0`}
                title={entry.data.title}
                class="w-full h-full border-0"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
              ></iframe>
            )}
          </div>

          <div class="mt-6">
            <h1 class="text-2xl md:text-3xl lg:text-4xl font-bruta uppercase leading-tight mb-4 text-white">
              {entry.data.title}
            </h1>
            
            <div class="flex flex-wrap items-center gap-4 text-gray-400 text-sm mb-6 pb-6 border-b border-gray-800">
              <span class="font-bold text-white bg-gray-800 px-4 py-1.5 rounded-full flex items-center gap-2">
                <svg class="w-4 h-4 text-[#fd4f00]" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 14.5v-9l6 4.5-6 4.5z"/></svg>
                {entry.data.author || 'DataDocks'}
              </span>
              <span>Published on {formattedDate}</span>
            </div>

            <div class="bg-gray-900 rounded-xl p-6 text-gray-300 leading-relaxed">
              <section aria-label="Video Description" itemprop="description">
                <Content />
              </section>
            </div>
          </div>
        </div>

        <div class="w-full lg:w-96 flex-shrink-0 flex flex-col gap-6" style="margin-top: 0;">
          <h3 class="text-xl font-bruta uppercase mb-2 text-white">More Resources</h3>
          
          {relatedPosts.map((post: any) => {
            const relPostType = post.data.postType?.discriminant || 'article';
            const finalReadTime = post.data.readTime || getReadTime(post.body || '');
            
            if ((relPostType === 'video' || relPostType === 'short') && post.data.postType?.value && 'youtubeId' in post.data.postType.value && post.data.postType.value.youtubeId) {
              const videoId = post.data.postType.value.youtubeId;
              const isShort = relPostType === 'short';
              return (
                <a 
                  href={`${import.meta.env.BASE_URL}/${post.collection === 'videos' ? 'videos' : 'posts'}/${post.slug}${post.collection === 'videos' ? '?autoplay=1' : ''}`.replace('//', '/')}
                  class="group relative flex flex-col rounded-2xl overflow-hidden shadow-sm transition-all duration-300 hover:shadow-xl border-2 border-white/20 hover:border-white w-full"
                >
                <div class="flex items-start gap-4 p-2 transition-colors">
                   <div class="w-32 md:w-40 aspect-video bg-gray-800 rounded-lg overflow-hidden shrink-0 border border-white/10 group-hover:border-white/30 transition-all">
                     <lite-youtube 
                        videoid={videoId} 
                        playlabel={post.data.title} 
                        style={`background-image: url('https://i.ytimg.com/vi/${videoId}/hqdefault.jpg'); background-size: cover; background-position: center;`}
                        class="w-full h-full pointer-events-none" 
                      ></lite-youtube>
                   </div>
                   <div class="flex-grow min-w-0 py-1">
                     <h4 class="text-sm md:text-base lg:text-lg font-bold font-bruta uppercase leading-[1.15] line-clamp-3 text-white group-hover:text-[#fd4f00] transition-colors">{post.data.title}</h4>
                     <div class="mt-2 text-[10px] font-bold uppercase tracking-widest text-[#fd4f00] opacity-80">
                        {isShort ? 'Watch Short' : 'Watch Video'}
                     </div>
                   </div>
                </div>
              </a>
            );
          }

          return (
            <a 
              href={`${import.meta.env.BASE_URL}/${post.collection === 'videos' ? 'videos' : 'posts'}/${post.slug}`.replace('//', '/')} 
              class="group block w-full border-b border-white/10 last:border-0 pb-4 mb-4"
            >
              <div class="flex items-start gap-4 p-2 transition-colors">
                   <div class="w-32 md:w-40 aspect-video bg-[#FBC3AD] rounded-lg overflow-hidden shrink-0 border border-white/10 group-hover:border-white/30 transition-all flex items-center justify-center">
                     <svg class="w-8 h-8 text-[#fd4f00] opacity-60" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" /></svg>
                   </div>
                   <div class="flex-grow min-w-0 py-1">
                     <h4 class="text-sm md:text-base lg:text-lg font-bold font-bruta uppercase leading-[1.15] line-clamp-3 text-white group-hover:text-[#fd4f00] transition-colors">{post.data.title}</h4>
                     <div class="mt-2 text-[10px] font-bold uppercase tracking-widest text-gray-400">
                        Article • {finalReadTime.replace(/ read$/i, '')}
                     </div>
                   </div>
              </div>
            </a>
          );
        })}
        </div>
        
      </div>
    </main>

    <Footer />
  </Layout>
) : (
  <BlogPostLayout frontmatter={entry.data} headings={headings} relatedPosts={relatedPosts}>
    <Content />
  </BlogPostLayout>
)}