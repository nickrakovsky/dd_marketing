---
export const prerender = true;

import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';
import CTA from '../../components/home/CTA.astro';

export async function getStaticPaths() {
  const integrations = await getCollection('integrations');
  return integrations.map((int: CollectionEntry<'integrations'>) => ({
    params: { slug: int.slug },
    props: { integration: int },
  }));
}

interface Props {
  integration: CollectionEntry<'integrations'>;
}

const { integration: propIntegration } = Astro.props as Props;
const { slug } = Astro.params;

let integration: CollectionEntry<'integrations'> | undefined = propIntegration;
if (!integration) {
  const integrations = await getCollection('integrations');
  integration = integrations.find((i: CollectionEntry<'integrations'>) => i.slug === slug);
}

if (!integration) {
  Astro.response.status = 404;
  return Astro.rewrite('/404');
}

await integration.render();
---

<Layout title={integration.data.pageTitle || integration.data.title} description={integration.data.description}>
  <style>
    .text-brand-orange {
      color: #fd4f00;
    }
  </style>

  <Navigation />
  
  <main class="bg-[#FFF8E9] text-[#000000] relative">
      
      {/* Refined Hero Section */}
      <section class="relative min-h-[75vh] flex flex-col items-center justify-center pt-24 pb-20 px-6 overflow-hidden">
        
        {/* Flanking Graphics - Centered and edge-aligned WITHOUT obstructing Navigation */}
        <div class="absolute inset-0 pointer-events-none select-none z-10 hidden md:block overflow-hidden">
            {/* Left Visual Group */}
            <div class="absolute left-0 top-1/2 -translate-y-1/2 w-[35%] max-w-[350px] -translate-x-[40%]">
                <div class="relative w-full h-full">
                    <img src="/images/integrations/hero-shape-1.svg" alt="" class="w-full h-auto opacity-70" />
                    <img src="/images/integrations/datadocks-icon.svg" alt="DataDocks" class="absolute top-1/2 right-[5%] -translate-y-1/2 w-28 h-28 lg:w-36 lg:h-36 object-contain filter drop-shadow-2xl" />
                </div>
            </div>

            {/* Right Visual Group */}
            <div class="absolute right-0 top-1/2 -translate-y-1/2 w-[35%] max-w-[350px] translate-x-[40%]">
                <div class="relative w-full h-full">
                    <img src="/images/integrations/hero-shape-2.svg" alt="" class="w-full h-auto opacity-70" />
                    <img src={integration.data.icon} alt={integration.data.title} class="absolute top-1/2 left-[5%] -translate-y-1/2 w-28 h-28 lg:w-36 lg:h-36 object-contain filter drop-shadow-2xl transform rotate-[15deg]" />
                </div>
            </div>
        </div>

        <div class="w-full max-w-7xl mx-auto relative z-20">
          <div class="text-center mb-10">
              {/* Balanced Two-Line H1 Branding - Allowing wrap for long integration names */}
              <h1 class="font-bruta leading-none tracking-tighter mb-10">
                  <span class="text-brand-orange text-4xl md:text-6xl lg:text-7xl block uppercase mb-2">
                      DataDocks+
                  </span>
                  <span class="text-black text-5xl md:text-7xl lg:text-8xl block uppercase leading-[0.95]">
                      {integration.data.title}
                  </span>
              </h1>

          {/* Unified Recoleta Body Copy using heroBody as the longer-form copy */}
              <p class="font-recoleta text-lg md:text-2xl font-semibold text-gray-800 max-w-4xl mx-auto leading-[1.2] tracking-tight">
                  {integration.data.heroBody}
              </p>
          </div>

          {/* Standard Hero CTA Form */}
          <div class="w-full flex justify-center mt-12 relative z-30">
            <form
              id="integration-hero-form"
              class="flex flex-col sm:flex-row items-stretch justify-center gap-0 bg-[#EFE2D2] sm:bg-transparent"
            >
              <input
                type="email"
                name="email"
                placeholder="Enter your email"
                style="outline: none !important; box-shadow: none !important; -webkit-appearance: none;"
                class="!h-12 sm:!h-14 w-full sm:w-[22rem] px-4 text-center sm:text-left sm:hover:pl-5 sm:focus:pl-5 transition-all duration-300 bg-[#EFE2D2] text-black placeholder:text-[#8D785C] text-lg border-none font-recoleta focus:ring-0 focus:outline-none"
                required
              />
              <button
                type="submit"
                class="!h-12 sm:!h-14 w-full sm:w-auto px-8 bg-[#FE5000] hover:bg-black text-white font-medium transition-colors duration-500 whitespace-nowrap tracking-wide text-lg flex items-center justify-center font-recoleta [text-shadow:0px_1px_2px_rgba(0,0,0,0.4)] hover:[text-shadow:none]"
              >
                Schedule a Demo
              </button>
            </form>
          </div>
        </div>
      </section>

      <script is:inline>
        (function () {
          var calendlyUrl = "https://calendly.com/nick-rakovsky/datadocks-demo?primary_color=FF5722";

          function attachIntegrationForm() {
            var form = document.getElementById("integration-hero-form");
            if (!form || form.dataset.bound) return;
            form.dataset.bound = 'true';
            form.addEventListener("submit", function(e) {
              e.preventDefault();
              var emailInput = form.querySelector('input[name="email"]');
              var email = emailInput ? emailInput.value : '';

              if (email) {
                if (window.bento) {
                  window.bento.identify(email);
                  window.bento.track("Demo Subscriber", { source: window.location.pathname });
                } else {
                  var attempts = 0;
                  var interval = setInterval(function() {
                    if (window.bento) {
                      clearInterval(interval);
                      window.bento.identify(email);
                      window.bento.track("Demo Subscriber", { source: window.location.pathname });
                    } else if (++attempts >= 20) {
                      clearInterval(interval);
                      console.warn('[Bento] SDK not loaded after 4s. Check PUBLIC_BENTO_SITE_UUID in env.');
                    }
                  }, 200);
                }
              }
              window.open(calendlyUrl, "_blank", "noopener");
              form.reset();
            });
          }

          attachIntegrationForm();
          document.addEventListener('astro:page-load', attachIntegrationForm);
        })();
      </script>

      {/* Integration Advantages Section */}
      {integration.data.benefits && integration.data.benefits.length > 0 && (
        <section id="advantages" class="py-24 relative z-20">
          <div class="max-w-7xl mx-auto px-6 lg:px-8">
            <div class="text-center mb-16">
              <h2 class="font-bruta text-6xl md:text-7xl uppercase tracking-tight max-w-5xl mx-auto">
                  {integration.data.advantagesTitle || "Integration Advantages"}
              </h2>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
              {integration.data.benefits.map((benefit: any) => (
                <div class="flex flex-col items-start bg-[#f1e3d2] p-8 rounded-[1.25rem] shadow-sm hover:shadow-2xl transition-all border border-[#e3d5c4]/30 group">
                  {benefit.icon && (
                    <div class="mb-8 w-16 h-16 flex items-center justify-center group-hover:scale-110 transition-transform duration-500">
                      <img src={benefit.icon} alt="" class="w-full h-full object-contain" />
                    </div>
                  )}
                  <h3 class="text-2xl font-bold font-recoleta text-gray-900 mb-4 leading-tight tracking-tight">{benefit.title}</h3>
                  <p class="text-gray-700 leading-relaxed font-medium text-lg lg:text-xl opacity-90">{benefit.text}</p>
                </div>
              ))}
            </div>

            {integration.data.disclaimer && (
              <div class="mt-20 text-center">
                  <p class="text-sm font-recoleta font-normal leading-relaxed text-[#6F6452] max-w-6xl mx-auto">
                      {integration.data.disclaimer}
                  </p>
              </div>
            )}
          </div>
        </section>
      )}

    </main>

  <CTA />
  <Footer />
</Layout>
