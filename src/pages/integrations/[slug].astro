---
export const prerender = true;

import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.jsx';
import Footer from '../../components/Footer.astro';
import CTA from '../../components/home/CTA.astro';

export async function getStaticPaths() {
  const integrations = await getCollection('integrations');
  return integrations.map(int => ({
    params: { slug: int.slug },
    props: { integration: int },
  }));
}

const { integration: propIntegration } = Astro.props;
const { slug } = Astro.params;

let integration = propIntegration;
if (!integration) {
  const integrations = await getCollection('integrations');
  integration = (integrations as any[]).find(i => i.slug === slug);
}

if (!integration) {
  Astro.response.status = 404;
  return Astro.rewrite('/404');
}

const { Content } = await (integration as any).render();
---

<Layout title={`${integration.data.pageTitle || integration.data.title} | DataDocks Integration`} description={integration.data.description}>
  <Navigation client:idle />
  
  <main class="bg-[#FFF8E9] min-h-screen pt-32 pb-24">
    
    {/* Header / Overview */}
    <div class="max-w-7xl mx-auto px-6 lg:px-8 mb-20">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <h3 class="text-brand-orange text-lg font-bold tracking-tight uppercase mb-4">{integration.data.subheader}</h3>
          <h1 class="text-5xl md:text-6xl font-black text-gray-900 tracking-tight font-recoleta mb-6 leading-tight">
            {integration.data.title}
          </h1>
          <p class="text-xl text-gray-700 leading-relaxed mb-8">
            {integration.data.overview}
          </p>
          <a href="https://calendly.com/nick-rakovsky/datadocks-demo?month=2023-05" class="inline-flex justify-center rounded-lg text-sm font-semibold py-3 px-6 bg-gray-900 text-white hover:bg-gray-700">
             Schedule a Demo
          </a>
        </div>
        <div class="flex justify-center flex-col items-center bg-white p-16 rounded-3xl shadow-[0_20px_50px_rgba(0,0,0,0.05)]">
           {integration.data.icon ? (
             <img src={integration.data.icon} alt={integration.data.title} class="w-48 h-48 object-contain mb-8" />
           ) : (
             <div class="w-48 h-48 bg-gray-100 rounded-full mb-8"></div>
           )}
           {integration.data.disclaimer && (
             <p class="text-xs text-gray-400 text-center uppercase tracking-wider">{integration.data.disclaimer}</p>
           )}
        </div>
      </div>
    </div>

    {/* Benefits section (if present) */}
    {integration.data.benefits && integration.data.benefits.length > 0 && (
      <div class="max-w-7xl mx-auto px-6 lg:px-8 py-20 bg-white rounded-3xl mb-20 shadow-sm border border-orange-50">
        <div class="text-center mb-16">
          <h2 class="text-3xl font-bold font-recoleta sm:text-4xl text-gray-900">Why Integrate {integration.data.title}?</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-12 text-center">
          {integration.data.benefits.map((benefit) => (
            <div class="flex flex-col items-center">
              {benefit.icon && (
                <div class="mb-6 p-4 bg-orange-50 rounded-full">
                  <img src={benefit.icon} alt="" class="w-12 h-12 object-contain" />
                </div>
              )}
              <h3 class="text-xl font-bold font-recoleta text-gray-900 mb-3">{benefit.title}</h3>
              <p class="text-gray-600 leading-relaxed">{benefit.text}</p>
            </div>
          ))}
        </div>
      </div>
    )}

    {/* Content Section */}
    <div class="max-w-3xl mx-auto px-6 lg:px-8">
      <div class="prose prose-lg prose-orange mx-auto">
        <Content />
      </div>
    </div>

  </main>

  <CTA />
  <Footer />
</Layout>
