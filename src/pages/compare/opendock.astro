---
import Layout from "../../layouts/Layout.astro";
import Navigation from "../../components/Navigation.jsx";
import Footer from "../../components/Footer.astro";

const sections = [
  {
    id: "training",
    heading: "Training and Support",
    image: { src: "/images/6697eaf1ef0175dfdcf7e88c_DD-Comic.webp", alt: "Training and support illustration" },
    items: [
      { title: "Ease of Setup", odScore: 15, ddScore: 100 },
      { title: "Carrier Onboarding", odScore: 30, ddScore: 100 },
      { title: "Ongoing Support", odScore: 30, ddScore: 100 },
    ],
    summary: {
      dd: { title: "With DataDocks, you get comprehensive onboarding.", body: "And we stick around to make sure you and your carriers are successful." },
      od: { title: "Opendock will set you up in less than an hour.", body: "But users say: \"The service I'm receiving now isn't what I initially signed up for.\" <sup>1</sup>" },
    },
  },
  {
    id: "ui",
    heading: "User Interface",
    image: { src: "/images/661d172d591e8a0d7adb03e3_2.webp", alt: "User interface illustration" },
    items: [
      { title: "Manage Multiple Facilities", odScore: 15, ddScore: 100 },
      { title: "User Permissions", odScore: 30, ddScore: 100 },
      { title: "Scalability", odScore: 30, ddScore: 100 },
    ],
    summary: {
      dd: { title: "DataDocks provides a custom dashboard for each user.", body: "With filters and settings for each facility, the interface stays clean as you scale." },
      od: { title: "Opendock puts all your facilities and their appointments in one place.", body: "It offers visibility but we think it gets congested over time." },
    },
  },
  {
    id: "who",
    heading: "Who is it for?",
    image: { src: "/images/661d181970c22886b1a17fa8_3.webp", alt: "Who is it for illustration" },
    items: [
      { title: "National Carriers", odScore: 15, ddScore: 100 },
      { title: "Local Carriers", odScore: 30, ddScore: 100 },
      { title: "Integration with Other Systems", odScore: 30, ddScore: 100 },
    ],
    summary: {
      dd: { title: "DataDocks focusses on dock scheduling.", body: "We thrive on those nuances and tailor the system to match your setup." },
      od: { title: "Loadsmart excels at Freight Brokerage, and Opendock is part of that vision.", body: "But we don't think they get the nuances of warehouses and carrier relationships." },
    },
  },
  {
    id: "unexpected",
    heading: "Dealing with the Unexpected",
    image: { src: "/images/661d1b8e591e8a0d7adf484a_4-p-2000.webp", alt: "Dealing with the unexpected illustration" },
    items: [
      { title: "Reliability", odScore: 15, ddScore: 100 },
      { title: "Edge Cases", odScore: 30, ddScore: 100 },
      { title: "Rescheduling", odScore: 30, ddScore: 100 },
    ],
    summary: {
      dd: { title: "DataDocks is made for dealing with real-life challenges.", body: "Whether it's rescheduling canceled appointments or taking care of spot trailers." },
      od: { title: "Opendock is designed for operations with a fixed schedule.", body: "It \"can be limited\" <sup>2</sup> and service outages can be frustrating." },
    },
  },
  {
    id: "data",
    heading: "Data and Accountability",
    image: { src: "/images/661d1c92fdc2884d165589b2_5-p-2000.webp", alt: "Data and accountability illustration" },
    items: [
      { title: "Easy-to-use", odScore: 15, ddScore: 100 },
      { title: "Reporting", odScore: 30, ddScore: 100 },
      { title: "Customizability", odScore: 30, ddScore: 100 },
    ],
    summary: {
      dd: { title: "If you're preparing for a data-driven future, DataDocks is for you.", body: "Whether it's logging unscheduled trucks or editing past appointments, we make it easy." },
      od: { title: "If you want a logistics-friendly alternative to Google Calendar, Opendock nails it.", body: "But for continuous improvement, you need more accurate data." },
    },
  },
];
---

<Layout
  title="DataDocks vs OpenDock | Dock Scheduling Software Comparison"
  description="Comparison between DataDocks and OpenDock for dock scheduling software."
  noindex={true}
>
  <Navigation client:idle />

  <main class="bg-[#FFF8E9] min-h-screen">

    <!-- ═══ HERO ══════════════════════════════════════════════════════════ -->
    <section class="vs-hero">
      <div class="vs-hero__inner">

        <img class="vs-hero__deco vs-hero__deco--left" src="/images/6.svg" alt="" loading="eager" aria-hidden="true" />
        <img class="vs-hero__deco vs-hero__deco--right" src="/images/15.svg" alt="" loading="eager" aria-hidden="true" />

        <div class="vs-hero__content">

          {/* Single H1 with 3 styled spans — datadocks and OpenDock same size */}
          <h1 class="vs-hero__h1">
            <span class="vs-hero__datadocks">datadocks</span>
            <span class="vs-hero__second-line">
              <span class="vs-hero__vs">vs.</span>
              <span class="vs-hero__opendock">OpenDock</span>
            </span>
          </h1>

          <!-- Verified: Recoleta 17.36px/20.83px, max-width 486px -->
          <div class="vs-hero__body">
            <p class="vs-hero__body-text">
              How to Choose the Right Dock Scheduling Software?<br /><br />
              If your facility gets about 20 loads per week, Opendock has you covered.<br /><br />
              Any more than that, and we think you'll appreciate what
              <strong class="vs-hero__orange">DataDocks</strong> can do.
            </p>
            <!-- Verified: flex 38px, bg #EFE2D2, black button, Recoleta -->
            <form class="vs-hero__form" method="get" action="/demo">
              <input class="vs-hero__form-input" type="email" name="email" id="hero-email" placeholder="Enter your email" aria-label="Enter your email" required />
              <button class="vs-hero__form-btn" type="submit">Schedule a Demo</button>
            </form>
          </div>

        </div>
      </div>
    </section>

    <!-- ═══ COMPARISON SECTIONS ══════════════════════════════════════════ -->
    {sections.map((section) => (
      <section class="vs-section" id={section.id}>
        <div class="vs-section__inner">

          <h2 class="vs-section__heading js-reveal">{section.heading}</h2>

          <div class="vs-section__grid">

            {section.items.map((item) => (
              <article class="gauge-item">
                <h3 class="gauge-item__title">{item.title}</h3>
                <div class="gauge-group">
                  <div class="gauge">
                    <span class="gauge__label">Opendock</span>
                    <div class="gauge__track">
                      <div class="gauge__fill js-gauge" style={`--score: ${item.odScore}%`}></div>
                    </div>
                  </div>
                  <div class="gauge">
                    <span class="gauge__label">DataDocks</span>
                    <div class="gauge__track">
                      <div class="gauge__fill gauge__fill--dd js-gauge" style={`--score: ${item.ddScore}%`}></div>
                    </div>
                  </div>
                </div>
              </article>
            ))}

            <div class="vs-summary js-reveal">
              <div class="vs-summary__card">
                <img src="/images/logo-3.svg" alt="DataDocks" class="vs-summary__icon" />
                <div>
                  <p class="vs-summary__title">{section.summary.dd.title}</p>
                  <p class="vs-summary__body">{section.summary.dd.body}</p>
                </div>
              </div>
              <div class="vs-summary__card">
                <img src="/images/3.svg" alt="Opendock" class="vs-summary__icon" />
                <div>
                  <p class="vs-summary__title">{section.summary.od.title}</p>
                  <p class="vs-summary__body" set:html={section.summary.od.body}></p>
                </div>
              </div>
            </div>

          </div>
        </div>
      </section>
    ))}

    <!-- ═══ FOOTNOTES ════════════════════════════════════════════════════ -->
    <div class="vs-footnotes">
      <a href="https://www.g2.com/products/opendock/reviews/opendock-review-7755123" target="_blank" rel="noopener" class="vs-footnote"><sup>1</sup> Review posted to g2.com, February 2023</a>
      <a href="https://www.g2.com/products/opendock/reviews/opendock-review-8691077" target="_blank" rel="noopener" class="vs-footnote"><sup>2</sup> Review posted to g2.com, October 2023</a>
    </div>

    <!-- ═══ CTA SECTION ══════════════════════════════════════════════════ -->
    <!-- TODO: pending verified computed styles -->
    <section class="vs-cta">
      <div class="vs-cta__inner">
        <h2 class="vs-cta__heading">Let us help you decide if DataDocks is a good fit for your needs</h2>
        <form class="vs-hero__form" method="get" action="/demo">
          <input class="vs-hero__form-input" type="email" name="email" id="cta-email" placeholder="Enter your email" aria-label="Enter your email" required />
          <button class="vs-hero__form-btn" type="submit">Schedule a Demo</button>
        </form>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

<style>
  /* ══ HERO ═══════════════════════════════════════════════════════════════ */
  /* No overflow:hidden — images intentionally bleed into next section */
  .vs-hero { display: block; padding-top: 34.72px; padding-bottom: 34.72px; position: relative; }
  .vs-hero__inner { position: relative; }

  /* Bigger images, bleeding below hero */
  .vs-hero__deco {
    position: absolute;
    top: 11.83px;
    width: 25%; /* Verified */
    overflow: clip;
    pointer-events: none;
  }
  .vs-hero__deco--left  { left: 0;  height: 666.422px; }
  .vs-hero__deco--right { right: 0; height: 702.906px; }

  /* Clean flex col, scalable space-between, fluid margin */
  .vs-hero__content {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: space-between;
    gap: clamp(40px, 6vw, 80px); /* Scalable outer gap */
    margin-inline: clamp(24px, 10vw, 150px);
    z-index: 2;
  }

  /* Single H1 — flex column so datadocks sits above vs+OpenDock row */
  .vs-hero__h1 {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin: 0;
  }

  /* datadocks span — Scales fluidly with the viewport */
  .vs-hero__datadocks {
    font-family: 'Bruta', sans-serif;
    font-size: clamp(60px, 7.8vw, 140px); 
    font-weight: 800;
    color: rgb(253, 79, 0);
    letter-spacing: -1px;
    line-height: 0.95; /* Tighter line-height to reduce vertical gap */
    text-transform: uppercase;
    text-align: center;
    display: block;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
  }

  /* Second line: vs. + OpenDock row */
  .vs-hero__second-line {
    display: flex;
    flex-direction: row;
    align-items: baseline; /* CRITICAL: baseline alignment fixes the "hanging vs." issue */
    justify-content: center;
    padding-right: clamp(16px, 3.5vw, 50px); /* Scalable optical offset */
    margin-top: -0.1em; /* Cleanly pulls the second line up to fix the excessive gap */
  }

  /* vs. span */
  .vs-hero__vs {
    font-family: 'Bruta', sans-serif;
    font-size: clamp(28px, 3.5vw, 60px);
    font-weight: 800;
    line-height: 1;
    color: rgb(0, 0, 0);
    -webkit-font-smoothing: antialiased;
  }

  /* OpenDock span */
  .vs-hero__opendock {
    font-family: 'Bruta', sans-serif;
    font-size: clamp(60px, 7.8vw, 140px);
    font-weight: 800;
    letter-spacing: -1px;
    line-height: 1;
    text-transform: uppercase;
    color: rgb(0, 0, 0);
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
  }

  /* Fluid max-width and fluid gap between text and form */
  .vs-hero__body {
    max-width: clamp(340px, 40vw, 550px);
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: clamp(32px, 5.6vw, 80px); /* Increases the gap fluidly */
  }

  .vs-hero__body-text {
    font-family: 'Recoleta', sans-serif;
    font-size: clamp(18px, 1.98vw, 28px);
    font-weight: 500;  /* Dropped from 600 to thin it out visually */
    line-height: 1.25; 
    color: rgb(0, 0, 0);
    margin: 0;
    text-align: center;
    -webkit-font-smoothing: antialiased; /* Renders thinner on macOS */
  }

  .vs-hero__orange {
    color: rgb(253, 79, 0);
    font-weight: inherit;
  }

  /* Verified: flex 38px, bg #EFE2D2 */
  .vs-hero__form { display: flex; align-items: center; height: 38px; width: 100%; background-color: rgb(239, 226, 210); }
  .vs-hero__form-input { flex: 1; height: 100%; border: none; background: transparent; padding-inline: 17.3583px; font-family: 'Recoleta', sans-serif; font-size: 17.3583px; color: rgb(0, 0, 0); outline: none; }
  .vs-hero__form-input::placeholder { color: rgb(0, 0, 0); opacity: 0.5; }

  /* Verified: 167.92px wide, black bg, white, Recoleta, no radius, transition 0.6s */
  .vs-hero__form-btn {
    flex-shrink: 0;
    width: 167.922px;
    height: 38px;
    padding: 6.075px 17.3583px;
    font-family: 'Recoleta', sans-serif;
    font-size: 17.3583px;
    font-weight: 400;
    color: rgb(255, 255, 255);
    background-color: rgb(0, 0, 0);
    border: none;
    border-radius: 0;
    cursor: pointer;
    transition: all 0.6s cubic-bezier(0.19, 1, 0.22, 1);
    white-space: nowrap;
  }
  .vs-hero__form-btn:hover { background-color: rgb(253, 79, 0); }

  /* ══ COMPARISON SECTIONS ════════════════════════════════════════════════ */
  /* Verified: block, max-width 1400px, padding 69.43px 63.55px */
  .vs-section { display: block; }
  .vs-section__inner {
    max-width: 1400px;
    margin-inline: auto;
    padding: 69.43px 63.55px;
    display: flex;
    flex-direction: column;
    gap: 34.72px; /* replaces spacer-medium divs */
  }

  /* Verified: Bruta, 54.68px/49.21px, uppercase, center, black */
  .vs-section__heading {
    font-family: 'Bruta', sans-serif;
    font-size: 54.6787px;
    font-weight: 800;
    line-height: 49.2109px;
    text-align: center;
    text-transform: uppercase;
    color: rgb(0, 0, 0);
    margin: 0;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
  }

  /* Verified: display grid, 3 cols, gap 69.43px, row 2 for summary */
  .vs-section__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 69.43px;
  }

  /* Verified: flex col, justify-start */
  .gauge-item { display: flex; flex-direction: column; justify-content: flex-start; }

  /* Verified: Recoleta SemiBold 600, 23.87px/28.64px */
  .gauge-item__title {
    font-family: 'Recoleta', sans-serif;
    font-size: 23.8677px;
    font-weight: 600;
    line-height: 28.6413px;
    color: rgb(0, 0, 0);
    margin: 0 0 17.36px 0; /* replaces spacer-small */
  }

  .gauge-group { display: flex; flex-direction: column; gap: 12px; }

  .gauge { display: flex; flex-direction: column; gap: 8.68px; }

  /* Verified: Recoleta 17.36px/20.83px */
  .gauge__label { font-family: 'Recoleta', sans-serif; font-size: 17.3583px; line-height: 20.83px; color: rgb(0, 0, 0); }

  /* Gauge track — height TBD (pending verified data) */
  .gauge__track { height: 16px; background-color: rgb(239, 226, 210); width: 100%; overflow: hidden; }

  /* Animated fill — starts at 0, animates to --score on scroll */
  .gauge__fill { height: 100%; width: 0; background-color: rgb(100, 100, 100); transition: width 1s ease; }
  .gauge__fill--dd { background-color: rgb(253, 79, 0); }
  .gauge__fill.is-animated { width: var(--score); }

  /* Summary row — spans all 3 columns */
  .vs-summary { grid-column: 1 / -1; display: flex; gap: 40px; }
  .vs-summary__card { flex: 1; display: flex; gap: 16px; align-items: flex-start; }
  .vs-summary__icon { width: 40px; height: 40px; object-fit: contain; flex-shrink: 0; }
  .vs-summary__title { font-family: 'Recoleta', sans-serif; font-size: 17.3583px; font-weight: 600; line-height: 20.83px; color: rgb(0, 0, 0); margin: 0 0 8px 0; }
  .vs-summary__body { font-family: 'Recoleta', sans-serif; font-size: 17.3583px; line-height: 20.83px; color: rgb(0, 0, 0); margin: 0; }

  /* ══ FOOTNOTES ══════════════════════════════════════════════════════════ */
  .vs-footnotes { max-width: 1400px; margin-inline: auto; padding: 0 63.55px 69.43px; display: flex; flex-direction: column; gap: 8px; }
  .vs-footnote { font-family: 'Recoleta', sans-serif; font-size: 14px; color: rgb(0, 0, 0); opacity: 0.6; }

  /* ══ CTA ════════════════════════════════════════════════════════════════ */
  /* TODO: verify computed styles for CTA section */
  .vs-cta { background-color: rgb(0, 0, 0); padding: 69.43px 63.55px; }
  .vs-cta__inner { max-width: 800px; margin-inline: auto; display: flex; flex-direction: column; align-items: center; gap: 32px; }
  .vs-cta__heading { font-family: 'Bruta', sans-serif; font-size: 40px; font-weight: 800; text-transform: uppercase; text-align: center; color: rgb(255, 255, 255); margin: 0; -webkit-font-smoothing: antialiased; }

  /* ══ SCROLL REVEAL ══════════════════════════════════════════════════════ */
  .js-reveal { opacity: 0; transform: translateY(20px); transition: opacity 0.6s ease, transform 0.6s ease; }
  .js-reveal.is-visible { opacity: 1; transform: translateY(0); }
</style>

<script>
  // Gauge fill animation on scroll
  const gauges = document.querySelectorAll<HTMLElement>('.js-gauge');
  const reveals = document.querySelectorAll<HTMLElement>('.js-reveal');

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-animated', 'is-visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.3 }
  );

  gauges.forEach((el) => observer.observe(el));
  reveals.forEach((el) => observer.observe(el));
</script>
