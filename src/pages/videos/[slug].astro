---
import { getCollection, getEntry } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';

export const prerender = true;

export async function getStaticPaths() {
  const videoEntries = await getCollection('videos');
  return videoEntries.map((entry: CollectionEntry<'videos'>) => ({
    params: { slug: entry.slug }, 
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<'videos'>;
}

const { slug } = Astro.params;
const entry: CollectionEntry<'videos'> = (Astro.props as Props).entry || await getEntry('videos', slug as string);

if (!entry) {
  return Astro.redirect('/404');
}
const { Content } = await entry.render();

const postType = entry.data.postType?.discriminant || 'video';
const youtubeId = entry.data.postType?.value && 'youtubeId' in entry.data.postType.value ? entry.data.postType.value.youtubeId : undefined;

const formattedDate = new Date(entry.data.pubDate).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});

// Fetch related content (mix of videos and posts)
const allVideos = await getCollection('videos');
const allPosts = await getCollection('posts');

const relatedVideos = allVideos
  .filter((v: CollectionEntry<'videos'>) => v.slug !== entry.slug && v.data.category === entry.data.category)
  .sort((a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf());

const relatedPosts = allPosts
  .filter((p: CollectionEntry<'posts'>) => p.data.category === entry.data.category)
  .sort((a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf());

let sidebarItems = [...relatedVideos.slice(0, 2), ...relatedPosts.slice(0, 2)];
---

<Layout
  title={entry.data.title}
  description={entry.data.description}
  image={youtubeId ? `https://img.youtube.com/vi/${youtubeId}/maxresdefault.jpg` : undefined}
  type="video"
  noindex={true}
  videoData={youtubeId ? {
    youtubeId: youtubeId,
    uploadDate: entry.data.pubDate,
    duration: 'duration' in entry.data.postType.value ? entry.data.postType.value.duration : undefined
  } : undefined}
>
  <link rel="stylesheet" href="/css/lite-yt-embed.css" media="print" onload="this.media='all'" />
  <script is:inline src="/css/lite-yt-embed.js" defer></script>
  <a href="#video-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 bg-[#fd4f00] text-white px-4 py-2 rounded-lg z-[100] font-bold">Skip to content</a>
  
  <Navigation />
  
  <main class="bg-[#0f0f0f] min-h-screen text-white pt-28 pb-20 font-recoleta">
    <div class="max-w-7xl mx-auto px-4 md:px-8">
      
      {/* Signposting Banner */}
      <div class="bg-[#fd4f00]/10 border border-[#fd4f00]/30 rounded-xl p-4 mb-8 flex flex-col sm:flex-row items-center justify-between gap-4">
        <div class="flex items-center gap-3">
          <svg class="w-6 h-6 text-[#fd4f00]" fill="currentColor" viewBox="0 0 24 24">
            <path d="M10 15l5.19-3L10 9v6m11.56-7.83c.13.47.22 1.1.28 1.9.07.8.1 1.49.1 2.09L22 12c0 .61-.03 1.3-.1 2.1-.06.8-.15 1.43-.28 1.9-.13.47-.45.85-.93.93-.47.13-1.1.22-1.9.28-.8.07-1.49.1-2.09.1L12 17.5c-.61 0-1.3-.03-2.1-.1-.8-.06-1.43-.15-1.9-.28-.47-.13-.85-.45-.93-.93-.13-.47-.22-1.1-.28-1.9-.07-.8-.1-1.49-.1-2.09L4 12c0-.61.03-1.3.1-2.1.06-.8.15-1.43.28-1.9.13-.47.45-.85.93-.93.47-.13 1.1-.22 1.9-.28.8-.07 1.49-.1 2.09-.1L12 6.5c.61 0 1.3.03 2.1.1.8.06 1.43.15 1.9.28.47.13.85.45.93.93zM5 12h14"/>
          </svg>
          <p class="text-sm md:text-base text-gray-300">
            This video is part of the <span class="text-white font-bold">DataDocks Resource Library</span>.
          </p>
        </div>
        <a 
          href={`https://www.youtube.com/watch?v=${youtubeId}`} 
          target="_blank" 
          rel="noopener noreferrer"
          class="bg-[#fd4f00] hover:bg-[#ff6a2a] text-white px-4 py-2 rounded-lg text-sm font-bold transition-colors flex items-center gap-2"
        >
          View on YouTube
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
      </div>

      <div class="flex flex-col lg:flex-row gap-8">
        <div id="video-content" class="flex-grow w-full max-w-4xl">
          
          <div class={`w-full rounded-2xl overflow-hidden shadow-2xl bg-black border border-gray-800 ${postType === 'short' ? 'max-w-sm mx-auto aspect-[9/16]' : 'aspect-video'}`}>
            {youtubeId && (
              <iframe
                src={`https://www.youtube.com/embed/${youtubeId}?autoplay=1&rel=0`}
                title={entry.data.title}
                class="w-full h-full border-0"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
              ></iframe>
            )}
          </div>

          <div class="mt-6">
            <h1 class="text-2xl md:text-3xl lg:text-4xl font-bruta uppercase leading-tight mb-4 text-white">
              {entry.data.title}
            </h1>
            
            <div class="flex flex-wrap items-center gap-4 text-gray-400 text-sm mb-6 pb-6 border-b border-gray-800">
              <span class="font-bold text-white bg-gray-800 px-4 py-1.5 rounded-full flex items-center gap-2">
                <svg class="w-4 h-4 text-[#fd4f00]" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 14.5v-9l6 4.5-6 4.5z"/></svg>
                {entry.data.author || 'DataDocks'}
              </span>
              <span>Published on {formattedDate}</span>
            </div>

            <div class="bg-gray-900 rounded-xl p-6 text-gray-300 leading-relaxed">
              <section aria-label="Video Description" itemprop="description">
                <Content />
              </section>
            </div>
          </div>
        </div>

        <div class="w-full lg:w-96 flex-shrink-0 flex flex-col gap-6">
          <h3 class="text-xl font-bruta uppercase mb-2 text-white">Related Resources</h3>
          
          {sidebarItems.map((item: any) => {
            const isVideo = item.collection === 'videos' || (item.data.postType?.discriminant === 'video' || item.data.postType?.discriminant === 'short');
            const href = item.collection === 'videos' ? `/videos/${item.slug}` : `/posts/${item.slug}`;
            
            return (
              <a 
                href={href}
                class="group block w-full border-b border-white/10 last:border-0 pb-4 mb-4"
              >
                <div class="flex items-start gap-4 p-2 transition-colors">
                  <div class="w-32 md:w-40 aspect-video bg-gray-800 rounded-lg overflow-hidden shrink-0 border border-white/10 group-hover:border-white/30 transition-all flex items-center justify-center relative">
                    {isVideo && item.data.postType?.value?.youtubeId ? (
                      <img 
                        src={`https://i.ytimg.com/vi/${item.data.postType.value.youtubeId}/hqdefault.jpg`} 
                        alt={item.data.title}
                        class="w-full h-full object-cover opacity-60 group-hover:opacity-100 transition-opacity"
                      />
                    ) : (
                      <svg class="w-8 h-8 text-[#fd4f00] opacity-60" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" /></svg>
                    )}
                  </div>
                  <div class="flex-grow min-w-0 py-1">
                    <h4 class="text-sm md:text-base font-bold font-bruta uppercase leading-[1.15] line-clamp-3 text-white group-hover:text-[#fd4f00] transition-colors">{item.data.title}</h4>
                    <div class="mt-2 text-[10px] font-bold uppercase tracking-widest text-[#fd4f00] opacity-80">
                      {isVideo ? 'Watch Video' : 'Read Article'}
                    </div>
                  </div>
                </div>
              </a>
            );
          })}
          
          <a href="/posts" class="text-center py-4 border-2 border-[#fd4f00] text-[#fd4f00] rounded-xl font-bruta uppercase hover:bg-[#fd4f00] hover:text-white transition-all">
            Back to Resource Hub
          </a>
        </div>
        
      </div>
    </div>
  </main>

  <Footer />
</Layout>
