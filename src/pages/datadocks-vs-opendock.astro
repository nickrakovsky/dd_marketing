---
export const prerender = true;

import Layout from "../layouts/Layout.astro";
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";
import CTA from "../components/home/CTA.astro";

const sections = [
  {
    id: "training",
    heading: "Training and Support",
    items: [
      { title: "Ease of Setup", odScore: 100, ddScore: 100 },
      { title: "Carrier Onboarding", odScore: 30, ddScore: 100 },
      { title: "Ongoing Support", odScore: 30, ddScore: 100 },
    ],
    summary: {
      dd: { title: "With DataDocks, you get comprehensive onboarding.", body: "And we stick around to make sure you and your carriers are successful." },
      od: { title: "Opendock will set you up in less than an hour.", body: "But users say: \"The service I'm receiving now isn't what I initially signed up for.\" <sup>1</sup>" },
    },
  },
  {
    id: "ui",
    heading: "User Interface",
    items: [
      { title: "Manage Multiple Facilities", odScore: 100, ddScore: 100 },
      { title: "User Permissions", odScore: 60, ddScore: 100 },
      { title: "Scalability", odScore: 30, ddScore: 100 },
    ],
    summary: {
      dd: { title: "DataDocks provides a custom dashboard for each user.", body: "With filters and settings for each facility, the interface stays clean as you scale." },
      od: { title: "Opendock puts all your facilities and their appointments in one place.", body: "It offers visibility but we think it gets congested over time." },
    },
  },
  {
    id: "who",
    heading: "Who is it for?",
    items: [
      { title: "National Carriers", odScore: 100, ddScore: 100 },
      { title: "Local Carriers", odScore: 30, ddScore: 100 },
      { title: "Integration with Other Systems", odScore: 50, ddScore: 100 },
    ],
    summary: {
      dd: { title: "DataDocks focusses on dock scheduling.", body: "We thrive on those nuances and tailor the system to match your setup." },
      od: { title: "Loadsmart excels at Freight Brokerage, and Opendock is part of that vision.", body: "But we don't think they get the nuances of warehouses and carrier relationships." },
    },
  },
  {
    id: "unexpected",
    heading: "Dealing with the Unexpected",
    items: [
      { title: "Reliability", odScore: 100, ddScore: 100 },
      { title: "Edge Cases", odScore: 10, ddScore: 100 },
      { title: "Rescheduling", odScore: 50, ddScore: 100 },
    ],
    summary: {
      dd: { title: "DataDocks is made for dealing with real-life challenges.", body: "Whether it's rescheduling canceled appointments or taking care of spot trailers." },
      od: { title: "Opendock is designed for operations with a fixed schedule.", body: "It \"can be limited\" <sup>2</sup> and service outages can be frustrating." },
    },
  },
  {
    id: "data",
    heading: "Data and Accountability",
    items: [
      { title: "Easy-to-use", odScore: 100, ddScore: 100 },
      { title: "Reporting", odScore: 20, ddScore: 100 },
      { title: "Customizability", odScore: 20, ddScore: 100 },
    ],
    summary: {
      dd: { title: "If you're preparing for a data-driven future, DataDocks is for you.", body: "Whether it's logging unscheduled trucks or editing past appointments, we make it easy." },
      od: { title: "If you want a logistics-friendly alternative to Google Calendar, Opendock nails it.", body: "But for continuous improvement, you need more accurate data." },
    },
  },
];
---

<Layout
  title="DataDocks vs OpenDock | Dock Scheduling Software Comparison"
  description="Comparison between DataDocks and OpenDock for dock scheduling software."
  noindex={true}
>
  <Navigation />

  <main class="bg-[#FFF8E9] min-h-screen overflow-x-hidden">

    <!-- ═══ HERO ══════════════════════════════════════════════════════════ -->
    <section class="vs-hero">
      <div class="vs-hero__inner">

        <img class="vs-hero__deco vs-hero__deco--left" src="/images/6.svg" alt="" loading="eager" aria-hidden="true" />
        <img class="vs-hero__deco vs-hero__deco--right" src="/images/15.svg" alt="" loading="eager" aria-hidden="true" />

        <div class="vs-hero__content">

          <h1 class="vs-hero__h1">
            <span class="vs-hero__datadocks">datadocks</span>
            <span class="vs-hero__second-line">
              <span class="vs-hero__vs">vs.</span>
              <span class="vs-hero__opendock">OpenDock</span>
            </span>
          </h1>

          <div class="vs-hero__body">
            <p class="vs-hero__body-text">
              How to Choose the Right Dock Scheduling Software?<br /><br />
              If your facility gets about 20 loads per week, Opendock has you covered.<br /><br />
              Any more than that, and we think you'll appreciate what
              <strong class="vs-hero__orange">DataDocks</strong> can do.
            </p>
            <!-- Hero CTA — matches homepage CTA component style -->
            <form
              id="vs-hero-form"
              class="vs-hero__form"
              method="get"
              action="/demo"
            >
              <input
                class="vs-hero__form-input"
                type="email"
                name="email"
                id="hero-email"
                placeholder="Enter your email"
                aria-label="Enter your email"
                required
              />
              <button class="vs-hero__form-btn" type="submit">Get Free Demo</button>
            </form>
          </div>

        </div>
      </div>
    </section>

    <!-- ═══ COMPARISON SECTIONS ══════════════════════════════════════════ -->
    {sections.map((section) => (
      <section class="vs-section" id={section.id}>
        <div class="vs-section__inner">

          <h2 class="vs-section__heading js-reveal">{section.heading}</h2>

          <div class="vs-section__grid">

            {section.items.map((item) => (
              <article class="gauge-item">
                <h3 class="gauge-item__title">{item.title}</h3>
                <div class="gauge-group">
                  <div class="gauge">
                    <div class="gauge__label-row">
                      <img src="/images/3.svg" alt="Opendock" class="gauge__logo" />
                      <span class="gauge__label">Opendock</span>
                    </div>
                    <div class="gauge__track-wrap">
                      <div class="gauge__track">
                        <div class="gauge__fill js-gauge" style={`--score: ${item.odScore}%`}></div>
                      </div>
                    </div>
                  </div>
                  <div class="gauge">
                    <div class="gauge__label-row">
                      <img src="/images/logo-3.svg" alt="DataDocks" class="gauge__logo" />
                      <span class="gauge__label">DataDocks</span>
                    </div>
                    <div class="gauge__track-wrap">
                      <div class="gauge__track">
                        <div class="gauge__fill gauge__fill--dd js-gauge" style={`--score: ${item.ddScore}%`}></div>
                      </div>
                    </div>
                  </div>
                </div>
              </article>
            ))}

            <div class="vs-summary js-reveal">
              <div class="vs-summary__card">
                <img src="/images/3.svg" alt="Opendock" class="vs-summary__icon" />
                <div>
                  <p class="vs-summary__title">{section.summary.od.title}</p>
                  <p class="vs-summary__body" set:html={section.summary.od.body}></p>
                </div>
              </div>
              <div class="vs-summary__card">
                <img src="/images/logo-3.svg" alt="DataDocks" class="vs-summary__icon" />
                <div>
                  <p class="vs-summary__title">{section.summary.dd.title}</p>
                  <p class="vs-summary__body">{section.summary.dd.body}</p>
                </div>
              </div>
            </div>

          </div>
        </div>
      </section>
    ))}

    <!-- ═══ FOOTNOTES ════════════════════════════════════════════════════ -->
    <div class="vs-footnotes">
      <a href="https://www.g2.com/products/opendock/reviews/opendock-review-7755123" target="_blank" rel="noopener" class="vs-footnote"><sup>1</sup> Review posted to g2.com, February 2023</a>
      <a href="https://www.g2.com/products/opendock/reviews/opendock-review-8691077" target="_blank" rel="noopener" class="vs-footnote"><sup>2</sup> Review posted to g2.com, October 2023</a>
    </div>

    <!-- ═══ CTA SECTION — identical to homepage ═════════════════════════ -->
    <CTA />

  </main>

  <Footer />
</Layout>

<style>
  /* ══ HERO ═══════════════════════════════════════════════════════════════ */
  .vs-hero {
    display: block;
    padding-top: 34.72px;
    padding-bottom: 0; /* Allow deco images to bleed into next section */
    position: relative;
    /* No overflow:hidden — deco images intentionally bleed downward */
  }
  /* Clip horizontal overflow at the page level via main */
  main { overflow-x: hidden; }
  .vs-hero__inner { position: relative; }

  /* Deco images — fade at bottom via mask, bleed slightly below hero */
  .vs-hero__deco {
    position: absolute;
    top: 11.83px;
    width: 28%;
    pointer-events: none;
    /* Fade out at bottom — start fade at 70%, fully transparent at 100% */
    -webkit-mask-image: linear-gradient(to bottom, black 65%, transparent 100%);
    mask-image: linear-gradient(to bottom, black 65%, transparent 100%);
  }
  .vs-hero__deco--left  { left: 0;  height: 820px; }
  .vs-hero__deco--right { right: 0; height: 860px; }

  .vs-hero__content {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: space-between;
    gap: clamp(32px, 5vw, 72px);
    margin-inline: clamp(24px, 12vw, 180px);
    z-index: 2;
  }

  /* H1 — slightly smaller than before */
  .vs-hero__h1 {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin: 0;
  }

  .vs-hero__datadocks {
    font-family: 'Bruta', sans-serif;
    /* Fluid: 52px at 400px viewport → 110px at 1400px viewport */
    font-size: clamp(52px, calc(52px + (110 - 52) * ((100vw - 400px) / (1400 - 400))), 110px);
    font-weight: 800;
    color: rgb(253, 79, 0);
    letter-spacing: -1px;
    line-height: 0.85;
    text-transform: uppercase;
    text-align: center;
    display: block;
    -webkit-font-smoothing: antialiased;
  }

  .vs-hero__second-line {
    display: flex;
    flex-direction: row;
    align-items: baseline;
    justify-content: center;
    padding-right: clamp(10px, 2.5vw, 40px);
    margin-top: -0.15em;
  }

  .vs-hero__vs {
    font-family: 'Bruta', sans-serif;
    /* Fluid: 24px at 400px → 48px at 1400px */
    font-size: clamp(24px, calc(24px + (48 - 24) * ((100vw - 400px) / (1400 - 400))), 48px);
    font-weight: 800;
    line-height: 1;
    color: rgb(0, 0, 0);
    -webkit-font-smoothing: antialiased;
  }

  .vs-hero__opendock {
    font-family: 'Bruta', sans-serif;
    font-size: clamp(52px, calc(52px + (110 - 52) * ((100vw - 400px) / (1400 - 400))), 110px);
    font-weight: 800;
    letter-spacing: -1px;
    line-height: 1;
    text-transform: uppercase;
    color: rgb(0, 0, 0);
    -webkit-font-smoothing: antialiased;
  }

  /* Hero body */
  .vs-hero__body {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: clamp(24px, 3.5vw, 48px);
  }

  .vs-hero__body-text {
    font-family: 'Recoleta', sans-serif;
    font-weight: 700;
    line-height: 1.35;
    color: rgb(0, 0, 0);
    margin: 0;
    text-align: center;
    -webkit-font-smoothing: antialiased;
  }

  /* Hero Body Typography Adjustments */
  /* Default (<575px): snaps to a narrower column, gradually expanding */
  @media (max-width: 574px) {
    .vs-hero__body { max-width: clamp(280px, 90vw, 380px); }
    .vs-hero__body-text { font-size: clamp(16px, 4.5vw, 20px); }
  }

  /* 575px to 949px: scale down to ensure lines are not broken */
  @media (min-width: 575px) and (max-width: 949px) {
    .vs-hero__body { max-width: 100%; }
    .vs-hero__body-text { font-size: clamp(16px, 2.5vw, 22px); }
  }

  /* >= 950px: font large enough so "Scheduling Software?" is line 2 */
  @media (min-width: 950px) {
    .vs-hero__body { max-width: 480px; }
    .vs-hero__body-text { font-size: clamp(22px, 2.5vw, 26px); }
  }

  .vs-hero__orange {
    color: rgb(253, 79, 0);
    font-weight: inherit;
  }

  /* Hero CTA form — taller, matching homepage CTA proportions */
  .vs-hero__form {
    display: flex;
    align-items: stretch;
    width: 100%;
  }
  .vs-hero__form-input {
    flex: 1;
    height: 3.35rem;
    border: none;
    background: rgb(239, 226, 210);
    padding-inline: 18px;
    font-family: 'Recoleta', sans-serif;
    font-size: 19px;
    color: rgb(0, 0, 0);
    outline: none;
    transition: padding-left 0.3s ease;
  }
  .vs-hero__form-input:hover { padding-left: 24px; }
  .vs-hero__form-input::placeholder { color: rgb(0, 0, 0); opacity: 0.5; }

  .vs-hero__form-btn {
    flex-shrink: 0;
    height: 3.35rem;
    padding: 0 24px;
    font-family: 'Recoleta', sans-serif;
    font-size: 17px;
    font-weight: 500;
    /* Title case — no uppercase transform */
    color: rgb(255, 255, 255);
    background-color: rgb(0, 0, 0);
    border: none;
    border-radius: 0;
    cursor: pointer;
    transition: all 0.5s cubic-bezier(0.19, 1, 0.22, 1);
    white-space: nowrap;
  }
  .vs-hero__form-btn:hover { background-color: rgb(253, 79, 0); }

  /* ══ COMPARISON SECTIONS ════════════════════════════════════════════════ */
  .vs-section { display: block; }
  .vs-section__inner {
    max-width: 1400px;
    margin-inline: auto;
    padding: 69.43px 63.55px;
    display: flex;
    flex-direction: column;
    gap: 34.72px;
  }

  /* H2 — desktop size kept, but clamped for mobile */
  .vs-section__heading {
    font-family: 'Bruta', sans-serif;
    font-size: clamp(28px, 4.5vw, 54px);
    font-weight: 800;
    line-height: 1.05;
    text-align: center;
    text-transform: uppercase;
    color: rgb(0, 0, 0);
    margin: 0;
    -webkit-font-smoothing: antialiased;
  }

  /* 3-col grid on desktop */
  .vs-section__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 52px;
  }

  .gauge-item { display: flex; flex-direction: column; justify-content: flex-start; }

  /* Subhead — fluid sizing to stay smaller than H2 */
  .gauge-item__title {
    font-family: 'Recoleta', sans-serif;
    font-size: clamp(20px, 3.5vw, 27px);
    font-weight: 700;
    line-height: 1.25;
    color: rgb(0, 0, 0);
    margin: 0 0 18px 0;
  }

  .gauge-group { display: flex; flex-direction: column; gap: 16px; }
  .gauge { display: flex; flex-direction: column; gap: 6px; }

  /* Label row with inline logo */
  .gauge__label-row {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  /* Logo in gauge — no box, no border, clean */
  .gauge__logo {
    width: 22px;
    height: 22px;
    object-fit: contain;
    flex-shrink: 0;
  }

  /* Body label text — slightly larger */
  .gauge__label {
    font-family: 'Recoleta', sans-serif;
    font-size: 19px;
    line-height: 1.3;
    color: rgb(0, 0, 0);
  }

  /* Track wrap — adds the outline offset around the bar */
  .gauge__track-wrap {
    padding: 2px;
    border: 1.5px solid rgba(0, 0, 0, 0.18);
    border-radius: 99px;
  }

  /* Track itself — sits inside the outline */
  .gauge__track {
    height: 14px;
    background-color: rgb(239, 226, 210);
    width: 100%;
    overflow: hidden;
    border-radius: 99px;
  }

  /* Animated fill */
  .gauge__fill {
    height: 100%;
    width: 0;
    background-color: #52D1A2;
    /* ease-out — no overshoot/spring bounce */
    transition: width 1.2s cubic-bezier(0.22, 0.61, 0.36, 1);
    border-radius: 99px;
  }
  .gauge__fill--dd { background-color: rgb(253, 79, 0); }
  .gauge__fill.is-animated { width: var(--score); }

  /* Summary row */
  .vs-summary {
    grid-column: 1 / -1;
    display: flex;
    gap: 48px;
    background-color: #EFE2D2;
    padding: 48px;
    border-radius: 40px;
    margin-top: 16px;
  }
  .vs-summary__card { flex: 1; display: flex; gap: 16px; align-items: flex-start; }

  /* Icon box removed — logos are full SVGs, displayed directly */
  .vs-summary__icon {
    width: 44px;
    height: 44px;
    object-fit: contain;
    flex-shrink: 0;
    margin-top: 2px; /* Slight optical alignment with text */
  }

  /* Summary text — scaled up */
  .vs-summary__title {
    font-family: 'Recoleta', sans-serif;
    font-size: 21px;
    font-weight: 700;
    line-height: 1.25;
    color: rgb(0, 0, 0);
    margin: 0 0 10px 0;
  }
  .vs-summary__body {
    font-family: 'Recoleta', sans-serif;
    font-size: 19px;
    line-height: 1.4;
    color: rgb(0, 0, 0);
    margin: 0;
  }

  /* ══ FOOTNOTES ══════════════════════════════════════════════════════════ */
  .vs-footnotes {
    max-width: 1400px;
    margin-inline: auto;
    padding: 0 63.55px 69.43px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .vs-footnote { font-family: 'Recoleta', sans-serif; font-size: 14px; color: rgb(0, 0, 0); opacity: 0.6; }

  /* ══ SCROLL REVEAL ══════════════════════════════════════════════════════ */
  .js-reveal { opacity: 0; transform: translateY(20px); transition: opacity 0.6s ease, transform 0.6s ease; }
  .js-reveal.is-visible { opacity: 1; transform: translateY(0); }

  /* ══ MOBILE ═════════════════════════════════════════════════════════════ */
  @media (max-width: 574px) {
    /* Stack form vertically on very small screens */
    .vs-hero__form {
      flex-direction: column;
    }
    .vs-hero__form-input {
      width: 100%;
      text-align: center;
      height: 3.35rem;
      min-height: 3.35rem;
    }
    .vs-hero__form-btn {
      width: 100%;
      height: 3.35rem;
      min-height: 3.35rem;
    }
  }

  @media (max-width: 767px) {
    /* Hide deco images on mobile — they overflow and look awkward */
    .vs-hero__deco { display: none; }

    /* Tighten hero margins on mobile */
    .vs-hero__content {
      margin-inline: 20px;
      gap: 28px;
    }

    /* Section padding reduction */
    .vs-section__inner {
      padding: 40px 20px;
      gap: 24px;
    }

    /* Stack grid to single column on mobile */
    .vs-section__grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    /* Summary stacks vertically */
    .vs-summary {
      flex-direction: column;
      gap: 28px;
      padding: 28px 20px;
      border-radius: 20px;
    }

    /* Footnotes padding */
    .vs-footnotes {
      padding: 0 20px 40px;
    }
  }

  /* ══ TABLET (768–1023px) ════════════════════════════════════════════════ */
  @media (min-width: 768px) and (max-width: 1023px) {
    .vs-hero__deco { width: 20%; }
    .vs-hero__deco--left  { height: 500px; }
    .vs-hero__deco--right { height: 520px; }

    .vs-hero__content { margin-inline: clamp(80px, 15vw, 140px); }
    .vs-hero__body { max-width: 100%; }

    .vs-section__inner { padding: 48px 32px; }

    /* 2-col grid on tablet */
    .vs-section__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 40px;
    }

    /* Summary goes full-width under the 2-col items */
    .vs-summary { flex-direction: column; gap: 28px; }
  }
</style>

<script>
  // Gauge fill animation on scroll
  const gauges = document.querySelectorAll<HTMLElement>('.js-gauge');
  const reveals = document.querySelectorAll<HTMLElement>('.js-reveal');

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-animated', 'is-visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.3 }
  );

  gauges.forEach((el) => observer.observe(el));
  reveals.forEach((el) => observer.observe(el));

  // Hero form — open Calendly — moved to is:inline below
</script>

<script is:inline>
  (function() {
    var calendlyUrl = 'https://calendly.com/nick-rakovsky/datadocks-demo?primary_color=FF5722';

    function attachVsForm() {
      var form = document.getElementById('vs-hero-form');
      if (!form || form.dataset.bound) return;
      form.dataset.bound = 'true';
      form.addEventListener('submit', function(e) {
        e.preventDefault();
        var emailInput = form.querySelector('input[name="email"]');
        var email = emailInput ? emailInput.value : '';
        if (email) {
          fetch('/api/bento-track', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              email: email,
              event: 'Demo Subscriber',
              source: window.location.pathname,
              landingPage: sessionStorage.getItem('dd_landing_page') || window.location.href,
              visitorUuid: (typeof window.getBentoVisitorUuid === 'function') ? window.getBentoVisitorUuid() : null
            }),
            keepalive: true
          }).catch(function() {});
        }
        window.open(calendlyUrl, '_blank', 'noopener');
        form.reset();
      });
    }

    attachVsForm();
    document.addEventListener('astro:page-load', attachVsForm);
  })();
</script>


