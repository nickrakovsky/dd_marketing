---
import PrintLayout from '../layouts/PrintLayout.astro';
---

<PrintLayout title="DataDocks Proposal | Texas Supply Chains">
  <div class="pdf-container">
    
    <!-- PAGE 1: THE HOOK & THE VALUE -->
    <section class="page shadow-2xl relative overflow-hidden bg-[#FFF8E9] text-[#000000] flex flex-col font-sans">
      <!-- HEADER -->
      <div class="px-12 pt-16 pb-0 shrink-0">
        <div class="flex justify-between items-end text-black mb-1">
            <span class="text-[9px] font-bold uppercase tracking-[0.2em] font-sans opacity-60 text-black translate-y-[2px]">Capabilities Statement: Food Production & Distribution.</span>
            <div class="flex items-center gap-3">
                <img src="/_offline_print/Brand-Collateral/datadocks-lockup-orange.svg" class="h-8 w-auto" alt="DataDocks" />
            </div>
        </div>
        <div class="h-px bg-black opacity-20 w-full"></div>
      </div>

      <!-- [ THE TOP SECTION ] -->
      <div class="px-20 pt-16 pb-6 flex flex-col justify-start relative border-b border-black/5 shrink-0">
        <h1 class="text-[32px] font-recoleta font-bold leading-tight max-w-3xl mb-14">
            DataDocks is the enterprise dock scheduling software trusted by the world's most demanding supply chains to keep their goods moving.
        </h1>

        <!-- Trust Anchor -->
        <div class="space-y-6 opacity-80 brightness-0">
          <div class="flex items-center justify-around gap-6">
            <img src="/images/Pepsi_2023.svg" class="w-[58px] h-[58px] object-contain shrink-0" alt="Pepsi" />
            <img src="/images/conagra.svg" class="w-[84px] h-[58px] object-contain shrink-0" alt="Conagra" />
            <img src="/images/Group-1.svg" class="w-[110px] h-[36px] object-contain shrink-0" alt="HelloFresh" />
            <img src="/images/Colavita_logo.svg" class="w-[155px] h-[28px] object-contain shrink-0" alt="Colavita" />
          </div>
          <div class="flex items-center justify-around gap-6 px-12">
            <img src="/images/signature_brands.png" class="w-[58px] h-[58px] object-contain shrink-0 grayscale brightness-0" alt="Signature Brands" />
            <img src="/images/gwfg-logo-white.svg" class="w-[98px] h-[48px] object-contain shrink-0 brightness-0" alt="Golden West" />
            <img src="/images/axon-logo.svg" class="w-[155px] h-[32px] object-contain shrink-0" alt="Axon" />
          </div>
        </div>
      </div>

      <!-- [ THE PRODUCT SECTION ] -->
      <div class="flex-grow min-h-0 px-10 py-4 relative flex flex-col justify-center">
        <!-- Visual depth without hard background cuts -->
        <div class="absolute inset-0 bg-gradient-to-b from-transparent via-black/[0.015] to-transparent pointer-events-none"></div>
        
        <!-- Product Visual Anchor -->
        <div class="relative mb-8 w-full max-w-[95%] mx-auto flex items-center justify-center">
          <!-- Geometric Stacked Glow (Zero-Blur, 100% PDF Stable) -->
          <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
             <div class="absolute w-[10%] h-[10%] bg-[#FE5000]/5 rounded-full"></div>
             <div class="absolute w-[20%] h-[20%] bg-[#FE5000]/4 rounded-full"></div>
             <div class="absolute w-[30%] h-[30%] bg-[#FE5000]/3 rounded-full"></div>
             <div class="absolute w-[40%] h-[40%] bg-[#FE5000]/3 rounded-full"></div>
             <div class="absolute w-[50%] h-[50%] bg-[#FE5000]/2 rounded-full"></div>
             <div class="absolute w-[60%] h-[60%] bg-[#FE5000]/2 rounded-full"></div>
             <div class="absolute w-[70%] h-[70%] bg-[#FE5000]/1 rounded-full"></div>
             <div class="absolute w-[80%] h-[80%] bg-[#FE5000]/1 rounded-full"></div>
             <div class="absolute w-[90%] h-[90%] bg-[#FE5000]/1 rounded-full"></div>
             <div class="absolute w-[100%] h-[100%] bg-[#FE5000]/1 rounded-full"></div>
             <div class="absolute w-[110%] h-[110%] bg-[#FE5000]/1 rounded-full"></div>
          </div>
          
          <!-- Geometric Stacked Shadow (Zero-Blur Elevation) -->
          <div class="absolute inset-x-8 top-12 -bottom-12 pointer-events-none">
             <div class="absolute inset-0 bg-black/[0.02] rounded-3xl translate-y-2 scale-[1.02]"></div>
             <div class="absolute inset-0 bg-black/[0.02] rounded-3xl translate-y-4 scale-[1.04]"></div>
             <div class="absolute inset-0 bg-black/[0.01] rounded-3xl translate-y-6 scale-[1.06]"></div>
          </div>

          <!-- OSX MOCKUP -->
          <div class="relative bg-white rounded-2xl border border-black/10 overflow-hidden w-full">
            <div class="bg-[#f2f2f2] px-6 py-3.5 flex items-center justify-between border-b border-[#ddd]">
              <div class="flex gap-2">
                <div class="w-2.5 h-2.5 rounded-full bg-[#ff5f56]"></div>
                <div class="w-2.5 h-2.5 rounded-full bg-[#ffbd2e]"></div>
                <div class="w-2.5 h-2.5 rounded-full bg-[#27c93f]"></div>
              </div>
              <div class="text-[9px] font-sans font-bold opacity-30 uppercase tracking-[0.2em]">Live_Facility_Operations_View</div>
              <div class="flex gap-3">
                 <div class="bg-[#FE5000] text-white pl-2 pr-3 py-1 rounded-none border-l-4 border-white/60 text-[8px] font-black font-sans tracking-widest flex items-center">REAL-TIME SYNC</div>
                 <div class="bg-black text-white pl-2 pr-3 py-1 rounded-none border-l-4 border-[#FE5000] text-[8px] font-black font-sans tracking-widest flex items-center">CAPACITY OPTIMIZED</div>
              </div>
            </div>
            
            <div class="bg-white">
                <img src="/images/cropped-screenshot.png" class="w-full h-auto max-h-[340px] object-top object-contain block" alt="DataDocks UI Orchestrator" />
            </div>
          </div>
        </div>

        <!-- How We Help -->
        <div class="grid grid-cols-3 gap-12 mt-6 relative z-10">
          <div class="space-y-4">
            <h3 class="text-xl font-bruta font-bold uppercase tracking-[-0.02em] text-[#FE5000]">Cold-Chain Integrity</h3>
            <p class="font-sans text-[13px] leading-relaxed text-[#333]">
              Save fuel and protect temperature compliance by eliminating unnecessary wait times for refrigerated trailers.
            </p>
          </div>
          <div class="space-y-4">
            <h3 class="text-xl font-bruta font-bold uppercase tracking-[-0.02em] text-[#FE5000]">Throughput & Labor</h3>
            <p class="font-sans text-[13px] leading-relaxed text-[#333]">
              Process higher volumes without adding doors by matching dock activity directly to your active labor capacity.
            </p>
          </div>
          <div class="space-y-4">
            <h3 class="text-xl font-bruta font-bold uppercase tracking-[-0.02em] text-[#FE5000]">Yard Management</h3>
            <p class="font-sans text-[13px] leading-relaxed text-[#333]">
              Eliminate driver detention fees with a single source of truth that replaces chaotic gate queues with scheduled precision.
            </p>
          </div>
        </div>
      </div>

      <!-- FOOTER -->
      <div class="px-12 pb-8 pt-4 bg-transparent relative z-10 shrink-0">
        <div class="h-px bg-black opacity-20 w-full mb-2"></div>
        <div class="flex justify-between items-baseline text-[9px] font-bold uppercase tracking-widest text-black font-sans">
            <span>Prepared for: Consulate General of Canada in Dallas</span>
            <div class="flex gap-4">
                <span>v1.2 - Q2 2026</span>
                <span class="opacity-40">|</span>
                <span>Page 01</span>
            </div>
        </div>
      </div>
    </section>

    <!-- PAGE 2: THE DILIGENCE & THE HANDOFF -->
    <section class="page shadow-2xl relative overflow-hidden bg-[#FFF8E9] text-[#000000] flex flex-col font-sans">
      <!-- HEADER -->
      <div class="px-12 pt-8 pb-0 shrink-0">
        <div class="flex justify-between items-end text-black mb-1">
            <span class="text-[9px] font-bold uppercase tracking-[0.2em] font-sans opacity-40 translate-y-[2px]">Capabilities Statement: Food Production & Distribution.</span>
            <div class="flex items-center gap-3 translate-y-[1px]">
                <img src="/_offline_print/Brand-Collateral/datadocks-lockup-black.svg" class="h-[18px] w-auto" alt="DataDocks" />
            </div>
        </div>
        <div class="h-px bg-black opacity-20 w-full"></div>
      </div>

      <!-- [ THE DILIGENCE SECTION ] -->
      <div class="px-20 pt-12 pb-6 relative flex flex-col flex-grow">
        <div class="grid grid-cols-[1.4fr_1fr] gap-x-16 gap-y-10 mb-8">
           <!-- LEFT: Enterprise Security -->
           <div class="space-y-16">
              <div>
                <p class="text-[13px] font-bold text-[#FE5000] uppercase tracking-[0.2em] mb-4 font-sans">Enterprise Security</p>
                <div class="flex items-center gap-6">
                   <img src="/images/21972-312_SOC_NonCPA.png" class="h-24 w-auto shrink-0" alt="SOC2 Certified" />
                   <div class="space-y-1">
                     <p class="text-[17px] font-recoleta font-bold text-black leading-tight">SOC2 Type II Compliant</p>
                     <p class="text-[13.5px] leading-relaxed text-[#222] font-sans pr-8">Encrypted infrastructure guaranteeing absolute data privacy.</p>
                   </div>
                </div>
              </div>
              <div>
                <p class="text-[13px] font-bold text-[#FE5000] uppercase tracking-[0.2em] mb-4 font-sans">Infrastructure Connectivity</p>
                <p class="text-[13.5px] leading-relaxed text-[#222] font-sans max-w-sm">
                  Native cloud architecture built for seamless integration with existing <strong>WMS</strong> and <strong>ERP</strong> systems via REST APIs or EDI.
                </p>
              </div>
           </div>

           <!-- RIGHT: Scale & Reliability -->
           <div class="pl-12 border-l border-black/10 flex flex-col">
              <p class="text-[13px] font-bold text-[#FE5000] uppercase tracking-[0.2em] mb-5 font-sans">Scale & Reliability</p>
              
              <div class="flex flex-col space-y-6 pb-1">
                 <div>
                    <h3 class="text-[32px] font-recoleta font-bold text-black tracking-tight leading-none mb-1">5.5M+</h3>
                    <p class="text-[10px] font-sans font-bold text-black/40 uppercase tracking-[0.15em]">Appointments Yearly</p>
                 </div>

                 <div>
                    <h3 class="text-[32px] font-recoleta font-bold text-black tracking-tight leading-none mb-1">99.9%</h3>
                    <p class="text-[10px] font-sans font-bold text-black/40 uppercase tracking-[0.15em]">Historical Uptime</p>
                 </div>

                 <div>
                    <h3 class="text-[32px] font-recoleta font-bold text-black tracking-tight leading-none mb-1">100k+</h3>
                    <p class="text-[10px] font-sans font-bold text-black/40 uppercase tracking-[0.15em]">Carriers on the Platform</p>
                 </div>

                 <div>
                    <h3 class="text-[32px] font-recoleta font-bold text-black tracking-tight leading-none mb-1">1,000+</h3>
                    <p class="text-[10px] font-sans font-bold text-black/40 uppercase tracking-[0.15em]">Global Facilities</p>
                 </div>
              </div>
           </div>
        </div>

        <!-- Resilience Header -->
        <div class="mt-auto pb-6">
            <h2 class="text-center font-bruta text-5xl font-extrabold uppercase tracking-[-0.02em] text-black">
              Making North American Supply Chains More Resilient
            </h2>
        </div>
      </div>

      <!-- [ THE CAPABILITIES & HANDOFF ] -->
      <div class="px-20 pt-8 pb-10 bg-black/5 border-t border-black/5 flex flex-col flex-grow justify-between">
        <div class="grid grid-cols-2 gap-16 items-start">
          <div>
            <p class="text-xl font-recoleta font-bold text-[#FE5000] mb-6">Platform Capabilities</p>
            <ul class="space-y-4">
               <li class="flex items-start gap-4">
                  <div class="mt-2 w-1.5 h-1.5 rounded-full bg-[#FE5000] shrink-0"></div>
                  <p class="text-base font-bold font-sans">Real Time Visibility & Audit Trail</p>
               </li>
               <li class="flex items-start gap-4">
                  <div class="mt-2 w-1.5 h-1.5 rounded-full bg-[#FE5000] shrink-0"></div>
                  <p class="text-base font-bold font-sans">Carrier appointment booking portal.</p>
               </li>
               <li class="flex items-start gap-4">
                  <div class="mt-2 w-1.5 h-1.5 rounded-full bg-[#FE5000] shrink-0"></div>
                  <p class="text-base font-bold font-sans">Customizable Automation Rules</p>
               </li>
            </ul>
          </div>
          <div>
            <p class="text-xl font-recoleta font-bold text-[#FE5000] mb-6">Support Commitment</p>
            <p class="text-[15.5px] leading-relaxed text-[#222] font-sans font-medium">
              We take customer success seriously, delivering comprehensive onboarding and rapid-response technical support designed for minimal disruption to daily operations.
            </p>
          </div>
        </div>

        <!-- Handoff Section -->
        <div class="pt-8 border-t border-black/10">
           <div class="flex justify-between items-end">
              <div>
                 <p class="text-[10px] font-bold text-[#FE5000] tracking-[0.3em] uppercase font-sans mb-1">Point of Contact</p>
                 <h2 class="text-[38px] font-recoleta font-bold text-black tracking-tight leading-none mb-1">Nick Rakovsky</h2>
                 <p class="text-sm font-sans text-black/50 font-medium">sales@datadocks.com</p>
              </div>
              
              <div class="text-right flex flex-col items-end">
                 <div class="text-[42px] font-recoleta font-semibold text-[#FE5000] tracking-tight leading-none">datadocks.com</div>
                 <p class="text-[11px] font-bold uppercase tracking-[0.2em] text-black/30 font-sans mt-1">Enterprise Dock Scheduling</p>
              </div>
           </div>
        </div>
      </div>

      <!-- FOOTER (Unified with darker background) -->
      <div class="px-12 pb-8 pt-4 bg-black/5 shrink-0">
        <div class="h-px bg-black opacity-20 w-full mb-2"></div>
        <div class="flex justify-between items-baseline text-[9px] font-bold uppercase tracking-widest text-black font-sans">
            <span>Prepared for: Consulate General of Canada in Dallas</span>
            <div class="flex gap-4">
                <span>v1.2 - Q2 2026</span>
                <span class="opacity-40">|</span>
                <span>Page 02</span>
            </div>
        </div>
      </div>
    </section>

    <!-- UI Overlay container -->
    <div class="fixed bottom-8 right-8 print:hidden">
      <button onclick="window.print()" class="bg-[#FE5000] text-white px-8 py-4 rounded-full font-bold shadow-xl shadow-[#FE5000]/40 hover:scale-105 transition-all flex items-center gap-2 group">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 group-hover:rotate-12 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M9 19l3 3m0 0l3-3m-3 3V10" />
        </svg>
        Generate marketing_proposal.pdf
      </button>
    </div>
  </div>
</PrintLayout>

<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700;800;900&display=swap');

  @media screen {
    body {
      background-color: #262626;
      padding: 60px 0;
    }
    .pdf-container {
      max-width: 210mm;
      margin: 0 auto;
      display: flex;
      flex-direction: column;
      gap: 60px;
    }
    .page {
      width: 210mm;
      height: 297mm;
    }
  }

  @media print {
    body {
      background-color: transparent;
      padding: 0;
    }
    .page {
      width: 210mm;
      height: 297mm;
      break-after: page;
      margin: 0;
      box-shadow: none !important;
    }
    img {
      image-rendering: -webkit-optimize-contrast;
    }
  }

  h1, h2, h3, .font-recoleta {
    font-family: 'Recoleta', serif;
  }
  
  .font-bruta {
    font-family: 'Bruta', sans-serif;
  }

  .font-sans, .font-inter {
    font-family: 'Inter', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
  }
</style>
