---
// 1. Imports
import Layout from './Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import { Image } from 'astro:assets';
import { getFriendlyDate } from '../utils/dateFormatter';
import { getAuthor } from '../data/authors';
import { getEntry } from 'astro:content';
import RelatedFeatureCallout from '../components/RelatedFeatureCallout.astro';
import LeadCaptureWidget from '../components/LeadCaptureWidget.astro';
import LeadMagnetForm from '../components/LeadMagnetForm.astro';
import SidebarShortVideo from '../components/SidebarShortVideo.astro';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

const { frontmatter, headings = [] as Heading[], relatedPosts = [] } = Astro.props;
const h2Headings = headings.filter((h: Heading) => h.depth === 2);

// 2. Date Formatting
const formattedDate = getFriendlyDate(frontmatter.pubDate);

const formattedUpdatedDate = frontmatter.updatedDate 
  ? getFriendlyDate(frontmatter.updatedDate)
  : null;

// 3. Dynamic Reading Time Range Formula
const htmlContent = await Astro.slots.render('default');
const plainText = htmlContent.replace(/<[^>]+>/g, '').trim();
const wordCount = plainText ? plainText.split(/\s+/).length : 0;
// Using 250 wpm for fast readers, 180 wpm for relaxed readers
const minReadingTime = Math.max(1, Math.floor(wordCount / 250));
const maxReadingTime = Math.max(1, Math.ceil(wordCount / 180));
const calculatedReadTime = minReadingTime === maxReadingTime 
  ? `${minReadingTime} min read` 
  : `${minReadingTime}-${maxReadingTime} min read`;

const finalReadTime = frontmatter.readTime || calculatedReadTime;

// 4. Author Data
const author = getAuthor(frontmatter.author);

// 5. Related Feature Data
let relatedFeatureEntry = null;
if (frontmatter.relatedFeature) {
  if (typeof frontmatter.relatedFeature === 'object' && 'id' in frontmatter.relatedFeature) {
    relatedFeatureEntry = await getEntry(frontmatter.relatedFeature);
  } else if (typeof frontmatter.relatedFeature === 'string') {
    relatedFeatureEntry = await getEntry('features', frontmatter.relatedFeature);
  }
}

const relatedFeatureEntries = [];
if (frontmatter.relatedFeatures?.length) {
  for (const ref of frontmatter.relatedFeatures) {
    const entry = typeof ref === 'object' && 'id' in ref ? await getEntry(ref) : await getEntry('features', ref);
    if (entry) relatedFeatureEntries.push(entry);
  }
} else if (relatedFeatureEntry) {
  relatedFeatureEntries.push(relatedFeatureEntry); // Fallback to singular for backwards compatibility
}

const benefitsData: Record<string, {title: string, desc: string, icon: string}> = {
  'increase-capacity': { title: 'Increase Capacity', desc: 'Eliminate bottlenecks and slash overtime costs. DataDocks optimizes your appointment slots based on actual load times.', icon: '/images/features/linechart-file.svg' },
  'digitize-operations': { title: 'Digitize Operations', desc: 'Move away from paper and spreadsheets. Get real-time visibility into your yard and docks.', icon: '/images/features/checked-laptop.svg' },
  'delight-carriers': { title: 'Delight Carriers', desc: 'Become a shipper of choice. Give carriers a self-serve portal to book appointments 24/7.', icon: '/images/features/people.svg' },
  'see-everything': { title: 'See Everything', desc: 'A single dashboard for all your operations. Connect your teams with live updates.', icon: '/images/features/vision.svg' }
};

const relatedBenefits = (frontmatter.relatedBenefits || []).map((b: string) => {
  const bData = benefitsData[b];
  if (bData) {
    return {
      id: b,
      title: `${bData.title} with DataDocks`,
      description: bData.desc,
      icon: bData.icon,
      url: `/benefits/${b}`
    };
  }
  return null;
}).filter(Boolean);

// 6. LCP Optimisation
// Detect YouTube embeds — only load lite-yt JS when actually needed
const hasYouTube = htmlContent.includes('lite-youtube') || htmlContent.includes('data-smartlink-type="video');

// Find the first priority image rendered by MDXImage for a preload hint in <head>
// MDXImage marks the first body image with fetchpriority="high"; we extract its src
// so the browser can start fetching it before parsing the full body HTML.
let lcpImageSrc: string | null = null;
let lcpImageSrcset: string | null = null;
let lcpImageSizes: string | null = null;
const priorityImgMatch = htmlContent.match(/<img[^>]+fetchpriority="high"[^>]*>/);
if (priorityImgMatch) {
  const img = priorityImgMatch[0];
  const srcM = img.match(/[\s]src="([^"]+)"/);
  const srcsetM = img.match(/[\s]srcset="([^"]+)"/);
  const sizesM = img.match(/[\s]sizes="([^"]+)"/);
  if (srcM) lcpImageSrc = srcM[1];
  if (srcsetM) lcpImageSrcset = srcsetM[1];
  if (sizesM) lcpImageSizes = sizesM[1];
}
---

<Layout
  title={`${frontmatter.title} | DataDocks`}
  description={frontmatter.description}
  image={typeof frontmatter.cardImage === 'string' ? frontmatter.cardImage : frontmatter.cardImage?.src}
  type="article"
  articleData={{
    author: frontmatter.author,
    pubDate: frontmatter.pubDate,
    updatedDate: frontmatter.updatedDate,
    section: frontmatter.category
  }}
  schemaData={frontmatter.faq ? { faq: frontmatter.faq } : undefined}
>
  {/* Head slot: LCP image preload + conditional lite-youtube CSS */}
  <Fragment slot="head">
    {lcpImageSrc && (
      <link
        rel="preload"
        as="image"
        href={lcpImageSrc}
        {...(lcpImageSrcset ? { imagesrcset: lcpImageSrcset } : {})}
        {...(lcpImageSizes ? { imagesizes: lcpImageSizes } : {})}
        fetchpriority="high"
      />
    )}
    {hasYouTube && (
      <style is:inline>lite-youtube{background-color:#000;position:relative;display:block;contain:content;background-position:center center;background-size:cover;cursor:pointer;max-width:720px}lite-youtube::before{content:attr(data-title);display:block;position:absolute;top:0;background-image:linear-gradient(180deg,rgb(0 0 0/67%) 0%,rgb(0 0 0/54%) 14%,rgb(0 0 0/15%) 54%,rgb(0 0 0/5%) 72%,rgb(0 0 0/0%) 94%);height:99px;width:100%;font-family:"YouTube Noto",Roboto,Arial,Helvetica,sans-serif;color:hsl(0deg 0% 93.33%);text-shadow:0 0 2px rgba(0,0,0,.5);font-size:18px;padding:25px 20px;overflow:hidden;white-space:nowrap;text-overflow:ellipsis;box-sizing:border-box}lite-youtube:hover::before{color:#fff}lite-youtube::after{content:"";display:block;padding-bottom:calc(100% / (16 / 9))}lite-youtube>iframe{width:100%;height:100%;position:absolute;top:0;left:0;border:0}lite-youtube>.lty-playbtn{display:block;width:100%;height:100%;background:no-repeat center/68px 48px;background-image:url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 68 48"><path d="M66.52 7.74c-.78-2.93-2.49-5.41-5.42-6.19C55.79.13 34 0 34 0S12.21.13 6.9 1.55c-2.93.78-4.63 3.26-5.42 6.19C.06 13.05 0 24 0 24s.06 10.95 1.48 16.26c.78 2.93 2.49 5.41 5.42 6.19C12.21 47.87 34 48 34 48s21.79-.13 27.1-1.55c2.93-.78 4.64-3.26 5.42-6.19C67.94 34.95 68 24 68 24s-.06-10.95-1.48-16.26z" fill="red"/><path d="M45 24 27 14v20" fill="white"/></svg>');position:absolute;cursor:pointer;z-index:1;filter:grayscale(100%);transition:filter .1s cubic-bezier(0,0,0.2,1);border:0}lite-youtube:hover>.lty-playbtn,lite-youtube .lty-playbtn:focus{filter:none}lite-youtube.lyt-activated{cursor:unset}lite-youtube.lyt-activated::before,lite-youtube.lyt-activated>.lty-playbtn{opacity:0;pointer-events:none}.lyt-visually-hidden{clip:rect(0 0 0 0);clip-path:inset(50%);height:1px;overflow:hidden;position:absolute;white-space:nowrap;width:1px}</style>
    )}
  </Fragment>
  <div class="min-h-screen flex flex-col">
    <a href="#content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 bg-[#fd4f00] text-white px-4 py-2 rounded-lg z-[100] font-bold">Skip to content</a>
    <Navigation />

    <main class="flex-grow w-full bg-[#FFF8E9] dark:bg-gray-900 font-recoleta text-gray-800 dark:text-gray-200 transition-colors duration-300">
      
      <div class="w-full max-w-7xl mx-auto px-4 md:px-12 pt-12 lg:pt-16 pb-12">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 items-center">
          
          <div class={`flex flex-col text-left ${frontmatter.heroFigure ? 'lg:col-span-7' : 'lg:col-span-12 w-full'} items-start order-2 lg:order-1`}>
            
            <div class="font-recoleta text-black dark:text-gray-200 text-xl md:text-2xl font-bold mb-4 transition-colors duration-300">
              {frontmatter.category || "Logistics & Supply Chain"}
            </div>
            
            <div class="relative inline-block mb-6 w-full">
              <h1 class="text-5xl md:text-6xl lg:text-7xl font-bruta uppercase text-[#fd4f00] dark:text-[#ff7635] leading-[1.05] break-words transition-colors duration-300 text-left w-full">
                {frontmatter.title}
              </h1>
              

            </div>
            
            <div class="flex flex-wrap items-center gap-x-6 gap-y-4 py-5 border-y-2 border-[#E5D3B3] dark:border-gray-800 mt-2 transition-colors duration-300 w-full justify-start">
              <div class="flex flex-col">
                <div class="font-bold text-black dark:text-white text-lg transition-colors duration-300">{author.name}</div>
                <div class="text-sm text-gray-500 dark:text-gray-400 transition-colors duration-300">{author.role}</div>
                <div class="text-xs text-gray-400 dark:text-gray-500 mt-1 max-w-md transition-colors duration-300">{author.shortBio}</div>
              </div>
              
              <div class="flex flex-col text-sm text-gray-600 dark:text-gray-400 transition-colors duration-300">
                <span>First Published: {formattedDate}</span>
                {formattedUpdatedDate && (
                  <span>Last Updated: {formattedUpdatedDate}</span>
                )}
              </div>
              
              <div class="text-sm font-bold text-gray-500 dark:text-gray-300 bg-[#F8EDD9] dark:bg-gray-800 px-3 py-1 rounded-full border border-transparent dark:border-gray-700 transition-colors duration-300">
                {finalReadTime}
              </div>
              
              <div class={`flex gap-2 ${frontmatter.heroFigure ? 'ml-auto' : ''}`}>
                <button id="theme-toggle" class="w-10 h-10 rounded-full border-2 border-[#E5D3B3] dark:border-gray-700 flex items-center justify-center hover:bg-white dark:hover:bg-gray-800 transition-all duration-300 group" title="Toggle Theme" aria-label="Toggle between dark and light mode">
                  <svg class="w-5 h-5 text-gray-700 dark:text-gray-300 block dark:hidden group-hover:text-[#fd4f00] transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path></svg>
                  <svg class="w-5 h-5 text-gray-700 dark:text-gray-300 hidden dark:block group-hover:text-[#ff7635] transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
                </button>
                <button id="text-size-toggle" class="w-10 h-10 rounded-full border-2 border-[#E5D3B3] dark:border-gray-700 flex items-center justify-center hover:bg-white dark:hover:bg-gray-800 transition-all duration-300 font-bruta font-bold text-gray-700 dark:text-gray-300 hover:text-[#fd4f00] dark:hover:text-[#ff7635]" title="Toggle Text Size" aria-label="Toggle between normal and larger text sizes">
                  Aa
                </button>
              </div>
            </div>
          </div>
          
          {frontmatter.heroFigure && (
            <div class="w-full lg:col-span-5 relative order-1 lg:order-2 mb-8 lg:mb-0 hidden lg:block">
              <div class="w-full aspect-[4/5] flex items-center justify-center overflow-visible">
                <Image
                  src={frontmatter.heroFigure}
                  alt={`Illustration for ${frontmatter.title}`}
                  loading="eager"
                  widths={[360, 540, 720, 1024]}
                  sizes="(max-width: 768px) 100vw, 500px"
                  class="w-full h-full object-contain drop-shadow-[0_20px_20px_rgba(0,0,0,0.15)] dark:drop-shadow-[0_20px_20px_rgba(0,0,0,0.4)] transition-all duration-300"
                />
              </div>
            </div>
          )}
          
        </div>
      </div>
      
      <div class="w-full max-w-7xl mx-auto px-4 md:px-12 pb-24 relative lg:flex lg:items-start lg:gap-8 xl:gap-12">
        
        {/* Desktop Side TOC (Visible on LG+) */}
        <aside id="desktop-toc" class="desktop-toc-container hidden lg:block w-48 xl:w-56 flex-shrink-0 sticky bottom-12 self-end z-20 pr-4" aria-label="Table of Contents">
          {h2Headings.length > 0 && (
            <div class="space-y-6">
              <div class="space-y-2">
                <p class="font-bruta uppercase text-[#fd4f00] dark:text-[#ff7635] text-sm font-bold tracking-widest" aria-hidden="true">Contents</p>
                <div class="w-8 h-1 bg-[#fd4f00] dark:bg-[#ff7635] opacity-30"></div>
              </div>
              <nav aria-label="Table of contents">
                <ul class={`space-y-4 ${h2Headings.length > 12 ? '!space-y-1' : h2Headings.length > 7 ? '!space-y-2' : ''}`}>
                  {h2Headings.map((heading: Heading) => (
                    <li>
                      <a 
                        href={`#${heading.slug}`} 
                        class={`toc-link block font-recoleta font-medium text-gray-500 dark:text-gray-400 hover:text-[#fd4f00] dark:hover:text-[#ff7635] transition-all duration-200 line-clamp-2 border-l-2 border-transparent pl-4 ${h2Headings.length > 12 ? 'text-[11px] py-0.5 leading-tight' : h2Headings.length > 7 ? 'text-xs py-1 leading-snug' : 'text-sm py-1'}`}
                      >
                        {heading.text}
                      </a>
                    </li>
                  ))}
                </ul>
              </nav>
            </div>
          )}
        </aside>

        {/* Main Content Area */}
        <div class="w-full min-w-0 max-w-2xl xl:max-w-3xl lg:mx-0 flex-grow relative">
          {/* Static TOC for Mobile */}
          {h2Headings.length > 0 && (
            <div class="lg:hidden relative z-40 mb-12">
              <details class="group bg-[#F8EDD9] dark:bg-gray-800 rounded-xl border border-[#E5D3B3] dark:border-gray-700 transition-colors duration-300 mobile-toc-details">
                <summary class="list-none cursor-pointer p-4 flex items-center justify-between outline-none">
                  <span class="font-bruta uppercase text-[#fd4f00] dark:text-[#ff7635] font-bold tracking-wider text-sm">Table of Contents</span>
                  <svg class="w-5 h-5 text-[#fd4f00] transition-transform duration-300 group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
                </summary>
                <div class="absolute left-0 right-0 top-full mt-2 bg-[#F8EDD9] dark:bg-gray-800 rounded-xl border border-[#E5D3B3] dark:border-gray-700 shadow-xl p-4 z-50 max-h-[60vh] overflow-y-auto">
                  <nav aria-label="Table of contents (mobile)">
                    <ul class="space-y-3">
                      {h2Headings.map((heading: Heading) => (
                        <li>
                          <a href={`#${heading.slug}`} class="mobile-toc-link block text-sm text-gray-700 dark:text-gray-300 font-recoleta hover:text-[#fd4f00] dark:hover:text-[#ff7635] transition-colors border-l-2 border-transparent pl-3">
                            {heading.text}
                          </a>
                        </li>
                      ))}
                    </ul>
                  </nav>
                </div>
              </details>
            </div>
          )}
        <article id="content" class="prose prose-lg md:prose-xl w-full max-w-none break-words transition-all duration-500
          dark:prose-invert 
          prose-h1:font-bruta prose-h1:text-[#fd4f00] dark:prose-h1:text-[#ff7635]
          prose-h2:font-recoleta prose-h2:text-3xl prose-h2:font-bold prose-h2:text-black dark:prose-h2:text-white
          prose-h3:font-recoleta prose-h3:text-2xl prose-h3:font-bold prose-h3:text-black dark:prose-h3:text-white
          prose-h4:font-bruta prose-h4:text-black dark:prose-h4:text-white prose-h4:text-xl
          prose-p:font-recoleta prose-p:leading-relaxed 
          prose-a:text-[#fd4f00] dark:prose-a:text-[#ff7635] prose-a:font-semibold hover:prose-a:underline
          prose-img:rounded-xl prose-img:w-full prose-img:border-0 prose-img:ring-0 prose-img:outline-none
          prose-strong:text-gray-900 dark:prose-strong:text-white prose-strong:font-bold
          prose-table:block prose-table:overflow-x-auto prose-table:w-full">
          
          {/* If there's a mobile view, we could also render the heroFigure inline before the content, but leaving it clean for now */}
          {frontmatter.heroFigure && (
            <div class="w-full mb-8 lg:hidden">
              <Image
                src={frontmatter.heroFigure}
                alt={`Illustration for ${frontmatter.title}`}
                loading="eager"
                widths={[360, 540, 720, 1024]}
                sizes="(max-width: 768px) 100vw, 500px"
                class="w-full max-h-[40vh] object-contain drop-shadow-md dark:drop-shadow-[0_10px_10px_rgba(0,0,0,0.4)] mx-auto transition-all duration-300"
              />
            </div>
          )}
          
          <Fragment set:html={htmlContent} />
        </article>

        {frontmatter.leadCapture && (
          <div class="block lg:hidden mt-12 w-full max-w-xl mx-auto">
            <LeadMagnetForm {...frontmatter.leadCapture} />
          </div>
        )}
      </div>

      {/* Right Sidebar (Visible on LG+) */}
      <aside id="blog-right-sidebar" class="hidden lg:block w-60 xl:w-64 flex-shrink-0 relative self-stretch" aria-label="Related Resources">
        {/* Hidden Fallback Data for SmartLink script */}
        <div 
          id="smartlink-fallback-data" 
          class="hidden" 
          data-features={JSON.stringify(relatedFeatureEntries.map(e => ({
            id: e.slug,
            title: e.data.title,
            description: e.data.description,
            icon: e.data.icon ? e.data.icon.replace(new RegExp('/([0-9a-fA-F]{24})_'), '/') : '',
            url: `/datadocks-features/${e.slug}`
          })))}
          data-benefits={JSON.stringify(relatedBenefits)}
        ></div>
        
        {frontmatter.leadCapture && (
          <LeadCaptureWidget {...frontmatter.leadCapture} />
        )}
        
        {frontmatter.relatedShortVideo && (
          <SidebarShortVideo videoId={frontmatter.relatedShortVideo} />
        )}
      </aside>
    </div>

    {relatedPosts.length > 0 && (
      <section class="w-full max-w-7xl mx-auto px-4 md:px-12 pb-24 border-t border-[#E5D3B3] dark:border-gray-800 pt-16 mt-8">
        <div class="flex flex-col md:flex-row md:items-end md:justify-between mb-10 gap-4">
          <div>
            <h2 class="font-bruta uppercase text-black dark:text-white text-3xl md:text-4xl font-bold tracking-tight mb-4">Related Content</h2>
            <div class="w-16 h-1 bg-[#fd4f00]"></div>
          </div>
          <a href="/posts" class="text-[#fd4f00] font-recoleta font-bold flex items-center gap-2 hover:underline">
            View all resources
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
          </a>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {relatedPosts.map((item: any) => {
            const isVideo = item.collection === 'videos' || (item.data.postType?.discriminant === 'video' || item.data.postType?.discriminant === 'short');
            const href = item.collection === 'videos' ? `/videos/${item.slug}` : `/posts/${item.slug}`;
            
            return (
              <a href={href} class="group flex flex-col bg-white dark:bg-gray-800 rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-500 border border-[#E5D3B3] dark:border-gray-700 hover:-translate-y-1">
                {/* Image / Thumbnail */}
                <div class="relative aspect-[16/10] overflow-hidden bg-gray-100 dark:bg-gray-900">
                  {item.data.cardImage ? (
                    <Image 
                      src={item.data.cardImage} 
                      alt={item.data.cardAlt || item.data.title}
                      width={600}
                      height={375}
                      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                    />
                  ) : isVideo && item.data.postType?.value?.youtubeId ? (
                    <img 
                      src={`https://i.ytimg.com/vi/${item.data.postType.value.youtubeId}/hqdefault.jpg`} 
                      alt={item.data.title}
                      class="w-full h-full object-cover opacity-80 group-hover:opacity-100 transition-opacity"
                    />
                  ) : (
                    <div class="w-full h-full flex items-center justify-center bg-[#FBC3AD]/30">
                      <svg class="w-12 h-12 text-[#fd4f00] opacity-20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" /></svg>
                    </div>
                  )}
                  {isVideo && (
                    <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity bg-black/20">
                      <div class="w-12 h-12 bg-[#fd4f00] rounded-full flex items-center justify-center text-white">
                        <svg class="w-6 h-6 ml-1" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                      </div>
                    </div>
                  )}
                </div>

                <div class="p-6 flex flex-col flex-grow">
                  <div class="flex items-center justify-between mb-3">
                    <span class="text-[10px] font-bold uppercase tracking-widest text-[#fd4f00] bg-[#fd4f00]/5 px-2 py-1 rounded">
                      {item.data.category || 'Logistics'}
                    </span>
                    <span class="text-[10px] font-bold uppercase tracking-widest text-gray-400">
                      {isVideo ? 'Video' : 'Article'}
                    </span>
                  </div>
                  <h3 class="font-recoleta text-lg md:text-xl font-bold text-gray-900 dark:text-white group-hover:text-[#fd4f00] transition-colors leading-tight mb-3 line-clamp-2">
                    {item.data.title}
                  </h3>
                  <p class="text-sm text-gray-600 dark:text-gray-400 line-clamp-2 mb-4">
                    {item.data.description}
                  </p>
                  <div class="mt-auto pt-4 border-t border-gray-100 dark:border-gray-700 flex items-center justify-between">
                    <span class="text-[11px] font-medium text-gray-500">{isVideo ? 'Watch Now' : 'Read More'}</span>
                    <svg class="w-4 h-4 text-[#fd4f00] transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
                  </div>
                </div>
              </a>
            );
          })}
        </div>
      </section>
    )}

    </main>

    <Footer />

    {/* lite-yt-embed.css is already inlined in Layout.astro — no external load needed.
         lite-yt-embed.js is only needed when the post actually contains a YouTube embed. */}
    {hasYouTube && (
      <script is:inline src="/css/lite-yt-embed.js" defer></script>
    )}

    <script is:inline>
      // Immediately apply theme preference to avoid FOUC
      (function() {
        try {
          const dflt = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
          const savedTheme = localStorage.getItem('theme');
          if (savedTheme === 'dark' || (!savedTheme && dflt === 'dark')) {
            document.documentElement.classList.add('dark');
          } else {
            document.documentElement.classList.remove('dark');
          }
        } catch (e) {
          // LocalStorage might be unavailable in some browser settings
        }
      })();

      function setupBlogInteractions() {
        // Theme Toggle Logic
        const themeToggle = document.getElementById('theme-toggle');
        if (themeToggle) {
          themeToggle.onclick = () => {
            document.documentElement.classList.toggle('dark');
            const isDark = document.documentElement.classList.contains('dark');
            localStorage.setItem('theme', isDark ? 'dark' : 'light');
          };
        }

        // Text Size Toggle Logic
        const textSizeToggle = document.getElementById('text-size-toggle');
        const article = document.getElementById('content');

        // Check initial text scale
        try {
          if (localStorage.getItem('text-scaled') === 'true') {
            article?.classList.add('text-scaled');
          } else {
            article?.classList.remove('text-scaled');
          }
        } catch (e) {
          // LocalStorage might be unavailable in some browser settings
        }

        if (textSizeToggle) {
          textSizeToggle.onclick = () => {
            article?.classList.toggle('text-scaled');
            const isScaled = article?.classList.contains('text-scaled');
            localStorage.setItem('text-scaled', isScaled ? 'true' : 'false');
          };
        }
      }

      // Run immediately for first load or when script is re-evaluated by Astro
      setupBlogInteractions();

      // Ensure it runs after View Transitions swap
      if (typeof window !== 'undefined' && !window.blogInteractionsSetup) {
        document.addEventListener('astro:after-swap', setupBlogInteractions);
        window.blogInteractionsSetup = true;
      }

      function setupScrollSpy() {
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              const id = entry.target.getAttribute('id');
              if (!id) return;

              document.querySelectorAll('.toc-link, .mobile-toc-link').forEach(link => {
                const isActive = link.getAttribute('href') === `#${id}`;
                link.classList.toggle('active', isActive);
              });
            }
          });
        }, { rootMargin: '0px 0px -75% 0px' });

        document.querySelectorAll('article h2').forEach(h2 => observer.observe(h2));
      }

      function setupMobileToc() {
        const mobileTocLinks = document.querySelectorAll('.mobile-toc-link');
        const detailsElem = document.querySelector('.mobile-toc-details');
        mobileTocLinks.forEach(link => {
          link.addEventListener('click', () => {
            if (detailsElem) {
              detailsElem.removeAttribute('open');
            }
          });
        });
      }

      function setupDesktopTocInteraction() {
        const desktopToc = document.getElementById('desktop-toc');
        if (!desktopToc) return;
        const links = desktopToc.querySelectorAll('.toc-link');
        let timeout;
        links.forEach(link => {
          link.addEventListener('click', () => {
            desktopToc.classList.add('is-active-click');
            clearTimeout(timeout);
            timeout = setTimeout(() => {
              desktopToc.classList.remove('is-active-click');
            }, 50);
          });
        });
      }

      if (typeof window !== 'undefined') {
        setupScrollSpy();
        setupMobileToc();
        setupDesktopTocInteraction();
        document.addEventListener('astro:after-swap', () => {
          setupScrollSpy();
          setupMobileToc();
          setupDesktopTocInteraction();
        });
      }
    </script>

  </div>
</Layout>


<script>
  let hoverTimeout: number | undefined;

  function ensureUIElements() {
    if (document.getElementById('smartlink-scrim')) return;

    // Create Scrim
    const scrim = document.createElement('div');
    scrim.id = 'smartlink-scrim';
    scrim.className = 'fixed inset-0 bg-black/40 hidden z-40 transition-opacity duration-300 opacity-0';
    scrim.setAttribute('aria-hidden', 'true');
    document.body.appendChild(scrim);

    // Create Mobile Sheet
    const sheet = document.createElement('div');
    sheet.id = 'smartlink-mobile-sheet';
    sheet.className = 'fixed bottom-0 inset-x-0 z-50 translate-y-full transition-transform duration-300 bg-[#FFF8E9] dark:bg-gray-800 rounded-none shadow-2xl border-t border-[#E5D3B3] dark:border-gray-700 overflow-hidden not-prose';
    sheet.setAttribute('role', 'dialog');
    sheet.setAttribute('aria-labelledby', 'sl-mobile-title');
    sheet.innerHTML = `
      <div class="w-12 h-1.5 bg-gray-300 dark:bg-gray-600 rounded-none mx-auto mt-3 mb-2"></div>
      <div class="px-6 pb-8 pt-2">
        <h3 id="sl-mobile-title" class="text-2xl font-bruta uppercase text-[#fd4f00] dark:text-[#ff7635] mb-3"></h3>
        <p id="sl-mobile-snippet" class="text-gray-700 dark:text-gray-300 font-recoleta text-lg leading-relaxed mb-6"></p>
        <div id="sl-mobile-actions" class="flex flex-col gap-3"></div>
      </div>
    `;
    document.body.appendChild(sheet);

    // Create Desktop Card
    const card = document.createElement('div');
    card.id = 'smartlink-desktop-card';
    card.className = 'fixed z-50 hidden w-80 bg-white dark:bg-gray-800 shadow-2xl border border-[#E5D3B3] dark:border-gray-700 rounded-none transition-opacity duration-200 opacity-0 group not-prose';
    card.innerHTML = `
      <div class="absolute -inset-y-6 inset-x-0 pointer-events-auto"></div>
      <div class="relative p-4">
        <h3 id="sl-desktop-title" class="font-sans text-sm font-bold text-gray-900 dark:text-white m-0 leading-tight"></h3>
        <p id="sl-desktop-snippet" class="font-sans text-xs text-gray-600 dark:text-gray-400 mt-1 leading-snug"></p>
        <div id="sl-desktop-actions" class="mt-3 flex items-center gap-3"></div>
      </div>
    `;
    document.body.appendChild(card);
  }

  function getActionLinksHTML(type: string, href: string, bibRef: string, isMobile: boolean): string {
    if (type === 'academic') {
      const btnClass = isMobile 
        ? "inline-flex items-center justify-center w-full py-3 px-4 bg-[#fd4f00] text-white rounded-none font-recoleta font-bold text-lg border-b-4 border-transparent hover:bg-black transition-all"
        : "inline-flex items-center gap-1 font-sans text-xs font-semibold text-gray-500 dark:text-gray-400 hover:text-[#fd4f00] dark:hover:text-[#ff7635] hover:underline w-fit";
      const secClass = isMobile
        ? "inline-flex items-center justify-center w-full py-3 px-4 bg-gray-200 text-gray-800 rounded-none font-recoleta font-bold text-lg border-b-4 border-transparent hover:bg-gray-300 transition-all"
        : "inline-flex items-center gap-1 font-sans text-xs font-semibold text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white hover:underline w-fit";
        
      let html = '';
      if (href && href !== '#') {
        html += `<a href="${href}" target="_blank" rel="noopener noreferrer" class="${btnClass}">
          Source
          ${!isMobile ? '<svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>' : ''}
        </a>`;
      }
      if (bibRef) {
        html += `<a href="${bibRef}" class="${secClass}" onclick="closeSmartLinkUI()">
          Full citation
          ${!isMobile ? '<svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M16 17l-4 4m0 0l-4-4m4 4V3" /></svg>' : ''}
        </a>`;
      }
      return html;
    } 
    
    if (type === 'glossary' && (!href || href === '#')) {
      return ''; 
    }

    const linkText = type === 'video' ? 'Watch video' : type === 'feature' ? 'Explore feature' : type === 'external' ? 'Visit site' : 'Read more';
    const targetAttrs = type === 'external' ? 'target="_blank" rel="noopener noreferrer"' : '';
    
    if (isMobile) {
      return `<a href="${href}" ${targetAttrs} class="inline-flex items-center justify-center w-full py-3 px-4 bg-[#fd4f00] text-white text-center rounded-none font-recoleta font-bold text-lg border-b-4 border-transparent hover:bg-black transition-all">${linkText}</a>`;
    } else {
      return `<a href="${href}" ${targetAttrs} class="inline-flex items-center gap-1 font-sans text-xs font-semibold text-gray-500 dark:text-gray-400 hover:text-[#fd4f00] dark:hover:text-[#ff7635] hover:underline w-fit">
        ${linkText}
        <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
          ${type === 'external' ? '<path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />' : '<path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />'}
        </svg>
      </a>`;
    }
  }

  function getPremiumCardHTML(dataset: any, isInline: boolean = false) {
    const type = dataset.smartlinkType;
    const href = dataset.smartlinkHref || '#';
    const title = (dataset.smartlinkTitle || '').replace(/</g, '&lt;');
    const snippet = (dataset.smartlinkSnippet || '').replace(/</g, '&lt;');
    const icon = dataset.smartlinkIcon || '';
    
    if (type === 'academic') {
      const citeNum = dataset.smartlinkBibref ? dataset.smartlinkBibref.replace('#ref-', '') : '';
      return `
        <div class="relative w-full border border-[#E5D3B3] dark:border-gray-700 border-l-4 border-l-[#fd4f00] bg-white dark:bg-gray-800 p-4 pl-6 rounded-none shadow-md transition-all duration-300 not-prose mt-2 mb-2">
          ${citeNum ? `<span class="absolute -left-[14px] top-4 w-7 h-7 bg-[#fd4f00] text-white text-sm font-bold rounded-none flex items-center justify-center shadow-sm border-2 border-white dark:border-gray-800">${citeNum}</span>` : ''}
          <div class="font-sans text-sm font-bold text-gray-900 dark:text-white mb-1">
            ${title}
          </div>
          <div class="font-sans text-sm text-gray-800 dark:text-gray-200 leading-relaxed [&>a]:text-[#fd4f00] [&>a]:font-medium [&>a:hover]:underline [&>strong]:text-gray-900 dark:[&>strong]:text-white">
            ${snippet}
          </div>
          <div class="mt-3 flex items-center gap-3">
            ${getActionLinksHTML(type, dataset.smartlinkHref, dataset.smartlinkBibref, false)}
          </div>
        </div>
      `;
    }
    if (type === 'external') {
      return `
        <div class="relative w-full border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800/50 p-4 rounded-none shadow-sm transition-all duration-300 not-prose mt-2 mb-2 flex items-start gap-3">
          <div class="w-8 h-8 shrink-0 bg-gray-200 dark:bg-gray-700 flex items-center justify-center rounded-none text-gray-500 dark:text-gray-400">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
          </div>
          <div>
            <div class="font-sans text-sm font-bold text-gray-900 dark:text-white leading-tight">
              ${title}
            </div>
            <div class="font-sans text-xs text-gray-600 dark:text-gray-400 mt-1">
              ${snippet}
            </div>
            <div class="mt-2 flex items-center gap-3">
              ${getActionLinksHTML(type, dataset.smartlinkHref, dataset.smartlinkBibref, false)}
            </div>
          </div>
        </div>
      `;
    }

    let iconHtml = '';
    
    if (isInline) {
      if (icon) {
        iconHtml = `
          <div class="w-9 h-9 bg-gray-50 border border-[#E5D3B3] flex items-center justify-center p-1.5 rounded-none shrink-0">
            <img src="${icon}" alt="" class="w-full h-full object-contain" loading="lazy" />
          </div>`;
      }
      return `
        <div class="relative w-full border border-[#E5D3B3] dark:border-gray-700 border-l-4 border-l-[#fd4f00] bg-white dark:bg-gray-800 p-5 rounded-none shadow-md transition-all duration-300 not-prose group/feature block">
          <a href="${href}" class="absolute inset-0 z-10"><span class="sr-only">${title}</span></a>
          <div class="flex flex-row items-start gap-4">
            ${iconHtml}
            <div class="flex-grow pr-6">
              <h3 class="font-sans text-base font-bold text-[#fd4f00] dark:text-[#ff7635] leading-tight mb-1 m-0 group-hover/feature:underline">
                ${title}
              </h3>
              <p class="font-sans text-sm text-gray-600 dark:text-gray-400 leading-relaxed mb-0">
                ${snippet}
              </p>
            </div>
          </div>
          <div class="absolute bottom-5 right-5 text-[#fd4f00] dark:text-[#ff7635] opacity-60 group-hover/feature:opacity-100 transition-opacity">
            <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </div>
        </div>
      `;
    } else {
      if (icon) {
        iconHtml = `
          <div class="w-7 h-7 bg-gray-50 border border-[#E5D3B3] flex items-center justify-center p-1 rounded-none shrink-0">
            <img src="${icon}" alt="" class="w-full h-full object-contain" loading="lazy" />
          </div>`;
      }
      return `
        <div class="relative border border-[#E5D3B3] dark:border-gray-700 border-t-4 border-t-[#fd4f00] bg-white dark:bg-gray-800 p-4 rounded-none shadow-md hover:shadow-lg transition-all duration-300 not-prose group/feature">
          <div class="flex items-center gap-2.5 mb-2">
            ${iconHtml}
            <h3 class="font-sans text-sm font-bold text-[#fd4f00] dark:text-[#ff7635] leading-tight m-0">
              <a href="${href}" class="before:absolute before:inset-0 outline-none hover:underline">
                ${title}
              </a>
            </h3>
          </div>
          <p class="font-sans text-xs text-gray-600 dark:text-gray-400 mt-2 leading-relaxed pr-6">
            ${snippet}
          </p>
          <div class="absolute bottom-4 right-4 text-[#fd4f00] dark:text-[#ff7635] opacity-60 group-hover/feature:opacity-100 transition-opacity">
            <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </div>
        </div>
      `;
    }
  }

  window.closeSmartLinkUI = function() {
    const sheet = document.getElementById('smartlink-mobile-sheet');
    const scrim = document.getElementById('smartlink-scrim');
    const card  = document.getElementById('smartlink-desktop-card');
    
    if (sheet && scrim) {
      sheet.classList.add('translate-y-full');
      scrim.classList.remove('opacity-100');
      setTimeout(() => scrim.classList.add('hidden'), 300);
    }
    if (card) {
      card.classList.remove('opacity-100');
      setTimeout(() => card.classList.add('hidden'), 200);
    }
  };

  function getActiveTriggers(): HTMLElement[] {
    return Array.from(document.querySelectorAll('#content [data-smartlink-trigger="true"]')).filter((el: any) => {
      // Exclude triggers nested inside a bibliography reference
      return !el.closest('[id^="ref-"]');
    }) as HTMLElement[];
  }

  function resolveAcademicDetails(trigger: HTMLElement) {
    if (trigger.dataset.smartlinkType === 'academic') {
      const bibRef = trigger.dataset.smartlinkBibref || '';
      if (bibRef && (!trigger.dataset.smartlinkHref || trigger.dataset.smartlinkHref === '#')) {
        const bibId = bibRef.replace('#', '');
        const bibEl = document.getElementById(bibId);
        if (bibEl) {
          // Find the content div, skipping the badge span
          const contentDiv = bibEl.querySelector('[data-bib-content]') || bibEl;
          
          const links = Array.from(contentDiv.querySelectorAll('a'));
          // Find the first link that isn't a hash/internal link or a jumpback
          const extLink = links.find(l => {
            const h = l.getAttribute('href');
            return h && !h.startsWith('#') && !l.classList.contains('bib-jumpback');
          });
          
          let href = '#';
          if (extLink) {
            href = extLink.getAttribute('href') || '#';
          }
          
          let snippet = '';
          contentDiv.childNodes.forEach(node => {
            if (node.nodeType === Node.TEXT_NODE) {
              snippet += node.textContent;
            } else if (node.nodeType === Node.ELEMENT_NODE) {
              const el = node as HTMLElement;
              if (!el.classList.contains('bib-jumpback') && !el.hasAttribute('data-bib-badge')) {
                snippet += el.textContent;
              }
            }
          });
          snippet = snippet.replace(/^\d+\s*/, '').trim();

          // Try to extract a human-readable title from the snippet.
          let title = 'Academic Reference';
          
          const quoteMatch = snippet.match(/["'“”‘’]([^"'“”‘’]+)["'“”‘’]/);
          if (quoteMatch) {
             title = quoteMatch[1];
          } else if (extLink) {
             const linkText = (extLink.textContent || '').trim();
             const isUrl = /^https?:\/\//i.test(linkText) || /doi\.org/i.test(linkText);
             if (linkText && !isUrl) {
                title = linkText;
                snippet = snippet.replace(linkText, '').replace(/\(\s*\)/, '').trim();
             } else {
                const periodMatch = snippet.match(/^([^.]+)\./);
                if (periodMatch && periodMatch[1].length < 100) {
                   title = periodMatch[1];
                }
             }
          } else {
             const periodMatch = snippet.match(/^([^.]+)\./);
             if (periodMatch && periodMatch[1].length < 100) {
                title = periodMatch[1];
             }
          }
          
          // Clean up snippet: remove any trailing URLs or brackets
          if (href && href !== '#') {
            snippet = snippet.replace(href, '').trim();
          }
          // Remove trailing dots/punctuation from title
          title = title.replace(/\.$/, '').trim();
          
          // Limit length
          if (title.length > 100) {
            title = title.substring(0, 97) + '...';
          }
          if (snippet.length > 200) {
            snippet = snippet.substring(0, 197) + '...';
          }
          
          trigger.dataset.smartlinkHref = href;
          trigger.dataset.smartlinkTitle = title;
          trigger.dataset.smartlinkSnippet = snippet || '';
        }
      }
    }
  }

  function resolveExternalDetails(trigger: HTMLElement) {
    if (trigger.dataset.smartlinkType === 'external') {
      if (trigger.dataset.smartlinkManual === 'true') return;
      const domain = trigger.dataset.smartlinkTitle || 'External Link';
      const linkText = trigger.textContent?.trim() || '';
      
      let surroundingText = '';
      if (trigger.parentElement) {
        const textContent = trigger.parentElement.textContent || '';
        const sentences = textContent.match(/[^.!?]+[.!?]+/g) || [textContent];
        const linkSentence = sentences.find(s => s.includes(linkText)) || textContent;
        // Clean up the sentence to be a nice snippet
        surroundingText = linkSentence.replace(/\s+/g, ' ').trim();
        if (surroundingText.length > 120) surroundingText = surroundingText.substring(0, 117) + '...';
      }
      
      // Format domain as brand (e.g. sciencedirect.com -> Sciencedirect)
      const brandName = domain.split('.')[0];
      trigger.dataset.smartlinkTitle = brandName.charAt(0).toUpperCase() + brandName.slice(1);
      trigger.dataset.smartlinkSnippet = surroundingText || `External resource: ${domain}`;
    }
  }

  function openMobileSheet(trigger: HTMLElement) {
    resolveAcademicDetails(trigger);
    resolveExternalDetails(trigger);
    ensureUIElements();
    const sheet  = document.getElementById('smartlink-mobile-sheet');
    const scrim  = document.getElementById('smartlink-scrim');
    const title  = document.getElementById('sl-mobile-title');
    const snip   = document.getElementById('sl-mobile-snippet');
    const actions = document.getElementById('sl-mobile-actions');
    if (!sheet || !scrim || !actions) return;

    const type = trigger.dataset.smartlinkType || 'post';
    const href = trigger.dataset.smartlinkHref || '#';
    const bibRef = trigger.dataset.smartlinkBibref || '';

    if (title) title.textContent = trigger.dataset.smartlinkTitle  || 'Reference';
    if (snip)  snip.textContent  = trigger.dataset.smartlinkSnippet || '';
    
    if (type === 'academic') {
      if (title) {
        title.className = 'text-xl font-sans font-bold text-gray-900 dark:text-white mb-2';
        title.textContent = trigger.dataset.smartlinkTitle || 'Academic Reference';
      }
      if (snip) {
        snip.className = 'text-gray-700 dark:text-gray-300 font-serif text-base leading-relaxed mb-6';
        snip.innerHTML = trigger.dataset.smartlinkSnippet || '';
      }
    } else {
      if (title) {
        title.className = 'text-2xl font-bruta uppercase text-[#fd4f00] dark:text-[#ff7635] mb-3';
        title.textContent = trigger.dataset.smartlinkTitle || 'Reference';
      }
      if (snip) {
        snip.className = 'text-gray-700 dark:text-gray-300 font-recoleta text-lg leading-relaxed mb-6';
      }
    }

    actions.innerHTML = getActionLinksHTML(type, href, bibRef, true);

    scrim.classList.remove('hidden');
    requestAnimationFrame(() => {
      scrim.classList.add('opacity-100');
      sheet.classList.remove('translate-y-full');
    });

    const closeOnScrim = () => {
      window.closeSmartLinkUI();
      scrim.removeEventListener('click', closeOnScrim);
    };
    scrim.addEventListener('click', closeOnScrim);
  }

  function createPersistentCard(trigger: HTMLElement): HTMLElement {
    resolveAcademicDetails(trigger);
    resolveExternalDetails(trigger);
    const type = trigger.dataset.smartlinkType || 'post';
    const href = trigger.dataset.smartlinkHref || '#';
    const bibRef = trigger.dataset.smartlinkBibref || '';
    const youtubeId = trigger.dataset.smartlinkYoutubeId || '';
    let title = (trigger.dataset.smartlinkTitle || 'Reference').replace(/</g, '&lt;');
    const snippet = (trigger.dataset.smartlinkSnippet || '').replace(/</g, '&lt;');

    const card = document.createElement('div');
    card.className = 'absolute left-0 z-30 w-full smartlink-persistent-card group transition-all duration-300 pointer-events-auto transform rounded-none';

    if (type === 'feature' || type === 'benefit' || type === 'academic' || type === 'external') {
       card.classList.add('opacity-70', 'data-[hovered=true]:opacity-100', 'data-[hovered=true]:z-40');
       card.innerHTML = getPremiumCardHTML(trigger.dataset);
    } else {
       card.classList.add('sidebar-card', 'opacity-40', 'grayscale', 'dark:opacity-50', 'dark:grayscale', 'data-[hovered=true]:opacity-100', 'data-[hovered=true]:grayscale-0', 'data-[hovered=true]:z-40', 'rounded-none');
       const actionsHtml = getActionLinksHTML(type, href, bibRef, false);

       let mediaHtml = '';
       if (type === 'video' && youtubeId) {
         card.classList.remove('grayscale', 'dark:grayscale');
         card.classList.replace('opacity-40', 'opacity-60');
         card.classList.replace('dark:opacity-50', 'opacity-60');
         card.classList.add('opacity-60', 'transition-all', 'duration-300');
         card.dataset.hovered = 'false';
         card.style.padding = '0px';
         mediaHtml = `
           <div class="p-3 border-b border-[#E5D3B3] dark:border-gray-700 bg-white dark:bg-gray-800 rounded-none group-data-[hovered=true]:border-[#fd4f00]">
             <div class="sidebar-card-title">${title}</div>
           </div>
           <div class="w-full bg-black relative rounded-none overflow-hidden" style="padding-bottom: calc(100% / (9 / 16));">
             <lite-youtube videoid="${youtubeId}" playlabel="Play short" params="rel=0" class="absolute inset-0 w-full h-full"></lite-youtube>
           </div>
         `;
         card.innerHTML = mediaHtml;
       } else {
         card.innerHTML = `
           <h3 class="sidebar-card-title">${title}</h3>
           <p class="sidebar-card-snippet">${snippet}</p>
           <div class="mt-3 flex items-center gap-3">
             ${actionsHtml}
           </div>`;
       }
    }
    return card;
  }

  function showHoverCard(trigger: HTMLElement, e: MouseEvent) {
    if (window.innerWidth < 768 || window.innerWidth >= 1024) return;
    resolveAcademicDetails(trigger);
    clearTimeout(hoverTimeout);
    ensureUIElements();
    const card    = document.getElementById('smartlink-desktop-card');
    const dTitle  = document.getElementById('sl-desktop-title');
    const dSnip   = document.getElementById('sl-desktop-snippet');
    const actions = document.getElementById('sl-desktop-actions');
    if (!card || !actions) return;

    const type = trigger.dataset.smartlinkType || 'post';
    const href = trigger.dataset.smartlinkHref || '#';
    const bibRef = trigger.dataset.smartlinkBibref || '';

    if (dTitle) dTitle.textContent = trigger.dataset.smartlinkTitle  || 'Reference';
    if (dSnip)  dSnip.textContent  = trigger.dataset.smartlinkSnippet || '';
    
    actions.innerHTML = getActionLinksHTML(type, href, bibRef, false);

    const cardWidth  = 320; // w-80
    const cardH      = card.offsetHeight || 180;
    const roomAbove  = e.clientY > cardH + 10;
    
    let leftPos = e.clientX - (cardWidth / 2);
    leftPos = Math.max(16, Math.min(leftPos, window.innerWidth - cardWidth - 16));
    
    card.style.left     = `${leftPos}px`;
    card.style.width    = `${cardWidth}px`;
    card.style.top      = roomAbove
      ? `${e.clientY - cardH - 4}px`
      : `${e.clientY + 4}px`;

    card.classList.remove('hidden');
    requestAnimationFrame(() => card.classList.add('opacity-100'));
  }

  function hideHoverCard() {
    hoverTimeout = window.setTimeout(() => {
      const card = document.getElementById('smartlink-desktop-card');
      if (card) {
        card.classList.remove('opacity-100');
        setTimeout(() => {
          if (!card.classList.contains('opacity-100')) {
            card.classList.add('hidden');
          }
        }, 200);
      }
    }, 150);
  }

  function positionPersistentCards() {
    if (window.innerWidth < 1024) return;
    const sidebar = document.getElementById('blog-right-sidebar');
    if (!sidebar) return;

    // Remove existing dynamic cards to recalculate cleanly
    sidebar.querySelectorAll('.smartlink-persistent-card').forEach(c => c.remove());

    const contentArea = document.getElementById('content');
    if (!contentArea) return;
    const contentTop = contentArea.getBoundingClientRect().top + window.scrollY;

    const placedCards: { top: number; bottom: number; el: HTMLElement; isFallback?: boolean }[] = [];
    const minGap = 32;
    const minTopOffset = 400; // Fallback cards must not appear within first 400px of article
    const minFallbackSeparation = 250; // Min vertical distance between fallback cards
    
    // Account for existing static sidebar items (Lead Capture, Video)
    const staticItems = Array.from(sidebar.children).filter(el => !el.classList.contains('smartlink-persistent-card')) as HTMLElement[];
    let staticHeightUsed = 0;
    
    if (staticItems.length > 0) {
        const lastItem = staticItems[staticItems.length - 1];
        staticHeightUsed = lastItem.offsetTop + lastItem.offsetHeight + minGap;
        
        staticItems.forEach(item => {
           placedCards.push({
               top: item.offsetTop,
               bottom: item.offsetTop + item.offsetHeight,
               el: item
           });
        });
    }

    const allTriggers = getActiveTriggers();

    // Fallback Logic: Inject at most 1 feature + 1 benefit card
    const fallbackDataEl = document.getElementById('smartlink-fallback-data');
    if (fallbackDataEl) {
        let features: any[] = [];
        let benefits: any[] = [];
        try {
            features = JSON.parse(fallbackDataEl.dataset.features || '[]');
            benefits = JSON.parse(fallbackDataEl.dataset.benefits || '[]');
        } catch(e) {}
        
        // Find first unlinked feature
        let featureFallback: any = null;
        for (const f of features) {
            const isLinked = allTriggers.some(el => {
                return el.dataset.smartlinkType === 'feature' && (el.dataset.smartlinkHref || '').includes(f.id);
            });
            if (!isLinked) { featureFallback = { type: 'feature', ...f }; break; }
        }
        
        // Find first unlinked benefit
        let benefitFallback: any = null;
        for (const b of benefits) {
            const isLinked = allTriggers.some(el => {
                return el.dataset.smartlinkType === 'benefit' && (el.dataset.smartlinkHref || '').includes(b.id);
            });
            if (!isLinked) { benefitFallback = { type: 'benefit', ...b }; break; }
        }

        const fallbackItems = [featureFallback, benefitFallback].filter(Boolean);
        const headings = Array.from(document.querySelectorAll('.prose h2')) as HTMLElement[];
        
        // Place feature at H2#1, benefit at H2#3+ (with minimum separation)
        const targetIndices = [1, Math.max(3, Math.min(headings.length - 1, 4))];
        let lastFallbackY = -Infinity;
        
        fallbackItems.forEach((item, index) => {
            const hIdx = Math.min(targetIndices[index] || 1, headings.length - 1);
            const heading = headings[hIdx];
            if (heading) {
                const dummyTrigger = document.createElement('span');
                Object.assign(dummyTrigger.dataset, {
                    smartlinkType: item.type,
                    smartlinkHref: item.url,
                    smartlinkTitle: item.title,
                    smartlinkSnippet: item.description,
                    smartlinkIcon: item.icon
                });
                const pCard = createPersistentCard(dummyTrigger);
                pCard.dataset.hovered = 'true'; 
                pCard.classList.remove('opacity-70'); // fully opaque fallback
                
                sidebar.appendChild(pCard);
                const h = pCard.offsetHeight || 120;
                
                let idealY = (heading.getBoundingClientRect().top + window.scrollY) - contentTop;
                idealY = Math.max(idealY, staticHeightUsed);
                idealY = Math.max(idealY, minTopOffset); // Enforce minimum distance from top
                idealY = Math.max(idealY, lastFallbackY + minFallbackSeparation); // Enforce separation
                lastFallbackY = idealY + h;

                placedCards.push({
                    top: idealY,
                    bottom: idealY + h,
                    el: pCard,
                    isFallback: true
                });
            }
        });
    }

    // Now place natural triggers
    const keyToCard = new Map<string, HTMLElement>();
    const seenKeys = new Set<string>();

    allTriggers.forEach((trigger) => {
      if (trigger.dataset.smartlinkType === 'video-widescreen') return;

      resolveAcademicDetails(trigger);
      const key = trigger.dataset.smartlinkBibref || trigger.dataset.smartlinkHref || trigger.dataset.smartlinkTitle || '';
      if (!key) return;

      let cardEl = keyToCard.get(key);
      if (!cardEl) {
        cardEl = trigger.cardEl || createPersistentCard(trigger);
        keyToCard.set(key, cardEl);

        const currentCardEl = cardEl; // Capture in closure
        if (!currentCardEl.dataset.cardHoverBound) {
          currentCardEl.dataset.cardHoverBound = 'true';
          currentCardEl.addEventListener('mouseenter', () => {
            currentCardEl.dataset.hovered = 'true';
            allTriggers.forEach(t => {
              if (t.cardEl === currentCardEl) {
                t.dataset.highlighted = 'true';
              }
            });
            if (currentCardEl.dataset.smartlinkType === 'video') {
              currentCardEl.classList.replace('opacity-60', 'opacity-100');
            }
          });
          currentCardEl.addEventListener('mouseleave', () => {
            currentCardEl.dataset.hovered = 'false';
            allTriggers.forEach(t => {
              if (t.cardEl === currentCardEl) {
                t.dataset.highlighted = 'false';
              }
            });
            if (currentCardEl.dataset.smartlinkType === 'video') {
              currentCardEl.classList.replace('opacity-100', 'opacity-60');
            }
          });
        }
      }

      trigger.cardEl = cardEl;
      sidebar.appendChild(cardEl);

      if (!seenKeys.has(key)) {
        seenKeys.add(key);

        const triggerRect = trigger.getBoundingClientRect();
        const triggerY = (triggerRect.top + window.scrollY) - contentTop;

        let idealY = triggerY;
        idealY = Math.max(idealY, staticHeightUsed);

        const h = cardEl.offsetHeight || 120;
        placedCards.push({ top: idealY, bottom: idealY + h, el: cardEl });
      }
    });

    // Identify table blocker regions
    const tables = Array.from(document.querySelectorAll('.prose .table-wrapper')) as HTMLElement[];
    const tableBlockers = tables.map(t => {
      const rect = t.getBoundingClientRect();
      const top = (rect.top + window.scrollY) - contentTop - minGap;
      const bottom = (rect.bottom + window.scrollY) - contentTop + minGap;
      return { top, bottom };
    });

    // Resolve overlaps (Shift DOWN)
    placedCards.sort((a, b) => a.top - b.top);
    for (let i = 0; i < placedCards.length; i++) {
      const curr = placedCards[i];
      const cardH = curr.bottom - curr.top;
      
      // 1. Avoid previous cards
      if (i > 0) {
        const prev = placedCards[i - 1];
        if (curr.top < prev.bottom + minGap) {
          const shift = (prev.bottom + minGap) - curr.top;
          curr.top += shift;
          curr.bottom += shift;
        }
      }

      // 2. Avoid tables — try placing ABOVE the table first, then below
      for (const tb of tableBlockers) {
        if (curr.top < tb.bottom && curr.bottom > tb.top) {
          // Card overlaps this table. Try above first.
          const abovePos = tb.top - cardH - minGap;
          const belowPos = tb.bottom;
          // Only place above if there's room (not overlapping previous card)
          const prevBottom = i > 0 ? placedCards[i - 1].bottom + minGap : staticHeightUsed;
          if (abovePos >= prevBottom && abovePos >= 0) {
            curr.top = abovePos;
            curr.bottom = abovePos + cardH;
          } else {
            // Place below the table
            curr.top = belowPos;
            curr.bottom = belowPos + cardH;
          }
        }
      }
      // Final check: if still overlapping any table after repositioning, push below
      let overlapWithTable = true;
      let safetyCounter = 0;
      while (overlapWithTable && safetyCounter < 10) {
        overlapWithTable = false;
        safetyCounter++;
        for (const tb of tableBlockers) {
          if (curr.top < tb.bottom && curr.bottom > tb.top) {
            curr.top = tb.bottom;
            curr.bottom = tb.bottom + cardH;
            overlapWithTable = true;
          }
        }
      }
    }

    // Resolve bottom collision (Shift UP)
    const prose = document.querySelector('.prose') as HTMLElement;
    if (prose && placedCards.length > 0) {
       const proseBottom = prose.offsetTop + prose.offsetHeight;
       const lastCard = placedCards[placedCards.length - 1];
       if (lastCard.bottom > proseBottom) {
          const shiftUp = lastCard.bottom - proseBottom;
          lastCard.top -= shiftUp;
          lastCard.bottom -= shiftUp;
          
          for (let i = placedCards.length - 2; i >= 0; i--) {
             const curr = placedCards[i];
             const next = placedCards[i + 1];
             if (curr.bottom > next.top - minGap) {
                const overlap = curr.bottom - (next.top - minGap);
                curr.top -= overlap;
                curr.bottom -= overlap;
             }
          }
       }
    }

    // Apply styles
    placedCards.forEach(c => {
       if (c.el.classList.contains('smartlink-persistent-card')) {
           c.el.style.top = `${c.top}px`;
       }
    });

    const lastCardFinal = placedCards[placedCards.length - 1];
    if (lastCardFinal) {
      sidebar.style.minHeight = `${lastCardFinal.bottom + minGap}px`;
    }
  }

  function attachSmartLinkEvents() {
    // Reset bindings and remove dynamic tablet cards to prevent duplication on re-runs
    document.querySelectorAll('.smartlink-tablet-card').forEach(c => c.remove());
    document.querySelectorAll('[data-has-inline-card]').forEach(el => el.removeAttribute('data-has-inline-card'));
    document.querySelectorAll('[data-smartlink-inline-bound]').forEach(el => el.removeAttribute('data-smartlink-inline-bound'));
    document.querySelectorAll('[data-smartlink-events-bound]').forEach(el => el.removeAttribute('data-smartlink-events-bound'));

    const triggers = getActiveTriggers();
    
    // Inject inline tablet cards
    triggers.forEach(el => {
        const trigger = el as HTMLElement;
        if (trigger.dataset.smartlinkInlineBound) return;
        trigger.dataset.smartlinkInlineBound = 'true';
        
        const type = trigger.dataset.smartlinkType;
        if (type === 'feature' || type === 'benefit' || type === 'video-widescreen') {
            const parentP = trigger.closest('p, li') as HTMLElement;
            if (parentP && parentP.parentNode && !parentP.dataset.hasInlineCard) {
                const inlineCard = document.createElement('div');
                
                if (type === 'video-widescreen') {
                    const youtubeId = trigger.dataset.smartlinkYoutubeId || '';
                    if (youtubeId) {
                        inlineCard.className = 'smartlink-tablet-card w-full my-8 not-prose';
                        inlineCard.innerHTML = `
                            <div class="w-full bg-black relative rounded-none overflow-hidden shadow-lg border border-[#E5D3B3] dark:border-gray-700" style="padding-bottom: calc(100% / (16 / 9));">
                                <lite-youtube videoid="${youtubeId}" params="rel=0" class="absolute inset-0 w-full h-full"></lite-youtube>
                            </div>
                        `;
                    }
                } else {
                    inlineCard.className = 'smartlink-tablet-card block lg:hidden my-6';
                    inlineCard.innerHTML = getPremiumCardHTML(trigger.dataset, true);
                }
                
                parentP.after(inlineCard);
                parentP.dataset.hasInlineCard = 'true';
            }
        }
    });
    
    // Tablet Fallback Injection — max 1 feature + 1 benefit
    const fallbackDataEl = document.getElementById('smartlink-fallback-data');
    if (fallbackDataEl) {
        let features: any[] = [];
        let benefits: any[] = [];
        try {
            features = JSON.parse(fallbackDataEl.dataset.features || '[]');
            benefits = JSON.parse(fallbackDataEl.dataset.benefits || '[]');
        } catch(e) {}
        
        let featureFallback: any = null;
        for (const f of features) {
            const isLinked = triggers.some((el: any) => el.dataset.smartlinkType === 'feature' && (el.dataset.smartlinkHref || '').includes(f.id)) || 
                             Array.from(document.querySelectorAll('[data-feature-callout-anchor="true"] a')).some(a => (a.getAttribute('href') || '').includes(f.id));
            if (!isLinked) { featureFallback = { type: 'feature', ...f }; break; }
        }
        let benefitFallback: any = null;
        for (const b of benefits) {
            const isLinked = triggers.some((el: any) => el.dataset.smartlinkType === 'benefit' && (el.dataset.smartlinkHref || '').includes(b.id));
            if (!isLinked) { benefitFallback = { type: 'benefit', ...b }; break; }
        }
        
        const fallbackItems = [featureFallback, benefitFallback].filter(Boolean);
        const headings = Array.from(document.querySelectorAll('.prose h2')) as HTMLElement[];
        const targetIndices = [1, Math.max(3, Math.min(headings.length - 1, 4))];
        
        fallbackItems.forEach((item: any, index: number) => {
            const hIdx = Math.min(targetIndices[index] || 1, headings.length - 1);
            const heading = headings[hIdx];
            if (heading && !heading.dataset.hasInlineCard) {
                const dummyData = {
                    smartlinkType: item.type,
                    smartlinkHref: item.url,
                    smartlinkTitle: item.title,
                    smartlinkSnippet: item.description,
                    smartlinkIcon: item.icon
                };
                const inlineCard = document.createElement('div');
                inlineCard.className = 'smartlink-tablet-card block lg:hidden my-6';
                inlineCard.innerHTML = getPremiumCardHTML(dummyData, true);
                heading.after(inlineCard);
                heading.dataset.hasInlineCard = 'true';
            }
        });
    }

    const card = document.getElementById('smartlink-desktop-card');
    
    triggers.forEach(el => {
      const trigger = el as HTMLElement;
      if (trigger.dataset.smartlinkEventsBound) return;
      trigger.dataset.smartlinkEventsBound = 'true';
      
      trigger.addEventListener('click', (e) => {
        const type = trigger.dataset.smartlinkType;
        if (type === 'video') {
          e.preventDefault();
          return;
        }

        const useMobileSheet = window.innerWidth < 768 && window.matchMedia('(pointer: coarse)').matches;
        if (useMobileSheet) {
          e.preventDefault();
          openMobileSheet(trigger);
        } else if (window.innerWidth >= 768 && window.innerWidth < 1024 && window.matchMedia('(pointer: coarse)').matches) {
          if (type !== 'feature' && type !== 'benefit') {
            e.preventDefault();
            showHoverCard(trigger, e);
          }
        }
      });

      trigger.addEventListener('mouseenter', (e) => {
        if (window.innerWidth >= 1024) {
          const pCard = trigger.cardEl;
          if (pCard) {
            pCard.dataset.hovered = 'true';
            if (pCard.dataset.smartlinkType === 'video') {
              pCard.classList.replace('opacity-60', 'opacity-100');
            }
          }
        } else if (window.innerWidth >= 768) {
          const type = trigger.dataset.smartlinkType;
          if (type !== 'feature' && type !== 'benefit') {
              showHoverCard(trigger, e);
          }
        }
      });

      trigger.addEventListener('mouseleave', () => {
        if (window.innerWidth >= 1024) {
          const pCard = trigger.cardEl;
          if (pCard) {
            pCard.dataset.hovered = 'false';
            if (pCard.dataset.smartlinkType === 'video') {
              pCard.classList.replace('opacity-100', 'opacity-60');
            }
          }
        } else if (window.innerWidth >= 768) {
          hideHoverCard();
        }
      });
    });

    if (card) {
      card.addEventListener('mouseenter', () => {
        clearTimeout(hoverTimeout);
      });
      card.addEventListener('mouseleave', hideHoverCard);
    }
    
    requestAnimationFrame(positionPersistentCards);
    setTimeout(positionPersistentCards, 500);
  }

  // Custom typings
  declare global {
    interface HTMLElement {
      cardEl?: HTMLElement;
    }
    interface Window {
      closeSmartLinkUI: () => void;
    }
  }

  // Initialize
  if (!document.getElementById('smartlink-scrim')) {
    ensureUIElements();
  }
  attachSmartLinkEvents();
  document.addEventListener('astro:page-load', attachSmartLinkEvents);

  let resizeTimer: number;
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimer);
    resizeTimer = window.setTimeout(positionPersistentCards, 100);
  });
</script>

