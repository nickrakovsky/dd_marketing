---

import '../styles/global.css';
import brutaFont from '../assets/fonts/BrutaGlbCompressed-ExtraBold.woff2';
import recoletaReg from '../assets/fonts/Recoleta-Regular.woff2';
import recoletaSemi from '../assets/fonts/Recoleta-SemiBold.woff2';
import { getAuthor } from '../data/authors';
import { CALENDLY_BOOKING_URL, CALENDLY_BOOKING_FRAGMENT, CALENDLY_BRAND_COLOR } from '../lib/calendly-config.mjs';

interface Props {
    title: string;
    description?: string;
    image?: string;
    type?: "website" | "article" | "video";
    noindex?: boolean;

    schemaData?: {
        faq?: { question: string; answer: string }[];
        reviews?: { author: string; quote: string; role?: string }[];
    };
    articleData?: {
        author: string;
        pubDate: Date;
        updatedDate?: Date;
        section?: string;
    };
    videoData?: {
        youtubeId: string;
        uploadDate: Date;
        duration?: string;
    };
}

const {
  title,
  description = "Optimize your dock scheduling and yard management with DataDocks. Reduce wait times, digitize operations, and delight your carriers.",
  image = "/images/OG-Cover.png",
  type = "website",
  noindex = false,

  schemaData,
  articleData,
  videoData
} = Astro.props;

const PUBLIC_BENTO_UUID = import.meta.env.PUBLIC_BENTO_SITE_UUID;
// Normalize pathname: strip trailing slash AND strip .html suffix (build.format: 'file' emits paths with .html)
const pathname = Astro.url.pathname === '/'
  ? '/'
  : Astro.url.pathname.replace(/\.html$/, '').replace(/\/$/, '');

const canonicalURL = new URL(pathname, Astro.site);
const socialImageURL = new URL(image, Astro.site);

// 5. Schema Assembly
const graph: any[] = [
  // 1. Organization (Identity)
  {
    "@type": "Organization",
    "@id": "https://datadocks.com/#organization",
    "name": "DataDocks",
    "legalName": "Northfire Inc.",
    "url": "https://datadocks.com",
    "logo": {
      "@type": "ImageObject",
      "url": "https://datadocks.com/images/Orange-Logo.svg",
      "width": 201,
      "height": 43
    },
    "description": "Dock scheduling software for warehouses and distribution centers. Reduce truck wait times with automated appointment scheduling.",
    "foundingDate": "2013",
    "sameAs": [
      "https://www.linkedin.com/company/datadocks",
      "https://x.com/datadocks",
      "https://www.youtube.com/@DataDocks",
      "https://www.capterra.com/p/179266/DataDocks/"
    ],
    "contactPoint": {
      "@type": "ContactPoint",
      "telephone": "+1-647-848-8250",
      "contactType": "Sales",
      "email": "info@datadocks.com",
      "areaServed": "Worldwide",
      "availableLanguage": ["English"]
    }
  },
  // 2. WebSite (Search & Discovery)
  {
    "@type": "WebSite",
    "@id": "https://datadocks.com/#website",
    "url": "https://datadocks.com",
    "name": "DataDocks",
    "description": "Dock Scheduling Software for Warehouses",
    "publisher": { "@id": "https://datadocks.com/#organization" }
  },
  // 3. WebPage (Accessibility & Context) — use specific types for known pages
  {
    "@type": pathname === '/' ? "WebPage"
           : pathname === '/about' ? "AboutPage"
           : pathname === '/posts' ? "CollectionPage"
           : "ItemPage",
    "@id": canonicalURL.toString(),
    "url": canonicalURL.toString(),
    "name": title,
    "description": description,
    "isPartOf": { "@id": "https://datadocks.com/#website" },
    "primaryImageOfPage": { "@type": "ImageObject", "url": socialImageURL.toString() },
    "accessibilityControl": ["fullKeyboardControl", "fullMouseControl"],
    "accessibilityFeature": ["alternativeText", "ARIA"],
    ...(Astro.url.pathname.split('/').filter(Boolean).length > 0 ? { "breadcrumb": { "@id": `${canonicalURL.toString()}#breadcrumb` } } : {})
  },
];

// 4. SoftwareApplication — homepage only (Google requires visible reviews on the page)
if (pathname === '/') {
  graph.push({
    "@type": "SoftwareApplication",
    "@id": "https://datadocks.com/#software",
    "name": "DataDocks",
    "applicationCategory": "BusinessApplication",
    "applicationSubCategory": "Dock Scheduling and Yard Management Software",
    "operatingSystem": "Web, iOS, Android",
    "description": "Dock scheduling and yard management software for logistics facilities. Automate dock appointments, reduce detention charges, and increase warehouse capacity.",
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": 4.9,
      "reviewCount": 50,
      "bestRating": 5,
      "worstRating": 1
    },
    "featureList": [
      "Self-service carrier portal",
      "Real-time yard visibility",
      "Automated capacity management",
      "Smart notifications",
      "ERP and WMS integration",
      "Custom business rules engine",
      "Efficiency reporting and analytics",
      "Yard management",
      "Dock scheduling",
      "Native iOS and Android mobile apps"
    ],
    "screenshot": "https://datadocks.com/images/DataDocks-Calendar-Screenshot.webp"
  });
}

// 5. Reviews (Social Proof)
if (schemaData?.reviews) {
  schemaData.reviews.forEach((review: any) => {
    graph.push({
      "@type": "Review",
      "author": {
        "@type": "Person",
        "name": review.author
      },
      "reviewBody": review.quote,
      "reviewRating": {
        "@type": "Rating",
        "ratingValue": 5,
        "bestRating": 5
      },
      ...(review.source ? { 
        "publisher": { 
          "@type": "Organization", 
          "name": review.source 
        } 
      } : {}),
      ...(review.url ? { "url": review.url } : {}),
      "itemReviewed": { 
        "@type": "SoftwareApplication",
        "@id": "https://datadocks.com/#software",
        "name": "DataDocks"
      }
    });
  });
}

// 6. Breadcrumbs (Structure) — only add when there are path segments (not homepage)
const breadcrumbItems = Astro.url.pathname.split('/').filter(Boolean);
if (breadcrumbItems.length > 0) {
  graph.push({
    "@type": "BreadcrumbList",
    "@id": `${canonicalURL.toString()}#breadcrumb`,
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://datadocks.com" },
      ...breadcrumbItems.map((path, index, arr) => {
        let name = path.replace(/-/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase());
        if (index === arr.length - 1) {
          // Use short labels for known collection/section pages, full title for leaf pages
          const shortLabels: Record<string, string> = { 'posts': 'Blog', 'benefits': 'Benefits', 'integrations': 'Integrations', 'about': 'About' };
          name = shortLabels[path] || title;
        }
        return {
          "@type": "ListItem",
          "position": index + 2,
          "name": name,
          "item": new URL(arr.slice(0, index + 1).join('/').replace(/\.html$/, ''), Astro.site).toString()
        };
      })
    ]
  });
}

if (schemaData?.faq) {
  graph.push({
    "@type": "FAQPage",
    "@id": `${canonicalURL.toString()}#faq`,
    "mainEntity": schemaData.faq.map((item: any) => ({
      "@type": "Question",
      "name": item.question,
      "acceptedAnswer": { "@type": "Answer", "text": item.answer }
    }))
  });
}

// Feature page: describe as part of the main DataDocks SoftwareApplication.
// We use WebPage (not a second SoftwareApplication) so Google doesn't flag
// missing aggregateRating/offers. The main SoftwareApplication on homepage
// carries the rich result signals.
// Integration pages: same pattern.

if (type === 'article' && articleData) {
  const authorData = getAuthor(articleData.author);
  graph.push({
    "@type": "BlogPosting",
    "@id": `${canonicalURL.toString()}#article`,
    "mainEntityOfPage": { "@id": canonicalURL.toString() },
    "headline": title.replace(/\s*\|.*$/, ''),
    "description": description,
    "image": socialImageURL.toString(),
    "datePublished": articleData.pubDate.toISOString(),
    "dateModified": (articleData.updatedDate || articleData.pubDate).toISOString(),
    "author": {
      "@type": "Person",
      "@id": `https://datadocks.com/about#${authorData.slug}`,
      "name": authorData.name,
      "url": `https://datadocks.com/about#${authorData.slug}`,
      "jobTitle": authorData.role,
      "worksFor": { "@id": "https://datadocks.com/#organization" },
      ...(authorData.linkedIn ? { "sameAs": [authorData.linkedIn] } : {})
    },
    "publisher": { "@id": "https://datadocks.com/#organization" },
    "articleSection": articleData.section,
    "inLanguage": "en",
    "isAccessibleForFree": true
  });
}


if (videoData) {
  graph.push({
    "@type": "VideoObject",
    "name": title,
    "description": description,
    "thumbnailUrl": [
      `https://img.youtube.com/vi/${videoData.youtubeId}/maxresdefault.jpg`,
      `https://img.youtube.com/vi/${videoData.youtubeId}/hqdefault.jpg`
    ],
    "uploadDate": videoData.uploadDate.toISOString(),
    ...(videoData.duration ? { "duration": videoData.duration } : {}),
    "contentUrl": `https://www.youtube.com/watch?v=${videoData.youtubeId}`,
    "embedUrl": `https://www.youtube.com/embed/${videoData.youtubeId}`,
    "publisher": { "@id": "https://datadocks.com/#organization" }
  });
}

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": graph
};
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <title>{title}</title>
        <meta name="description" content={description} />
        <link rel="canonical" href={canonicalURL} />
        <meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow"} />
        <meta name="generator" content={Astro.generator} />
        <meta name="keywords" content="dock scheduling software, yard management system, logistics SaaS, supply chain automation" />

        <meta property="og:type" content={type} />
        <meta property="og:url" content={canonicalURL} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content={socialImageURL} />
        <meta property="og:site_name" content="DataDocks" />

        <meta property="twitter:card" content="summary_large_image" />
        <meta property="twitter:url" content={canonicalURL} />
        <meta property="twitter:title" content={title} />
        <meta property="twitter:description" content={description} />
        <meta property="twitter:image" content={socialImageURL} />
        <meta name="twitter:creator" content="@datadocks" />

        <link rel="icon" href="/favicon.png" />
        <link rel="sitemap" href="/sitemap.xml" />
        <meta name="theme-color" content="#FFF8E9" />

<link rel="preload" as="font" type="font/woff2" href={brutaFont} crossorigin />
        {/* Only Bruta is preloaded — it's the H1/LCP font.
             Recoleta loads via @font-face with font-display:swap; the Georgia
             fallback (with size-adjust metrics) renders immediately. Preloading
             all 3 fonts (146 KB) was saturating mobile bandwidth. */}

        {/* lite-youtube CSS is now injected conditionally via <slot name="head" />
             by BlogPostLayout (when hasYouTube) and video pages. Saves 2 KB of
             render-blocking CSS on pages without YouTube embeds. */}
        <slot name="head" />

        <script type="application/ld+json" set:html={JSON.stringify(jsonLd)}></script>

        {/* GTM removed - GA4 now handled by Cloudflare Zaraz */}
        <link rel="dns-prefetch" href="https://fast.bentonow.com" />

        <style is:inline set:html={`
            @font-face {
              font-family: 'Recoleta-Fallback';
              src: local('Georgia');
              size-adjust: 98.7952%;
              ascent-override: 101.2195%;
              descent-override: 36.4252%;
              line-gap-override: 0%;
            }
            @font-face {
              font-family: 'Bruta-Fallback';
              src: local('Impact');
              size-adjust: 102.5000%;
              ascent-override: 73.1707%;
              descent-override: 24.3902%;
              line-gap-override: 33.1707%;
            }
            @font-face { font-family: 'Bruta'; src: url('${brutaFont}') format('woff2'); font-weight: 800; font-display: swap; }
            @font-face { font-family: 'DD-Recoleta'; src: url('${recoletaReg}') format('woff2'); font-weight: 400; font-display: swap; }
            @font-face { font-family: 'DD-Recoleta'; src: url('${recoletaSemi}') format('woff2'); font-weight: 600; font-display: swap; }

            @view-transition {
              navigation: auto;
            }
        `}></style>

    </head>
    <body>
        <slot />
        {/* GA4 is now implemented via Cloudflare Zaraz
        <script is:inline>
            window.dataLayer = window.dataLayer || [];
            function gtag(){window.dataLayer.push(arguments);}
            gtag('js', new Date());
            gtag('config', 'G-EZMTT6QYLJ');
            // Defer GTM load to after page is interactive
            (function() {
              const loadGTM = () => {
                var s = document.createElement('script');
                s.src = 'https://www.googletagmanager.com/gtag/js?id=G-EZMTT6QYLJ';
                s.async = true;
                document.head.appendChild(s);
              };
              if ('requestIdleCallback' in window) {
                requestIdleCallback(loadGTM);
              } else {
                setTimeout(loadGTM, 2000);
              }
            })();

        </script>
        */}

        {/* Attribution capture, Bento UUID helper, and Calendly popup launcher.
             First-touch attribution persists in localStorage so even a direct
             return visit weeks later still books the demo with the original
             utm_source. Calendly's popup widget loads on demand so we hear the
             event_scheduled postMessage and forward to Zaraz/GA4 only on real
             completed bookings — links to calendly.com/* are intercepted and
             reopened in the popup. */}
        <script is:inline define:vars={{ CALENDLY_BOOKING_URL, CALENDLY_BOOKING_FRAGMENT, CALENDLY_BRAND_COLOR }}>
          (function() {
            // --- Telemetry helper ----------------------------------------
            // We swallow most errors silently so the script doesn't halt and
            // break the booking flow. But silent failure means we never know
            // when localStorage is broken, Calendly assets fail to load, or
            // postMessages are getting rejected. This emits a single rate-
            // limited dataLayer event per error type per session so GA4 can
            // surface aggregate breakage trends without flooding logs.
            var telemetrySeen = {};
            function ddReportError(stage, detail) {
              if (telemetrySeen[stage]) return;
              telemetrySeen[stage] = true;
              try {
                var payload = { event: 'dd_attribution_error', stage: stage, detail: String(detail || '').slice(0, 200) };
                window.dataLayer = window.dataLayer || [];
                window.dataLayer.push(payload);
                if (window.zaraz && typeof window.zaraz.track === 'function') {
                  window.zaraz.track('dd_attribution_error', { stage: stage, detail: payload.detail });
                }
              } catch { /* nothing more we can do */ }
            }

            // --- Landing page (session-scoped, kept for Bento) -----------
            if (!sessionStorage.getItem('dd_landing_page')) {
              sessionStorage.setItem('dd_landing_page', window.location.href);
            }

            // --- Attribution: first-touch and last-touch -----------------
            var UTM_KEYS = ['utm_source', 'utm_medium', 'utm_campaign', 'utm_term', 'utm_content'];
            var params = new URLSearchParams(window.location.search);
            var hasUtm = UTM_KEYS.some(function(k) { return params.get(k); });

            var ref = '';
            try { ref = document.referrer ? new URL(document.referrer).hostname : ''; } catch { /* noop */ }
            var sameHost = ref && ref === window.location.hostname;

            var touch = {
              utm_source: params.get('utm_source') || (hasUtm ? '' : (ref && !sameHost ? ref : 'direct')),
              utm_medium: params.get('utm_medium') || (hasUtm ? '' : (ref && !sameHost ? 'referral' : 'direct')),
              utm_campaign: params.get('utm_campaign') || '',
              utm_term: params.get('utm_term') || '',
              utm_content: params.get('utm_content') || '',
              gclid: params.get('gclid') || '',
              referrer: ref,
              landing: window.location.pathname,
              ts: new Date().toISOString()
            };

            try {
              if (!localStorage.getItem('dd_first_touch')) {
                localStorage.setItem('dd_first_touch', JSON.stringify(touch));
              }
              // Update last-touch only when the visit carries a real source signal
              if (hasUtm || (ref && !sameHost)) {
                localStorage.setItem('dd_last_touch', JSON.stringify(touch));
              }
            } catch (err) {
              // Most likely Safari private mode quota or storage full. Means
              // attribution is degraded for this user — they'll show as direct.
              ddReportError('storage_write', err && err.message);
            }

            window.ddGetAttribution = function() {
              var first = {}, last = {};
              try { first = JSON.parse(localStorage.getItem('dd_first_touch') || '{}'); } catch { /* noop */ }
              try { last = JSON.parse(localStorage.getItem('dd_last_touch') || '{}'); } catch { /* noop */ }
              return { first: first, last: last };
            };

            // --- Known-email helpers (set when user submits any CTA form) ---
            // The email is what makes funnel-stage drop-off actionable in Bento.
            // Without it we can still see aggregate drop-off in GA4 but can't follow up
            // with the specific person who abandoned.
            window.ddSetEmail = function(email) {
              if (!email || typeof email !== 'string') return;
              try { localStorage.setItem('dd_known_email', email); } catch { /* noop */ }
            };
            window.ddGetEmail = function() {
              try { return localStorage.getItem('dd_known_email') || ''; } catch { return ''; }
            };

            // --- Bento visitor UUID helper -------------------------------
            window.getBentoVisitorUuid = function() {
              var cookies = document.cookie.split(';');
              for (var i = 0; i < cookies.length; i++) {
                var c = cookies[i].trim();
                if (c.indexOf('bento_') === 0) {
                  return c.split('=').slice(1).join('=');
                }
              }
              return null;
            };

            // --- Calendly popup loader + UTM injection -------------------
            // CALENDLY_BOOKING_URL is injected via define:vars from
            // src/lib/calendly-config.mjs — single source of truth.
            var CALENDLY_BASE = CALENDLY_BOOKING_URL;
            var calendlyAssetsLoaded = false;

            function loadCalendlyAssets() {
              if (calendlyAssetsLoaded) return Promise.resolve();
              calendlyAssetsLoaded = true;
              var css = document.createElement('link');
              css.rel = 'stylesheet';
              css.href = 'https://assets.calendly.com/assets/external/widget.css';
              document.head.appendChild(css);
              return new Promise(function(resolve) {
                var s = document.createElement('script');
                s.src = 'https://assets.calendly.com/assets/external/widget.js';
                s.async = true;
                s.onload = function() { resolve(); };
                s.onerror = function() {
                  calendlyAssetsLoaded = false;
                  // Calendly's CDN failing is a critical event — booking is
                  // about to fall back to opening a new tab. We want to know.
                  ddReportError('calendly_assets_load', 'widget.js failed');
                  resolve();
                };
                document.head.appendChild(s);
              });
            }

            function buildUtm() {
              var first = {};
              try { first = JSON.parse(localStorage.getItem('dd_first_touch') || '{}'); } catch { /* noop */ }
              return {
                utmSource: first.utm_source || 'direct',
                utmMedium: first.utm_medium || 'direct',
                utmCampaign: first.utm_campaign || '',
                utmTerm: first.utm_term || '',
                utmContent: first.utm_content || ''
              };
            }

            window.ddOpenCalendly = function(extraUrlParams) {
              loadCalendlyAssets().then(function() {
                var utm = buildUtm();
                // Preserve any query params already on the link (e.g. primary_color)
                var url = CALENDLY_BASE;
                if (extraUrlParams) {
                  url += (url.indexOf('?') === -1 ? '?' : '&') + extraUrlParams;
                }
                // Pre-fill email if a prior CTA form already captured it.
                // Calendly uses the `prefill` config, not URL params, when launched
                // via initPopupWidget — saves the user a step on return visits.
                var prefill = {};
                var knownEmail = window.ddGetEmail();
                if (knownEmail) prefill.email = knownEmail;

                if (window.Calendly && typeof window.Calendly.initPopupWidget === 'function') {
                  var opts = {
                    url: url,
                    utm: utm,
                    pageSettings: { primaryColor: CALENDLY_BRAND_COLOR }
                  };
                  if (knownEmail) opts.prefill = prefill;
                  window.Calendly.initPopupWidget(opts);
                } else {
                  ddReportError('popup_fallback', 'window.Calendly missing');
                  // Fallback if the widget script failed — append UTMs to the URL and open new tab
                  var qp = new URLSearchParams();
                  Object.keys(utm).forEach(function(k) {
                    if (utm[k]) {
                      var snake = k.replace(/[A-Z]/g, function(m) { return '_' + m.toLowerCase(); });
                      qp.set(snake, utm[k]);
                    }
                  });
                  var sep = url.indexOf('?') === -1 ? '?' : '&';
                  window.open(url + sep + qp.toString(), '_blank', 'noopener');
                }
              });
            };

            // --- Intercept calendly.com links and route through the popup
            // Selector uses CALENDLY_BOOKING_FRAGMENT so blog posts and any
            // other inline-Markdown links to the handle are auto-caught.
            var INTERCEPT_SELECTOR = 'a[href*="' + CALENDLY_BOOKING_FRAGMENT + '"]';
            document.addEventListener('click', function(e) {
              var a = e.target && e.target.closest && e.target.closest(INTERCEPT_SELECTOR);
              if (!a) return;
              if (e.metaKey || e.ctrlKey || e.shiftKey || e.button === 1) return; // let user open in new tab
              e.preventDefault();
              var href = a.getAttribute('href') || '';
              var qIdx = href.indexOf('?');
              var extra = qIdx >= 0 ? href.slice(qIdx + 1) : '';
              window.ddOpenCalendly(extra);
            });

            // --- Listen for Calendly funnel events --------------------------
            // We track all four stages so GA4 can show drop-off rates and Bento
            // can drive abandonment follow-ups for known emails.
            //
            //   profile_page_viewed     → saw the calendar
            //   event_type_viewed       → opened the demo event type
            //   date_and_time_selected  → picked a slot
            //   event_scheduled         → completed the booking (the conversion)
            var FUNNEL_EVENTS = {
              'calendly.profile_page_viewed':    'demo_profile_viewed',
              'calendly.event_type_viewed':      'demo_event_type_viewed',
              'calendly.date_and_time_selected': 'demo_date_selected',
              'calendly.event_scheduled':        'demo_booked'
            };

            // Strict origin allow-list — Calendly only ever postMessages from
            // the apex (https://calendly.com). Substring matching ('calendly.com')
            // would also accept https://calendly.com.attacker.example.
            var ALLOWED_ORIGINS = { 'https://calendly.com': true };
            // Track which funnel stages have already fired this page load so we
            // don't double-count when users open/close/reopen the popup.
            var firedStages = {};

            window.addEventListener('message', function(e) {
              if (!e.data || typeof e.data !== 'object') return;
              if (!ALLOWED_ORIGINS[e.origin]) return;
              var calendlyEvent = e.data.event;
              if (!calendlyEvent || !FUNNEL_EVENTS[calendlyEvent]) return;

              var ddEvent = FUNNEL_EVENTS[calendlyEvent];
              // Dedupe: profile_viewed/event_type_viewed/date_selected can fire
              // many times in a single popup session as the user navigates
              // around. We only want one record per stage per page load —
              // matches how a sane funnel report should count.
              if (firedStages[ddEvent]) return;
              firedStages[ddEvent] = true;

              var attribution = window.ddGetAttribution();
              var knownEmail = window.ddGetEmail();
              var payload = {
                event_category: 'demo',
                funnel_stage: ddEvent,
                first_utm_source: attribution.first.utm_source || 'direct',
                first_utm_medium: attribution.first.utm_medium || 'direct',
                first_utm_campaign: attribution.first.utm_campaign || '',
                first_landing_page: attribution.first.landing || '',
                last_utm_source: attribution.last.utm_source || '',
                last_utm_medium: attribution.last.utm_medium || '',
                last_utm_campaign: attribution.last.utm_campaign || ''
              };

              // GA4 (via Zaraz) — anonymous funnel reporting
              if (window.zaraz && typeof window.zaraz.track === 'function') {
                window.zaraz.track(ddEvent, payload);
              }
              if (typeof window.gtag === 'function') {
                window.gtag('event', ddEvent, payload);
              }
              window.dataLayer = window.dataLayer || [];
              window.dataLayer.push(Object.assign({ event: ddEvent }, payload));

              // Bento — only when we know who they are. This is what enables
              // per-person abandonment follow-up. Skipped silently for
              // anonymous visitors (the nav button path) since we have no
              // way to email them.
              if (knownEmail) {
                fetch('/api/bento-track', {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify({
                    email: knownEmail,
                    event: ddEvent,
                    source: window.location.pathname,
                    landingPage: sessionStorage.getItem('dd_landing_page') || window.location.href,
                    visitorUuid: (typeof window.getBentoVisitorUuid === 'function') ? window.getBentoVisitorUuid() : null
                  }),
                  keepalive: true
                }).catch(function() {});
              }
            });
          })();
        </script>

        {PUBLIC_BENTO_UUID && (
          <Fragment>
            {/* Set bentoSettings on the main thread so Partytown can read it */}
            <script is:inline define:vars={{ PUBLIC_BENTO_UUID }}>
                window.bentoSettings = { uuid: PUBLIC_BENTO_UUID };
            </script>
            {/* Load the actual Bento SDK inside a Partytown Web Worker */}
            <script is:inline type="text/partytown" src={`https://fast.bentonow.com?site_uuid=${PUBLIC_BENTO_UUID}`}></script>
          </Fragment>
        )}
    </body>
</html>

<style>
    html, body { margin: 0; width: 100%; overflow-x: clip; }
</style>