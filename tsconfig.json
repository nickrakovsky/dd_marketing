{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "jsx": "react-jsx",
    "jsxImportSource": "react"
  },
  "include": [
    "src/**/*",
    "astro.config.mjs",
    ".astro/types.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "public",
    "webflow-migration",
    "assets-for-import",
    "analysis",
    "internal-marketing"
  ]
}